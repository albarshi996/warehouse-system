# Firebase web configuration. Copy this file to `.env` and replace the values
# with the ones from your Firebase console (Project settings → General →
# "Your apps" → SDK setup and configuration).
#
# All variables MUST be prefixed with `PUBLIC_` so that Astro inlines them
# into the client bundle. They are NOT secrets — Firebase web API keys are
# designed to be shipped to browsers and are protected by Firestore Security
# Rules + Firebase Auth, not by hiding the key.

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
