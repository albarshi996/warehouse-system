# Firebase web configuration. Copy this file to `.env` and replace the values
# with the ones from your Firebase console (Project settings → General →
# "Your apps" → SDK setup and configuration).
#
# All variables MUST be prefixed with `PUBLIC_` so that Astro inlines them
# into the client bundle. They are NOT secrets — Firebase web API keys are
# designed to be shipped to browsers and are protected by Firestore Security
# Rules + Firebase Auth, not by hiding the key.

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# ─── Odoo integration ───────────────────────────────────────────────────────
# Two safe-to-inline PUBLIC_ vars control the frontend. Leaving them unset (or
# MODE=training) keeps the app on the OFFLINE mock — no Odoo, no network.
#
#   training   → src/services/odoo/mockOdooClient.js  (default)
#   production → src/services/odoo/odooClient.js  →  PUBLIC_ODOO_PROXY_URL
PUBLIC_ODOO_MODE=training
PUBLIC_ODOO_PROXY_URL=

# ─── Odoo SECRETS — DO NOT put these here or prefix them with PUBLIC_ ────────
# These are TRUE secrets and must live ONLY inside the server-side proxy's
# secret store (see /odoo-proxy). They are listed here for documentation only;
# never commit real values, and never expose them to the browser.
#   ODOO_URL       = https://yourcompany.odoo.com
#   ODOO_DB        = your_database_name
#   ODOO_USER      = your_login_email
#   ODOO_API_KEY   = your_odoo_api_key
