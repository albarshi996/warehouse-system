---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
---

<DashboardLayout title="لوحة التحكم" showGuide={false}>
  <div class="text-right" dir="rtl">
    {/* Header */}
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white mb-2">
        محمد البرشي — متخصص سلاسل الإمداد
        <span class="block text-lg font-normal text-gray-400 mt-1">Supply Chain Specialist — Benghazi 2026</span>
      </h1>
      <p class="text-gray-400 text-sm mb-4 leading-relaxed">
        هذا الموقع يعرض رؤيتي التشغيلية لتحديث إدارة المستودعات والتوزيع في بنغازي
      </p>
      <div class="w-20 h-1 bg-brand-red rounded-full mb-6" />

      <!-- Prominent Report Banner -->
      <a href={`${base}/dashboard/cold-storage-plan`} class="block mb-6">
        <div class="rounded-2xl p-6 shadow-2xl border border-brand-red/30 bg-gradient-to-r from-brand-red via-[#c0392b] to-[#8b1a1a]">
          <h2 class="text-3xl font-extrabold text-white">تقرير تخزين الكوزمتيك</h2>
          <p class="text-white/90 mt-3 max-w-2xl">استعراض خطة تخزين الكوزمتيك الموحدة لمجمع الرحبة وتفاصيل الطاقة الاستيعابية والبيانات التشغيلية.</p>
          <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm text-white/90">
            📊 استعراض التقرير الموحد
          </div>
        </div>
      </a>
      
      <div class="bg-gradient-to-r from-blue-900/20 to-green-900/20 rounded-xl p-6 border border-blue-500/30">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 text-center">
          <div>
            <div class="text-2xl font-bold text-blue-400">١٩ نموذجاً</div>
            <div class="text-sm text-gray-400">النماذج التشغيلية الموثقة</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-green-400">٢٠ حياً</div>
            <div class="text-sm text-gray-400">مرصودة في خريطة التجزئة</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-yellow-400">٥ دورات</div>
            <div class="text-sm text-gray-400">مالية · HR · مشتريات · مستودعات · سلاسل الإمداد</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-purple-400">٤ مراحل</div>
            <div class="text-sm text-gray-400">خطة تنفيذ Odoo</div>
          </div>
        </div>
      </div>
    </div>

    {/* Quick Actions */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
      <a href={`${base}/dashboard/forms`} class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">📋</div>
          <h3 class="font-bold text-blue-400 mb-2">النماذج التشغيلية</h3>
          <p class="text-sm text-gray-300">استعرض النماذج الـ١٩ — قلب التوثيق العملي</p>
        </div>
      </a>
      <a href={`${base}/dashboard/retail-hub`} class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">🗺️</div>
          <h3 class="font-bold text-brand-yellow mb-2">خريطة الأسواق</h3>
          <p class="text-sm text-gray-300">تحليل فئات المستهلكين والأسواق في بنغازي</p>
        </div>
      </a>
      <a href={`${base}/dashboard/workflows`} class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">🏢</div>
          <h3 class="font-bold text-brand-yellow mb-2">الدورة المستندية</h3>
          <p class="text-sm text-gray-300">الهيكل التنظيمي ومسارات المستندات</p>
        </div>
      </a>
      <a href={`${base}/dashboard/cold-storage-plan`} class="block group">
        <div class="bg-brand-navy border border-brand-gold/20 rounded-xl p-6 hover:bg-brand-navy/90 transition-all hover:-translate-y-1">
          <div class="text-4xl mb-3">🏭</div>
          <h3 class="font-bold text-brand-gold mb-2">مخطط مجمع التبريد الرحبة</h3>
          <p class="text-sm text-gray-200">خريطة الوحدات والتوزيع داخل الرحبة لتخزين الكوزميتيك.</p>
        </div>
      </a>
      <a href={`${base}/dashboard/erp-workflows`} class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">⚙️</div>
          <h3 class="font-bold text-green-400 mb-2">رؤية Odoo</h3>
          <p class="text-sm text-gray-300">الدورات المستندية على Odoo Enterprise</p>
        </div>
      </a>
    </div>

    {/* Odoo Implementation Overview */}
    <section class="mt-10 mb-8">
      <div class="rounded-2xl bg-gradient-to-br from-green-900/20 via-blue-900/20 to-green-900/20 shadow-2xl border border-green-500/30 p-6 sm:p-10 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-64 h-64 bg-green-500/10 rounded-full blur-3xl pointer-events-none" />
        <div class="absolute bottom-0 right-0 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl pointer-events-none" />

        <div class="relative z-10">
          <h2 class="text-xl sm:text-2xl font-bold text-white text-center mb-2">
            نظرة عامة على تنفيذ أودو
            <span class="block text-sm font-normal text-gray-400 mt-1">Odoo Implementation Overview</span>
          </h2>
          <div class="w-16 h-1 bg-green-400 mx-auto mb-8 rounded-full" />

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-blue-500/10 backdrop-blur border border-blue-500/30 rounded-xl p-5">
              <div class="font-bold text-blue-400 mb-2">المرحلة 1</div>
              <h3 class="font-bold text-white mb-2">التقييم والتخطيط</h3>
              <div class="text-xs text-gray-400 mb-3">2-3 أسابيع</div>
              <ul class="space-y-1">
                <li class="text-xs text-gray-300">• تحليل المتطلبات</li>
                <li class="text-xs text-gray-300">• تخطيط الموارد</li>
                <li class="text-xs text-gray-300">• اختيار الشريك</li>
              </ul>
            </div>
            
            <div class="bg-green-500/10 backdrop-blur border border-green-500/30 rounded-xl p-5">
              <div class="font-bold text-green-400 mb-2">المرحلة 2</div>
              <h3 class="font-bold text-white mb-2">الإعداد الأساسي</h3>
              <div class="text-xs text-gray-400 mb-3">3-4 أسابيع</div>
              <ul class="space-y-1">
                <li class="text-xs text-gray-300">• تثبيت النظام</li>
                <li class="text-xs text-gray-300">• إعدادات الأمان</li>
                <li class="text-xs text-gray-300">• هيكل الشركة</li>
              </ul>
            </div>
            
            <div class="bg-yellow-500/10 backdrop-blur border border-yellow-500/30 rounded-xl p-5">
              <div class="font-bold text-yellow-400 mb-2">المرحلة 3</div>
              <h3 class="font-bold text-white mb-2">نقل البيانات</h3>
              <div class="text-xs text-gray-400 mb-3">4-6 أسابيع</div>
              <ul class="space-y-1">
                <li class="text-xs text-gray-300">• تنظيف البيانات</li>
                <li class="text-xs text-gray-300">• تخطيط النقل</li>
                <li class="text-xs text-gray-300">• التحقق من الصحة</li>
              </ul>
            </div>
            
            <div class="bg-purple-500/10 backdrop-blur border border-purple-500/30 rounded-xl p-5">
              <div class="font-bold text-purple-400 mb-2">المرحلة 4</div>
              <h3 class="font-bold text-white mb-2">التدريب والإطلاق</h3>
              <div class="text-xs text-gray-400 mb-3">2-3 أسابيع</div>
              <ul class="space-y-1">
                <li class="text-xs text-gray-300">• تدريب المستخدمين</li>
                <li class="text-xs text-gray-300">• اختبار شامل</li>
                <li class="text-xs text-gray-300">• الدعم الفني</li>
              </ul>
            </div>
          </div>

          <div class="bg-white/5 backdrop-blur border border-green-500/30 rounded-xl p-5">
            <h3 class="font-bold text-green-400 mb-3 flex items-center gap-2">
              <span>📋</span> التكلفة تُحدد بعد التنسيق مع إدارة تقنية المعلومات
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
              <div>
                <div class="text-lg font-bold text-blue-400">التراخيص</div>
                <div class="text-gray-400 text-sm">التكلفة تُحدد بعد التنسيق مع IT</div>
              </div>
              <div>
                <div class="text-lg font-bold text-green-400">التنفيذ</div>
                <div class="text-gray-400 text-sm">التكلفة تُحدد بعد التنسيق مع IT</div>
              </div>
              <div>
                <div class="text-lg font-bold text-yellow-400">التدريب</div>
                <div class="text-gray-400 text-sm">التكلفة تُحدد بعد التنسيق مع IT</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Key Benefits */}
    <section class="mt-10 mb-8">
      <div class="rounded-2xl bg-gradient-to-br from-brand-navy via-[#1a1a3e] to-[#0d0d2b] shadow-2xl border border-brand-red/20 p-6 sm:p-10">
        <h2 class="text-xl sm:text-2xl font-bold text-white text-center mb-6">
          مزايا التكامل مع أودو
          <span class="block text-sm font-normal text-gray-400 mt-1">Key Benefits of Odoo Integration</span>
        </h2>
        <div class="w-16 h-1 bg-brand-red mx-auto mb-8 rounded-full" />

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6">
            <div class="text-3xl mb-3">🎯</div>
            <h3 class="font-bold text-brand-red mb-2">دقة البيانات</h3>
            <p class="text-sm text-gray-300">98.5%+ مطابقة للبيانات قبل الإدخال في أودو</p>
          </div>
          
          <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6">
            <div class="text-3xl mb-3">⚡</div>
            <h3 class="font-bold text-brand-yellow mb-2">مزامنة فورية</h3>
            <p class="text-sm text-gray-300">تحديث فوري للبيانات بين الأنظمة</p>
          </div>
          
          <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6">
            <div class="text-3xl mb-3">📊</div>
            <h3 class="font-bold text-green-400 mb-2">تقارير موحدة</h3>
            <p class="text-sm text-gray-300">تقارير شاملة من مصدر واحد موثوق</p>
          </div>
        </div>
      </div>
    </section>

    {/* Tech Stack Section */}
    <section class="mt-10 mb-8">
      <div class="rounded-2xl bg-white/5 border border-white/10 p-6 sm:p-10">
        <h2 class="text-xl sm:text-2xl font-bold text-white text-center mb-2">التقنيات والخدمات المستخدمة في هذا المقترح</h2>
        <div class="w-16 h-1 bg-brand-red mx-auto mb-8 rounded-full" />
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
          <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center"><div class="text-2xl mb-2">⚡</div><div class="font-bold text-white text-sm">Astro + React</div><div class="text-xs text-gray-400 mt-1">واجهة حديثة وسريعة</div></div>
          <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center"><div class="text-2xl mb-2">☁️</div><div class="font-bold text-white text-sm">Firebase</div><div class="text-xs text-gray-400 mt-1">قاعدة بيانات سحابية</div></div>
          <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center"><div class="text-2xl mb-2">📋</div><div class="font-bold text-white text-sm">١٩ نموذجاً</div><div class="text-xs text-gray-400 mt-1">نماذج تشغيلية بمنطق تحقق</div></div>
          <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center"><div class="text-2xl mb-2">🔷</div><div class="font-bold text-white text-sm">Odoo Enterprise</div><div class="text-xs text-gray-400 mt-1">توثيق الدورات المستندية</div></div>
          <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center"><div class="text-2xl mb-2">📷</div><div class="font-bold text-white text-sm">Barcode Scanner</div><div class="text-xs text-gray-400 mt-1">تكامل قارئ الباركود</div></div>
          <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center"><div class="text-2xl mb-2">🌐</div><div class="font-bold text-white text-sm">GitHub Pages</div><div class="text-xs text-gray-400 mt-1">استضافة مجانية وموثوقة</div></div>
          <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center"><div class="text-2xl mb-2">🔤</div><div class="font-bold text-white text-sm">Cairo Font + RTL</div><div class="text-xs text-gray-400 mt-1">واجهة عربية كاملة</div></div>
        </div>
      </div>
    </section>

    {/* Next Steps Section */}
    <section class="mt-8 mb-8">
      <div class="rounded-2xl bg-gradient-to-br from-brand-navy via-[#1a1a3e] to-[#0d0d2b] border border-brand-red/20 p-6 sm:p-10">
        <h2 class="text-xl sm:text-2xl font-bold text-white text-center mb-6">الخطوات التالية</h2>
        <div class="w-16 h-1 bg-brand-red mx-auto mb-8 rounded-full" />
        <div class="space-y-4 mb-8 max-w-2xl mx-auto">
          <div class="bg-white/5 border border-white/10 rounded-xl p-6">
            <h3 class="font-bold text-brand-yellow mb-2">١. الموافقة المبدئية</h3>
            <p class="text-gray-400 text-sm leading-relaxed">اعتماد المقترح للانتقال إلى مرحلة التنسيق مع إدارة تقنية المعلومات</p>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-xl p-6">
            <h3 class="font-bold text-brand-yellow mb-2">٢. تعيين مسؤول تقني</h3>
            <p class="text-gray-400 text-sm leading-relaxed">تحديد مسؤول من IT لدراسة متطلبات التكامل مع الأنظمة القائمة</p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <button onclick="window.print()" class="px-8 py-4 bg-brand-red text-white rounded-xl font-bold hover:bg-brand-red-dark transition-all shadow-md active:scale-95">
            🖨️ طباعة التقرير الكامل
          </button>
          <a href="mailto:?subject=طلب اجتماع — مقترح سلاسل الإمداد&body=السلام عليكم،%0Aأود مناقشة المقترح المرفق:%0Ahttps://albarshi996.github.io/warehouse-system/" class="px-8 py-4 bg-transparent border-2 border-white text-white rounded-xl font-bold hover:bg-white hover:text-brand-navy transition-all text-center">
            ✉️ طلب اجتماع بالبريد
          </a>
        </div>
      </div>
    </section>

    {/* Footer */}
    <div class="text-center text-sm text-gray-500 mt-8">
      إعداد: محمد البرشي — متخصص سلاسل الإمداد · بنغازي ٢٠٢٦ · غير تجاري
    </div>
  </div>
</DashboardLayout>
