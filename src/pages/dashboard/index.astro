---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
---

<DashboardLayout title="لوحة التحكم" showGuide={false}>
  <div class="text-right" dir="rtl">
    {/* Header */}
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white mb-2">
        محمد البرشي — متخصص سلاسل الإمداد
        <span class="block text-lg font-normal text-gray-200 mt-1">Supply Chain Specialist — Benghazi 2026</span>
      </h1>
      <p class="text-gray-200 text-sm mb-4 leading-relaxed">
        بوابة العمليات الرسمية لإدارة المستودعات والتوزيع في بنغازي
      </p>
      <div class="w-20 h-1 bg-brand-red rounded-full mb-6" />

      <!-- Prominent Report Banner -->
      <a href={`${base}/dashboard/cold-storage-plan`} class="block mb-6">
        <div class="rounded-2xl p-6 shadow-2xl border border-brand-red/30 bg-gradient-to-r from-brand-red via-[#c41e3a] to-[#7e2b2a]">
          <h2 class="text-3xl font-extrabold text-white">مخطط وتقرير تخزين الكوزمتيك</h2>
          <p class="text-white/90 mt-3 max-w-2xl">عرض المخطط الفني وتوليد تقارير التخزين لوحدات الرحبة.</p>
          <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm text-white/90">
            🏭 فتح مخطط مجمع التبريد
          </div>
        </div>
      </a>
      
      <div class="bg-gradient-to-r from-blue-900/20 to-green-900/20 rounded-xl p-6 border border-blue-500/30">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 text-center">
          <div>
            <div class="text-2xl font-bold text-blue-400">١٩ نموذجاً</div>
            <div class="text-sm text-gray-200">النماذج التشغيلية الموثقة</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-green-400">٢٠ حياً</div>
            <div class="text-sm text-gray-200">مرصودة في خريطة التجزئة</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-yellow-400">٥ دورات</div>
            <div class="text-sm text-gray-200">مالية · HR · مشتريات · مستودعات · سلاسل الإمداد</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-purple-400">٤ قواعد ذهبية</div>
            <div class="text-sm text-gray-200">دورات عمل Odoo التشغيلية</div>
          </div>
        </div>
      </div>
    </div>

    {/* Centers: Reports + Foundation Archive */}
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-8">
      <a href={`${base}/dashboard/reports`} class="block group">
        <div class="h-full rounded-2xl p-6 border border-brand-gold/30 bg-gradient-to-br from-brand-navy via-[#1a1a3e] to-[#0d0d2b] shadow-xl hover:-translate-y-1 transition-all">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-3xl">📊</span>
            <h3 class="text-lg font-bold text-brand-gold">مركز التقارير</h3>
          </div>
          <p class="text-sm text-gray-200 leading-relaxed">كل تقارير المنظومة — التشغيلية والجودة والتحليلية والتوثيق المرئي — في مكان واحد.</p>
          <span class="mt-3 inline-flex items-center gap-1 text-brand-yellow text-sm font-bold">فتح المركز <span class="group-hover:-translate-x-1 transition-transform">←</span></span>
        </div>
      </a>
      <a href={`${base}/dashboard/archive`} class="block group">
        <div class="h-full rounded-2xl p-6 border border-white/10 bg-white/5 backdrop-blur shadow-xl hover:bg-white/10 hover:-translate-y-1 transition-all">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-3xl">🗄️</span>
            <h3 class="text-lg font-bold text-white">الأرشيف التأسيسي</h3>
          </div>
          <p class="text-sm text-gray-200 leading-relaxed">الوثائق التأسيسية: خطة تنفيذ أودو، مزايا التكامل، التقنيات المشغِّلة، وخطوات الاعتماد.</p>
          <span class="mt-3 inline-flex items-center gap-1 text-brand-yellow text-sm font-bold">فتح الأرشيف <span class="group-hover:-translate-x-1 transition-transform">←</span></span>
        </div>
      </a>
    </div>

    {/* Quick Actions */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
      <a href={`${base}/dashboard/forms`} class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">📋</div>
          <h3 class="font-bold text-blue-400 mb-2">النماذج التشغيلية</h3>
          <p class="text-sm text-gray-100">استعرض النماذج الـ١٩ — قلب التوثيق العملي</p>
        </div>
      </a>
      <a href={`${base}/dashboard/retail-hub`} class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">🗺️</div>
          <h3 class="font-bold text-brand-yellow mb-2">خريطة الأسواق</h3>
          <p class="text-sm text-gray-100">تحليل فئات المستهلكين والأسواق في بنغازي</p>
        </div>
      </a>
      <a href={`${base}/dashboard/workflows`} class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">🏢</div>
          <h3 class="font-bold text-brand-yellow mb-2">الدورة المستندية</h3>
          <p class="text-sm text-gray-100">الهيكل التنظيمي ومسارات المستندات</p>
        </div>
      </a>
      <a href={`${base}/dashboard/cold-storage-plan`} class="block group">
        <div class="bg-brand-navy border border-brand-gold/20 rounded-xl p-6 hover:bg-brand-navy/90 transition-all hover:-translate-y-1">
          <div class="text-4xl mb-3">🏭</div>
          <h3 class="font-bold text-brand-gold mb-2">مخطط مجمع التبريد الرحبة</h3>
          <p class="text-sm text-gray-200">خريطة الوحدات والتوزيع داخل الرحبة لتخزين الكوزميتيك.</p>
        </div>
      </a>
      <a href={`${base}/dashboard/erp-workflows`} class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">⚙️</div>
          <h3 class="font-bold text-green-400 mb-2">دورات عمل Odoo</h3>
          <p class="text-sm text-gray-100">الدورات المستندية التشغيلية على Odoo</p>
        </div>
      </a>
      <a href={`${base}/dashboard/assets-inventory`} class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">🗂️</div>
          <h3 class="font-bold text-brand-yellow mb-2">جرد الأصول</h3>
          <p class="text-sm text-gray-100">جرد أجهزة ومركبات ومكاتب برانزو مع التصدير</p>
        </div>
      </a>
      <a href={`${base}/dashboard/vehicles-inventory`} class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">🚗</div>
          <h3 class="font-bold text-green-400 mb-2">جرد المركبات</h3>
          <p class="text-sm text-gray-100">تفتيش شامل للمركبات مع استمارة التسليم والاستلام</p>
        </div>
      </a>
      <a href={`${base}/dashboard/global-warehouse-report`} class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">🌍</div>
          <h3 class="font-bold text-teal-400 mb-2">المقارنة العالمية</h3>
          <p class="text-sm text-gray-100">مقارنة النظام التشغيلي مع عمالقة اللوجستيات العالمية</p>
        </div>
      </a>
      <a href={`${base}/تقرير-التوظيف-والجدول-الزمني.html`} target="_blank" class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">👥</div>
          <h3 class="font-bold text-brand-yellow mb-2">تقرير التوظيف</h3>
          <p class="text-sm text-gray-100">جدول زمن إدارة المستودعات والهيكل الوظيفي</p>
        </div>
      </a>
      <a href={`${base}/dashboard/achievement-report`} class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">✅</div>
          <h3 class="font-bold text-green-400 mb-2">تقرير الانجاز</h3>
          <p class="text-sm text-gray-100">سجل الإنجازات اليومية والمهام التشغيلية</p>
        </div>
      </a>
      <a href={`${base}/dashboard/development-proposals`} class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">💡</div>
          <h3 class="font-bold text-brand-yellow mb-2">مقترحات التطوير</h3>
          <p class="text-sm text-gray-100">تحسين كفاءة المستودعات والمعايير الهندسية</p>
        </div>
      </a>
      <a href={`${base}/dashboard/warehouse-155-report`} class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">🏢</div>
          <h3 class="font-bold text-brand-red mb-2">تقرير تحوير 155</h3>
          <p class="text-sm text-gray-100">تحوير المستودعات لرفع الكفاءة التشغيلية</p>
        </div>
      </a>
      <a href={`${base}/عمليات-مخزنية.html`} target="_blank" class="block group">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-xl p-6 hover:bg-white/10 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">📦</div>
          <h3 class="font-bold text-teal-400 mb-2">عمليات مخزنية</h3>
          <p class="text-sm text-gray-100">نظام تفاعلي لإدارة الجرد والعمليات اليومية</p>
        </div>
      </a>
    </div>

    {/* Quality Management Report Section */}
    <section class="mb-8">
      <div class="rounded-2xl overflow-hidden border border-brand-red/20 shadow-2xl bg-brand-navy/50" style="height: 80vh; min-height: 600px;">
        <div class="bg-brand-red/10 px-6 py-3 border-b border-brand-red/20 flex items-center justify-between">
          <h2 class="text-xl font-bold text-white flex items-center gap-2">
            <span>🏆</span> تقرير إدارة الجودة الشاملة
          </h2>
          <a href={`${base}/تقرير-إدارة-الجودة.html`} target="_blank" class="text-xs text-brand-yellow hover:underline flex items-center gap-1">
             فتح في نافذة جديدة ↗
          </a>
        </div>
        <iframe
          src={`${base}/تقرير-إدارة-الجودة.html`}
          title="تقرير إدارة الجودة الشاملة"
          class="w-full h-full border-0"
          loading="lazy"
        ></iframe>
      </div>
    </section>

    {/* Foundation Archive pointer — moved founding/evaluation sections */}
    <section class="mt-10 mb-8">
      <a href={`${base}/dashboard/archive`} class="block group">
        <div class="rounded-2xl border border-brand-gold/25 bg-brand-gold/5 p-6 sm:p-8 hover:bg-brand-gold/10 transition-all">
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:justify-between">
            <div class="flex items-start gap-3">
              <span class="text-3xl">🗄️</span>
              <div>
                <h2 class="text-lg sm:text-xl font-bold text-brand-gold mb-1">الأرشيف التأسيسي</h2>
                <p class="text-sm text-gray-200 leading-relaxed max-w-2xl">
                  نظرة عامة على تنفيذ أودو (٤ مراحل)، ومزايا التكامل، والتقنيات المشغِّلة
                  للمنصة، وخطوات الاعتماد المبدئي — محفوظة كمرجع تأسيسي بعيداً عن العمل اليومي.
                </p>
              </div>
            </div>
            <span class="inline-flex items-center gap-1 text-brand-yellow text-sm font-bold whitespace-nowrap">
              فتح الأرشيف <span class="group-hover:-translate-x-1 transition-transform">←</span>
            </span>
          </div>
        </div>
      </a>
    </section>

    {/* Footer */}
    <div class="text-center text-sm text-gray-200 mt-8">
      إعداد: محمد البرشي — متخصص سلاسل الإمداد · بنغازي ٢٠٢٦ · غير تجاري
    </div>
  </div>
</DashboardLayout>
