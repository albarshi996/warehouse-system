---
/**
 * متابعة العمليات — شاشة المدير: العمليات الجارية ومن يعمل عليها وسجلّ المسح الحيّ.
 * تقرأ ما تكتبه منظومة «الجرد الذكي» في Firestore لحظياً.
 * القاعدة الذهبية: لا حذف — صفحة ومكوّن جديدان (stock/).
 */
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import OperationsMonitor from '../../components/brandzo-erp/stock/OperationsMonitor.jsx';
---

<DashboardLayout title="متابعة العمليات" showGuide={false}>
  <div class="text-right" dir="rtl">
    <div class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">📡 متابعة العمليات</h1>
      <p class="text-gray-300 text-sm leading-relaxed max-w-3xl">
        تابع الجرد والاستلام <span class="text-brand-gold font-bold">لحظة بلحظة</span> من مكتبك:
        أي عملية مفتوحة الآن، ومن يعمل عليها، وكل مسح باسم من نفّذه ووقته — من سجلّ دائم لا يُعدَّل.
      </p>
      <div class="w-20 h-1 bg-brand-red rounded-full mt-3"></div>
    </div>

    <OperationsMonitor client:load />
  </div>
</DashboardLayout>
