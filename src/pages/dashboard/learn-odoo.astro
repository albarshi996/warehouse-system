---
/**
 * تعلم أودو (Learn Odoo) — بيئة تدريب تحاكي واجهة Odoo Enterprise الحقيقية.
 * نسخة أولى (البنية): شريط التطبيقات + القائمة الجانبية + عارض النموذج العام،
 * مع شاشة أمر شراء حيّة (تأكيد الطلب يُغيّر الحالة ويُظهر زر الاستلام الذكي).
 *
 * القاعدة الذهبية: لا حذف — صفحة ومكوّنات جديدة بالكامل (odoo-sim/).
 */
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import OdooSimulator from '../../components/brandzo-erp/odoo-sim/OdooSimulator.jsx';
---

<DashboardLayout title="تعلم أودو — محاكاة واجهة Odoo" showGuide={false}>
  <div class="text-right" dir="rtl">
    {/* Header */}
    <div class="mb-4">
      <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">🎓 تعلم أودو</h1>
      <p class="text-gray-200 text-sm leading-relaxed max-w-3xl">
        بيئة تدريب تحاكي واجهة <b>Odoo Enterprise</b> الحقيقية بدقّة — تتنقّل بين تطبيقات
        المشتريات والمستودعات والمالية، وترى كيف تبدو المستندات وتتصرّف تماماً كما في النظام
        الفعلي. جرّب: اضغط <b>Confirm Order</b> في أمر الشراء لتُلاحظ تغيّر الحالة وظهور زر
        الاستلام الذكي.
      </p>
      <div class="mt-3 inline-flex items-center gap-2 rounded-full border border-brand-gold/30 bg-brand-gold/10 px-3 py-1 text-xs text-brand-gold font-bold">
        <span class="w-2 h-2 rounded-full bg-brand-gold animate-pulse"></span>
        نسخة أولى — البنية الهيكلية + شاشة أمر الشراء
      </div>
      <div class="w-20 h-1 bg-brand-red rounded-full mt-3"></div>
    </div>

    <OdooSimulator client:load />
  </div>
</DashboardLayout>
