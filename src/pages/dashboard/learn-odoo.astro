---
/**
 * تعلم أودو (Learn Odoo) — بيئة تدريب تحاكي واجهة Odoo Enterprise الحقيقية
 * بدقّة عالية: عربية بالكامل (RTL)، بعملة الدينار الليبي، وبوضع «ملء الشاشة»
 * لتجربة غامرة 100% كما في النظام الفعلي.
 *
 * القاعدة الذهبية: لا حذف — صفحة ومكوّنات جديدة بالكامل (odoo-sim/).
 */
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import OdooSimulator from '../../components/brandzo-erp/odoo-sim/OdooSimulator.jsx';
---

<DashboardLayout title="تعلم أودو — محاكاة واجهة Odoo" showGuide={false}>
  <div class="text-right" dir="rtl">
    {/* رأس مُصغّر — يترك أقصى مساحة للمحاكي */}
    <div class="mb-3 flex flex-wrap items-center justify-between gap-3">
      <div class="flex items-center gap-3 min-w-0">
        <h1 class="text-xl sm:text-2xl font-bold text-white whitespace-nowrap">🎓 تعلم أودو</h1>
        <p class="text-gray-300 text-xs sm:text-sm leading-relaxed hidden md:block max-w-2xl">
          جولة تدريبية تحاكي واجهة <b>Odoo Enterprise</b> بدقّة — عربية بالكامل وبعملة
          <b> الدينار الليبي</b> — عبر المشتريات والمخزون والمالية مع فرض القواعد الذهبية آلياً.
        </p>
      </div>
      <div class="inline-flex items-center gap-2 rounded-full border border-brand-gold/30 bg-brand-gold/10 px-3 py-1 text-xs text-brand-gold font-bold shrink-0">
        <span class="w-2 h-2 rounded-full bg-brand-gold animate-pulse"></span>
        جولة موجَّهة 12 مرحلة — اضغط ⛶ لملء الشاشة الحقيقي
      </div>
    </div>

    <OdooSimulator client:load />
  </div>
</DashboardLayout>
