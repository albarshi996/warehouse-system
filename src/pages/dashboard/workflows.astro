---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import FAQ from '../../components/brandzo-erp/FAQ.jsx';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
---

<DashboardLayout title="الهيكل والمسارات">
  <div class="text-right" dir="rtl">
    <header class="mb-6 sm:mb-8">
      <h1 class="text-2xl sm:text-3xl font-bold text-brand-yellow">
        الهيكل والمسارات (Workflows & Org)
      </h1>
      <p class="text-gray-300 mt-2 text-sm sm:text-base leading-relaxed">
        الخريطة البصرية لنظام المستودعات: الهيكل التنظيمي للموظفين، والدورة المستندية الكاملة من طلب
        الشراء حتى المرتجعات. مأخوذة مباشرة من الباب الثاني والثالث في الدليل التشغيلي.
      </p>
    </header>

    <!-- Simple Static Content -->
    <div class="space-y-8">
      <!-- الهيكل التنظيمي Section -->
      <section class="rounded-2xl bg-gradient-to-br from-brand-navy via-[#1a1a3e] to-[#0d0d2b] shadow-2xl border border-brand-red/20 p-6 sm:p-10">
        <h2 class="text-xl font-bold text-white text-center mb-6">
          الهيكل التنظيمي للمستودعات
          <span class="block text-sm font-normal text-gray-400 mt-1">Warehouse Organizational Structure</span>
        </h2>
        <div class="w-16 h-1 bg-brand-red mx-auto mb-8 rounded-full"></div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Tier 1: Management -->
          <div class="bg-white/5 backdrop-blur border border-brand-red/30 rounded-xl p-6">
            <div class="text-center mb-4">
              <div class="w-16 h-16 bg-brand-red/20 rounded-full flex items-center justify-center mx-auto mb-3">
                <span class="text-2xl font-bold text-brand-red">م</span>
              </div>
              <h3 class="font-bold text-brand-red mb-2">مدير المستودعات</h3>
              <p class="text-sm text-gray-300">الإشراف العام على جميع العمليات</p>
            </div>
          </div>
          
          <!-- Tier 2: Supervisors -->
          <div class="bg-white/5 backdrop-blur border border-brand-yellow/30 rounded-xl p-6">
            <div class="text-center mb-4">
              <div class="w-16 h-16 bg-brand-yellow/20 rounded-full flex items-center justify-center mx-auto mb-3">
                <span class="text-2xl font-bold text-brand-yellow">مش</span>
              </div>
              <h3 class="font-bold text-brand-yellow mb-2">مشرفو العمليات</h3>
              <p class="text-sm text-gray-300">إدارة الفرق اليومية</p>
            </div>
          </div>
          
          <!-- Tier 3: Staff -->
          <div class="bg-white/5 backdrop-blur border border-green-400/30 rounded-xl p-6">
            <div class="text-center mb-4">
              <div class="w-16 h-16 bg-green-400/20 rounded-full flex items-center justify-center mx-auto mb-3">
                <span class="text-2xl font-bold text-green-400">ف</span>
              </div>
              <h3 class="font-bold text-green-400 mb-2">فرق التشغيل</h3>
              <p class="text-sm text-gray-300">تنفيذ المهام اليومية</p>
            </div>
          </div>
        </div>
        
        <div class="mt-8 text-center">
          <a href={`${base}/تقرير-هيكل-الوظائف-والادوار.html`} 
             target="_blank" 
             class="inline-block px-6 py-3 bg-brand-red text-white rounded-xl font-bold hover:bg-brand-red-dark transition-all">
            📄 عرض التقرير الكامل
          </a>
        </div>
      </section>

      <!-- الدورة المستندية Section -->
      <section class="rounded-2xl bg-gradient-to-br from-[#0d0d2b] to-brand-navy shadow-2xl border border-white/10 p-6 sm:p-10">
        <h2 class="text-xl font-bold text-white text-center mb-6">
          الدورة المستندية الكاملة
          <span class="block text-sm font-normal text-gray-400 mt-1">Complete Document Cycle</span>
        </h2>
        <div class="w-16 h-1 bg-brand-yellow mx-auto mb-8 rounded-full"></div>
        
        <div class="overflow-x-auto pb-4" dir="ltr">
          <svg viewBox="0 0 900 120" width="100%" class="min-w-[800px] mx-auto">
            <defs>
              <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
                <polygon points="0 0, 10 3.5, 0 7" fill="#4b5563" />
              </marker>
            </defs>

            {/* 1. PR */}
            <rect x="5" y="20" width="100" height="80" rx="12" fill="rgba(225, 29, 72, 0.05)" stroke="#e11d48" stroke-width="2" />
            <text x="55" y="55" text-anchor="middle" fill="white" font-weight="bold" font-size="12">طلب الشراء</text>
            <text x="55" y="75" text-anchor="middle" fill="#94a3b8" font-size="10">PR</text>
            <line x1="105" y1="60" x2="115" y2="60" stroke="#4b5563" stroke-width="2" marker-end="url(#arrowhead)" />

            {/* 2. PO */}
            <rect x="117" y="20" width="100" height="80" rx="12" fill="rgba(225, 29, 72, 0.05)" stroke="#e11d48" stroke-width="2" />
            <text x="167" y="55" text-anchor="middle" fill="white" font-weight="bold" font-size="12">أمر الشراء</text>
            <text x="167" y="75" text-anchor="middle" fill="#94a3b8" font-size="10">PO</text>
            <line x1="217" y1="60" x2="227" y2="60" stroke="#4b5563" stroke-width="2" marker-end="url(#arrowhead)" />

            {/* 3. ASN */}
            <rect x="229" y="20" width="100" height="80" rx="12" fill="rgba(225, 29, 72, 0.05)" stroke="#e11d48" stroke-width="2" />
            <text x="279" y="55" text-anchor="middle" fill="white" font-weight="bold" font-size="12">إشعار الاستلام</text>
            <text x="279" y="75" text-anchor="middle" fill="#94a3b8" font-size="10">ASN</text>
            <line x1="329" y1="60" x2="339" y2="60" stroke="#4b5563" stroke-width="2" marker-end="url(#arrowhead)" />

            {/* 4. GRN */}
            <rect x="341" y="20" width="100" height="80" rx="12" fill="rgba(251, 191, 36, 0.05)" stroke="#fbbf24" stroke-width="2" />
            <text x="391" y="55" text-anchor="middle" fill="white" font-weight="bold" font-size="12">إذن التسليم</text>
            <text x="391" y="75" text-anchor="middle" fill="#94a3b8" font-size="10">GRN</text>
            <line x1="441" y1="60" x2="451" y2="60" stroke="#4b5563" stroke-width="2" marker-end="url(#arrowhead)" />

            {/* 5. Putaway */}
            <rect x="453" y="20" width="100" height="80" rx="12" fill="rgba(251, 191, 36, 0.05)" stroke="#fbbf24" stroke-width="2" />
            <text x="503" y="55" text-anchor="middle" fill="white" font-weight="bold" font-size="12">إذن التخزين</text>
            <text x="503" y="75" text-anchor="middle" fill="#94a3b8" font-size="10">Putaway</text>
            <line x1="553" y1="60" x2="563" y2="60" stroke="#4b5563" stroke-width="2" marker-end="url(#arrowhead)" />

            {/* 6. Picking */}
            <rect x="565" y="20" width="100" height="80" rx="12" fill="rgba(251, 191, 36, 0.05)" stroke="#fbbf24" stroke-width="2" />
            <text x="615" y="55" text-anchor="middle" fill="white" font-weight="bold" font-size="12">إذن الصرف</text>
            <text x="615" y="75" text-anchor="middle" fill="#94a3b8" font-size="10">Picking</text>
            <line x1="665" y1="60" x2="675" y2="60" stroke="#4b5563" stroke-width="2" marker-end="url(#arrowhead)" />

            {/* 7. Dispatch */}
            <rect x="677" y="20" width="100" height="80" rx="12" fill="rgba(34, 197, 94, 0.05)" stroke="#22c55e" stroke-width="2" />
            <text x="727" y="55" text-anchor="middle" fill="white" font-weight="bold" font-size="12">إذن الشحن</text>
            <text x="727" y="75" text-anchor="middle" fill="#94a3b8" font-size="10">Dispatch</text>
            <line x1="777" y1="60" x2="787" y2="60" stroke="#4b5563" stroke-width="2" marker-end="url(#arrowhead)" />

            {/* 8. Return */}
            <rect x="789" y="20" width="100" height="80" rx="12" fill="rgba(34, 197, 94, 0.05)" stroke="#22c55e" stroke-width="2" />
            <text x="839" y="55" text-anchor="middle" fill="white" font-weight="bold" font-size="12">إذن المرتجعات</text>
            <text x="839" y="75" text-anchor="middle" fill="#94a3b8" font-size="10">Return</text>
          </svg>
        </div>
        
        <div class="mt-8 text-center">
          <a href={`${base}/تقرير-الدورة-المستندية.html`} 
             target="_blank" 
             class="inline-block px-6 py-3 bg-brand-yellow text-black rounded-xl font-bold hover:bg-brand-yellow-dark transition-all">
            📄 عرض تقرير الدورة المستندية
          </a>
        </div>
      </section>

      <!-- Odoo Integration Section -->
      <section class="rounded-2xl bg-gradient-to-br from-green-900/20 via-blue-900/20 to-green-900/20 shadow-2xl border border-green-500/30 p-6 sm:p-10">
        <h2 class="text-xl font-bold text-white text-center mb-6">
          التكامل مع أودو
          <span class="block text-sm font-normal text-gray-400 mt-1">Odoo Integration Mapping</span>
        </h2>
        <div class="w-16 h-1 bg-green-400 mx-auto mb-8 rounded-full"></div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-white/5 backdrop-blur border border-green-500/30 rounded-xl p-6">
            <h3 class="font-bold text-green-400 mb-4">الوحدات المقابلة في أودو</h3>
            <ul class="space-y-2 text-sm text-gray-300">
              <li class="flex items-center gap-2">
                <span class="text-green-400">•</span>
                <span>المخزون → Inventory Module</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-400">•</span>
                <span>المشتريات → Purchase Module</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-400">•</span>
                <span>المبيعات → Sales Module</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-400">•</span>
                <span>المحاسبة → Accounting Module</span>
              </li>
            </ul>
          </div>
          
          <div class="bg-white/5 backdrop-blur border border-blue-500/30 rounded-xl p-6">
            <h3 class="font-bold text-blue-400 mb-4">مزايا التكامل</h3>
            <ul class="space-y-2 text-sm text-gray-300">
              <li class="flex items-center gap-2">
                <span class="text-blue-400">•</span>
                <span>بيانات دقيقة 98.5%</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="text-blue-400">•</span>
                <span>مزامنة فورية</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="text-blue-400">•</span>
                <span>تقارير موحدة</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="text-blue-400">•</span>
                <span>امتثال كامل</span>
              </li>
            </ul>
          </div>
        </div>
        
        <div class="mt-8 text-center">
          <a href={`${base}/dashboard/odoo-installation`} 
             class="inline-block px-6 py-3 bg-green-500 text-white rounded-xl font-bold hover:bg-green-600 transition-all">
            ⚙️ دليل التثبيت الكامل
          </a>
        </div>
      </section>
    </div>

    <FAQ client:load />

    <footer class="mt-10 text-center text-xs text-gray-400">
      مصدر البيانات: الدليل التشغيلي — الباب الثاني والثالث.
    </footer>
  </div>
</DashboardLayout>
