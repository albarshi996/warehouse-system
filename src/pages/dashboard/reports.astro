---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import ReportsHub from '../../components/brandzo-erp/reports/ReportsHub.astro';
---

<DashboardLayout title="مركز التقارير" showGuide={false}>
  <div class="text-right" dir="rtl">
    {/* Header */}
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white mb-2">📊 مركز التقارير</h1>
      <p class="text-gray-200 text-sm leading-relaxed max-w-2xl">
        مركزٌ موحّد لكل تقارير المنظومة: التشغيلية، والجودة، والتحليلية، والتوثيق
        المرئي — في مكان واحد منظّم بدل تناثرها عبر الصفحات.
      </p>
      <div class="w-20 h-1 bg-brand-red rounded-full mt-4"></div>
    </div>

    <ReportsHub />
  </div>
</DashboardLayout>
