---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Icon from '../../components/ui/Icon.astro';

const title = "معرض التوثيق المرئي";
---

<DashboardLayout title={title}>
  <div class="space-y-8 animate-fade-in-up">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold text-white flex items-center gap-3">
          <Icon name="image" size={32} class="text-brand-red" />
          معرض التوثيق المرئي
        </h1>
        <p class="text-gray-400 mt-2">
          توثيق مرئي ومقترحات مصورة للمستودعات والعمليات اللوجستية.
        </p>
      </div>
    </div>

    <!-- Gallery Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Sample Image Card 1 -->
      <div class="glass-card overflow-hidden group">
        <div class="aspect-video relative overflow-hidden bg-gray-900">
          <img
            src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&q=80&w=800"
            alt="مستودع حديث"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 opacity-80 group-hover:opacity-100"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-4">
             <span class="text-brand-gold text-xs font-bold">مقترح تنظيم</span>
             <h3 class="text-white font-bold">تنظيم الأرفف الذكي</h3>
          </div>
        </div>
        <div class="p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="px-2 py-1 bg-brand-red/20 text-brand-red text-[10px] font-bold rounded uppercase tracking-wider">
              صورة توثيقية
            </span>
            <span class="text-gray-500 text-xs">2026/05/15</span>
          </div>
          <h3 class="text-white font-bold mb-1">نموذج المستودع الذكي</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            توثيق لمقترح آلية ترتيب الأرفف لزيادة الكفاءة التشغيلية بنسبة 25%.
          </p>
        </div>
      </div>

      <!-- Sample Image Card 2 -->
      <div class="glass-card overflow-hidden group">
        <div class="aspect-video relative overflow-hidden bg-gray-900">
          <img
            src="https://images.unsplash.com/photo-1553413077-190dd305871c?auto=format&fit=crop&q=80&w=800"
            alt="عمليات لوجستية"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 opacity-80 group-hover:opacity-100"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-4">
             <span class="text-brand-gold text-xs font-bold">توثيق تشغيلي</span>
             <h3 class="text-white font-bold">منطقة الفرز والتوزيع</h3>
          </div>
        </div>
        <div class="p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="px-2 py-1 bg-brand-gold/20 text-brand-gold text-[10px] font-bold rounded uppercase tracking-wider">
              مقترح تشغيلي
            </span>
            <span class="text-gray-500 text-xs">2026/05/10</span>
          </div>
          <h3 class="text-white font-bold mb-1">آلية جرد المركبات</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            مقترح مرئي لآلية جرد وتوثيق المركبات في منطقة الاستلام والتسليم.
          </p>
        </div>
      </div>

      <!-- Sample Video Card -->
      <div class="glass-card overflow-hidden group">
        <div class="aspect-video relative bg-black">
          <video
            class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"
            controls
            poster="https://images.unsplash.com/photo-1566576721346-d4a3b4eaad5b?auto=format&fit=crop&q=80&w=800"
          >
            <source src="https://www.w3schools.com/html/mov_bbb.mp4" type="video/mp4" />
            متصفحك لا يدعم تشغيل الفيديو.
          </video>
        </div>
        <div class="p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="px-2 py-1 bg-blue-500/20 text-blue-400 text-[10px] font-bold rounded uppercase tracking-wider">
              فيديو توضيحي
            </span>
            <span class="text-gray-500 text-xs">2026/05/01</span>
          </div>
          <h3 class="text-white font-bold mb-1">شرح آلية الصرف</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            توثيق مرئي لمراحل دورة الصرف المخزني من الطلب حتى التسليم.
          </p>
        </div>
      </div>
    </div>

    <!-- Empty State / Placeholder for Future Assets -->
    <div class="bz-card-dark p-12 text-center border-dashed border-2 border-white/10">
      <div class="w-16 h-16 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-4">
        <Icon name="fileUp" size={32} class="text-gray-600" />
      </div>
      <h3 class="text-xl font-bold text-gray-300 mb-2">في انتظار المزيد من الوسائط</h3>
      <p class="text-gray-500 max-w-md mx-auto">
        سيتم إضافة المزيد من الصور والفيديوهات التوثيقية والمقترحات المرئية تباعاً لتعزيز التوثيق التشغيلي.
      </p>
    </div>
  </div>
</DashboardLayout>

<style>
  .glass-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    transition: all 0.3s ease;
  }

  .glass-card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(192, 57, 43, 0.3);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5), 0 0 24px rgba(192, 57, 43, 0.15);
    transform: translateY(-4px);
  }
</style>
