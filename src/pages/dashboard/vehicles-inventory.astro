window.handleImportFile = function(event){const f=event.target.files[0];if(f)processImportFile(f);}
function processImportFile(file) {
  if(!file.name.match(/\.xlsx?$/i)){showToast('⚠️ يرجى اختيار ملف .xlsx صحيح');return;}
  const reader=new FileReader();
  reader.onload=function(e){
    try{
      const wb=XLSX.read(new Uint8Array(e.target.result),{type:'array'});
      const ws1=wb.Sheets['البيانات الأساسية'];
      if(ws1){
        const rows=XLSX.utils.sheet_to_json(ws1,{header:1,defval:''});
        const fieldMap={'رقم النموذج':'formNo','تاريخ الفحص':'inspDate','وقت الفحص':'inspTime','الجهة / القسم':'department','رقم اللوحة':'plateNo','الماركة':'brand','الموديل':'model','سنة الصنع':'year','اللون':'color','رقم الهيكل (VIN)':'vin','رقم المحرك':'engineNo','نوع الوقود':'fuelType','العداد الحالي (كم)':'odometer','تاريخ آخر صيانة':'lastService','آخر صيانة عند (كم)':'lastServiceKm','انتهاء الرخصة':'licExpiry','المستلم من':'receivedFrom','المستلم':'receivedFrom','رقم وثيقة التأمين':'insNo','انتهاء التأمين':'insExpiry','الحمولة (طن)':'payload'};
        rows.forEach(row=>{
          if(row.length>=2){const key=String(row[0]).trim();const val=String(row[1]).trim();if(fieldMap[key]&&val){const el=document.getElementById(fieldMap[key])||document.querySelector(`[name="${fieldMap[key]}"]`);if(el)el.value=val;}if(key==='نوع المركبة'&&val){document.querySelectorAll('input[name="vehicleCategory"]').forEach(r=>{if(r.value===val)r.checked=true;});toggleVehicleType();}if(key==='الحكم على المركبة'&&val){document.querySelectorAll('input[name="overallStatus"]').forEach(r=>{if(r.value===val)r.checked=true;});}}
        });
      }
      const ws2=wb.Sheets['نتائج الفحص'];
      if(ws2){
        const rows=XLSX.utils.sheet_to_json(ws2,{header:1,defval:''});
        const allItems=[...EXT_ITEMS,...MECH_ITEMS,...ELEC_ITEMS,...INT_ITEMS,...TRANS_ITEMS];
        const statusMap={'سليم':'_ok','يحتاج متابعة':'_warn','معطل':'_bad','لا ينطبق':'_na'};
        rows.slice(1).forEach(row=>{
          const label=String(row[1]||'').trim();const status=String(row[2]||'').trim();const notes=String(row[3]||'').trim();
          const item=allItems.find(x=>x.label===label);
          if(item&&status&&statusMap[status]){const r=document.getElementById(item.id+statusMap[status]);if(r)r.checked=true;}
          if(item&&notes){const n=document.querySelector(`[name="notes_${item.id}"]`);if(n)n.value=notes;}
        });
      }
      updateSummary();updateLiveDate();closeImport();showToast('✅ تم استيراد البيانات بنجاح!');
    }catch(err){showToast('❌ خطأ في قراءة الملف');console.error(err);}
  };
  reader.readAsArrayBuffer(file);
}

