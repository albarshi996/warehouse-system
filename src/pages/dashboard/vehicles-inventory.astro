<!-- قالب الطباعة/PDF — يُبنى برمجيًّا بهوية إنجاز المشارق -->
<div id="printArea" aria-hidden="true"></div>

</div>

<script>
  import * as XLSXmod from 'xlsx';
  import {
    SECTIONS,
    ALL_ITEMS,
    TIRE_POSITIONS,
    SAFETY_FIELDS,
    ACCESSORY_FIELDS,
    INFO_FIELDS,
    TRANSPORT_CATEGORIES,
    emptyInspection,
    summarize,
  } from '../../services/vehicles/inspectionModel.js';
  import { inspectionToSheets, sheetsToInspection, workbookToSheets, SHEET_NAMES } from '../../services/vehicles/inspectionExcel.js';
  import {
    listenVehicles,
    saveInspection,
    uploadInspectionsBatch,
    listInspections,
    getInspection,
    listenSub,
    addMaintenanceRequest,
    closeMaintenanceRequest,
    addOilChange,
    addAccidentReport,
    reserveInspectionNumber,
  } from '../../services/vehicles/vehiclesService.js';
  import { subscribeAuth, fetchUserProfile } from '../../services/auth/authService.js';

  const XLSX = XLSXmod;
  const BASE = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0, -1) : import.meta.env.BASE_URL;
  const LETTERHEAD_URL = `${BASE}/identity/enjaz-letterhead.jpeg`;

  // أدوار الكتابة — للعرض فقط؛ الإلزام الحقيقي في قواعد Firestore.
  const WRITER_ROLES = ['admin', 'warehouse_manager', 'fleet'];

  // ─── الحالة ─────────────────────────────────────────────────────────
  let vehicles = [];
  let profile = null;
  let canWrite = false;
  let currentVehicle = null; // مركبة نافذة الملف
  let vehSubUnsubs = [];
  const $ = (id) => document.getElementById(id);
  const q = (sel) => document.querySelector(sel);

  function showToast(msg) {
    const c = $('toastContainer');
    if (!c) return;
    const t = document.createElement('div');
    t.className = 'toast-v';
    t.textContent = msg;
    c.appendChild(t);
    setTimeout(() => t.remove(), 4200);
  }
  const esc = (s) => String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

  // ─── حالة السحابة ───────────────────────────────────────────────────
  function setCloud(state, text) {
    const chip = $('cloudChip');
    chip.classList.remove('online', 'pending', 'offline');
    chip.classList.add(state);
    $('cloudChipText').textContent = text;
  }
  window.addEventListener('online', () => setCloud('online', 'متصل — متزامن'));
  window.addEventListener('offline', () => setCloud('offline', 'بلا إنترنت — الحفظ محلي مؤقتًا'));

  // ─── الدور والصلاحية + بدء الاستماع الحيّ بعد المصادقة ──────────────
  // (الاستماع قبل اكتمال المصادقة كان سيُرفض من قواعد الأمان لغير المسجّل.)
  let vehiclesUnsub = null;
  subscribeAuth(async (user) => {
    if (!user) return; // AuthGate يتكفّل بالتحويل
    profile = await fetchUserProfile(user);
    canWrite = WRITER_ROLES.includes(profile?.role);
    document.querySelectorAll('.writer-only').forEach((el) => {
      el.hidden = !canWrite;
    });
    if (!vehiclesUnsub) {
      vehiclesUnsub = listenVehicles((list, hasPending) => {
        vehicles = list;
        setCloud(hasPending ? 'pending' : 'online', hasPending ? 'بانتظار مزامنة كتابات…' : 'متصل — متزامن');
        renderRegistry();
      });
    }
    renderRegistry(); // أزرار الصفوف تُرسم بحسب الصلاحية
  });

  function vehicleAlerts(v) {
    const alerts = [];
    const today = new Date().toISOString().slice(0, 10);
    if (v.licExpiry && v.licExpiry < today) alerts.push('رخصة منتهية');
    if (v.insExpiry && v.insExpiry < today) alerts.push('تأمين منتهٍ');
    const oil = v.lastOilChange || {};
    if (oil.nextDate && oil.nextDate < today) alerts.push('زيت مستحق');
    else if (oil.nextKm && v.odometer && Number(v.odometer) >= Number(oil.nextKm)) alerts.push('زيت مستحق');
    return alerts;
  }

  function verdictBadge(status) {
    if (!status) return '<span class="badge na">— بلا حكم</span>';
    if (status.startsWith('مقبولة -')) return `<span class="badge ok">✅ جاهزة</span>`;
    if (status.startsWith('مقبولة بشروط')) return `<span class="badge cond">⚠️ بشروط</span>`;
    return `<span class="badge rej">❌ مرفوضة</span>`;
  }

  function renderRegistry() {
    const term = ($('regSearch').value || '').trim();
    const filtered = vehicles.filter((v) =>
      !term ||
      [v.plateNo, v.brand, v.model, v.receivedFrom, v.department, v.vin]
        .some((f) => String(f || '').includes(term))
    );

    $('kpiTotal').textContent = vehicles.length;
    $('kpiReady').textContent = vehicles.filter((v) => (v.lastInspection?.overallStatus || '').startsWith('مقبولة -')).length;
    $('kpiMaint').textContent = vehicles.reduce((n, v) => n + (Number(v.openMaintenance) || 0), 0);
    $('kpiAlerts').textContent = vehicles.reduce((n, v) => n + vehicleAlerts(v).length, 0);
    $('regCount').textContent = term ? `${filtered.length} من ${vehicles.length}` : `${vehicles.length} مركبة`;

    const body = $('regBody');
    $('regEmpty').style.display = filtered.length ? 'none' : '';
    body.innerHTML = filtered
      .map((v) => {
        const li = v.lastInspection || {};
        const alerts = vehicleAlerts(v);
        const maint = Number(v.openMaintenance) || 0;
        const acc = Number(v.accidentCount) || 0;
        const follow = [
          maint ? `<span class="badge cond">🔧 ${maint} صيانة</span>` : '',
          alerts.map((a) => `<span class="badge ${a.includes('زيت') ? 'oil' : 'alert'}">${a}</span>`).join(' '),
          acc ? `<span class="badge na">🚨 ${acc} حادث</span>` : '',
        ].filter(Boolean).join(' ') || '<span style="color:#cbd5e1">—</span>';
        return `<tr>
          <td class="reg-plate">${esc(v.plateNo || v.id)}</td>
          <td>${esc(v.category || '—')}</td>
          <td>${esc(`${v.brand || ''} ${v.model || ''}`.trim() || '—')}${v.year ? ` <span style="color:#94a3b8;font-size:0.75rem">(${esc(v.year)})</span>` : ''}</td>
          <td>${esc(v.department || '—')}</td>
          <td>${esc(v.receivedFrom || '—')}</td>
          <td style="white-space:nowrap">${esc(li.date || '—')}${li.pct != null ? ` <span style="color:#94a3b8;font-size:0.75rem">${li.pct}%</span>` : ''}</td>
          <td>${verdictBadge(li.overallStatus)}</td>
          <td>${follow}</td>
          <td><div class="row-actions">
            <button class="mini-btn" onclick="openVehicleFile('${esc(v.id)}')">🗂 الملف</button>
            <button class="mini-btn" onclick="openLastInspection('${esc(v.id)}')">📋 آخر فحص</button>
            <button class="mini-btn writer-only" ${canWrite ? '' : 'hidden'} onclick="newInspectionFor('${esc(v.id)}')">＋ فحص</button>
          </div></td>
        </tr>`;
      })
      .join('');
  }

  // ─── رفع بذرة الأرشيف (23 مركبة من ملفات الإكسل القديمة) ──────────────
  window.uploadArchiveSeed = async function () {
    if (!canWrite) return showToast('⛔ صلاحية الكتابة لدور الحركة والمديرَين فقط');
    try {
      const mod = await import('../../data/vehicles-seed.json');
      const seed = mod.default || mod;
      if (!confirm(`سيُرفع أرشيف الجرد: ${seed.count} مركبة بفحوصاتها إلى السحابة.\nإعادة الرفع تُحدّث ولا تكرّر. متابعة؟`)) return;
      const btn = $('btnSeed');
      btn.disabled = true;
      const n = await uploadInspectionsBatch(seed.records, {
        profile,
        source: 'seed',
        onProgress: (done, total) => { btn.textContent = `⏳ ${done}/${total}…`; },
      });
      btn.disabled = false;
      btn.textContent = '⬆️ رفع بيانات الأرشيف';
      showToast(`✅ رُفعت بيانات ${n} مركبة إلى سجلّ الأسطول`);
    } catch (err) {
      console.error(err);
      $('btnSeed').disabled = false;
      $('btnSeed').textContent = '⬆️ رفع بيانات الأرشيف';
      showToast('❌ تعذّر الرفع: ' + (err?.message || 'خطأ غير معروف'));
    }
  };

  // ─── ملف المركبة ───────────────────────────────────────────────────
  window.openVehicleFile = async function (vehicleId) {
    currentVehicle = vehicles.find((v) => v.id === vehicleId) || { id: vehicleId };
    $('vehTitle').textContent = `🚚 ${currentVehicle.plateNo || vehicleId} — ${`${currentVehicle.brand || ''} ${currentVehicle.model || ''}`.trim()}`;
    $('vehSub').textContent = [currentVehicle.category, currentVehicle.department, currentVehicle.receivedFrom].filter(Boolean).join(' · ');
    $('vehOverlay').classList.add('active');
    switchVehTab('insp');

    // الفحوصات (قراءة واحدة) + الفروع الثلاثة (استماع حيّ)
    $('vehInspList').innerHTML = '<div class="reg-empty">⏳ تحميل…</div>';
    try {
      const insps = await listInspections(vehicleId);
      $('vehInspList').innerHTML = insps.length
        ? insps.map((i) => `
          <div class="veh-list-item">
            <div>
              <div class="main">📋 ${esc(i.info?.formNo || i.id)} — ${esc(i.info?.inspDate || '')}</div>
              <div class="meta">${verdictBadge(i.overallStatus)} · بنود: ${i.summary?.done ?? '—'}/${i.summary?.total ?? '—'} · بواسطة: ${esc(i.byName || '—')} ${i.source === 'seed' ? '· (أرشيف)' : ''}</div>
            </div>
            <button class="mini-btn" onclick="openInspectionDoc('${esc(vehicleId)}','${esc(i.id)}')">فتح النموذج</button>
          </div>`).join('')
        : '<div class="reg-empty">لا فحوصات محفوظة</div>';
    } catch (err) {
      console.error(err);
      $('vehInspList').innerHTML = '<div class="reg-empty">❌ تعذّر تحميل الفحوصات</div>';
    }

    vehSubUnsubs.forEach((u) => u());
    vehSubUnsubs = [
      listenSub(vehicleId, 'maintenance', (list) => {
        $('vehMaintList').innerHTML = list.length
          ? list.map((m) => `
            <div class="veh-list-item">
              <div>
                <div class="main">${m.status === 'done' ? '✅' : '🔧'} ${esc(m.title)} <span class="badge ${m.priority === 'طارئة' ? 'rej' : m.priority === 'عاجلة' ? 'cond' : 'na'}">${esc(m.priority || 'عادية')}</span></div>
                <div class="meta">${esc(m.details || '')}<br>طلبها: ${esc(m.byName || '—')}${m.status === 'done' ? ` · أُنجزت (${esc(m.closedBy || '')})${m.closeNote ? ' — ' + esc(m.closeNote) : ''}` : ''}</div>
              </div>
              ${m.status !== 'done' && canWrite ? `<button class="mini-btn" onclick="finishMaintenance('${esc(m.id)}')">✔ إنجاز</button>` : ''}
            </div>`).join('')
          : '<div class="reg-empty">لا طلبات صيانة</div>';
      }),
      listenSub(vehicleId, 'oil_changes', (list) => {
        $('vehOilList').innerHTML = list.length
          ? list.map((o) => `
            <div class="veh-list-item">
              <div>
                <div class="main">🛢️ ${esc(o.date || '—')} عند ${esc(o.odometer || '—')} كم ${o.oilType ? '· ' + esc(o.oilType) : ''}</div>
                <div class="meta">الاستحقاق القادم: ${esc(o.nextKm || '—')} كم / ${esc(o.nextDate || '—')} ${o.notes ? '· ' + esc(o.notes) : ''} · بواسطة: ${esc(o.byName || '—')}</div>
              </div>
            </div>`).join('')
          : '<div class="reg-empty">لا قيود زيت</div>';
      }),
      listenSub(vehicleId, 'accidents', (list) => {
        $('vehAccList').innerHTML = list.length
          ? list.map((a) => `
            <div class="veh-list-item">
              <div>
                <div class="main">🚨 ${esc(a.date || '—')} — ${esc(a.place || '')}</div>
                <div class="meta">السائق: ${esc(a.driver || '—')}<br>${esc(a.description || '')}${a.damage ? '<br>الأضرار: ' + esc(a.damage) : ''}${a.actions ? '<br>الإجراءات: ' + esc(a.actions) : ''}</div>
              </div>
            </div>`).join('')
          : '<div class="reg-empty">لا محاضر حوادث — سلامةً دائمة 🙏</div>';
      }),
    ];
  };

  function closeVehicleFile() {
    $('vehOverlay').classList.remove('active');
    vehSubUnsubs.forEach((u) => u());
    vehSubUnsubs = [];
    currentVehicle = null;
  }

  function switchVehTab(tab) {
    document.querySelectorAll('.veh-tab').forEach((b) => b.classList.toggle('active', b.dataset.tab === tab));
    for (const t of ['insp', 'maint', 'oil', 'acc']) $(`vehTab-${t}`).style.display = t === tab ? '' : 'none';
  }

  window.submitMaintenance = async function () {
    if (!currentVehicle) return;
    const title = $('maintTitle').value.trim();
    if (!title) return showToast('⚠️ اكتب موضوع الطلب');
    try {
      await addMaintenanceRequest(currentVehicle.id, { title, details: $('maintDetails').value, priority: $('maintPriority').value }, profile);
      $('maintTitle').value = ''; $('maintDetails').value = '';
      showToast('🔧 سُجّل طلب الصيانة');
    } catch (err) { console.error(err); showToast('❌ تعذّر التسجيل: ' + (err?.message || '')); }
  };
  window.finishMaintenance = async function (reqId) {
    if (!currentVehicle) return;
    const note = prompt('ملاحظة الإنجاز (اختياري):') || '';
    try { await closeMaintenanceRequest(currentVehicle.id, reqId, note, profile); showToast('✅ أُنجز الطلب'); }
    catch (err) { console.error(err); showToast('❌ تعذّر الإنجاز'); }
  };
  window.submitOilChange = async function () {
    if (!currentVehicle) return;
    if (!$('oilDate').value) return showToast('⚠️ حدّد تاريخ التغيير');
    try {
      await addOilChange(currentVehicle.id, {
        date: $('oilDate').value, odometer: $('oilOdometer').value, oilType: $('oilType').value,
        nextKm: $('oilNextKm').value, nextDate: $('oilNextDate').value, notes: $('oilNotes').value,
      }, profile);
      ['oilDate','oilOdometer','oilType','oilNextKm','oilNextDate','oilNotes'].forEach((id) => { $(id).value = ''; });
      showToast('🛢️ سُجّل تغيير الزيت');
    } catch (err) { console.error(err); showToast('❌ تعذّر التسجيل'); }
  };
  window.submitAccident = async function () {
    if (!currentVehicle) return;
    if (!$('accDate').value && !$('accDesc').value.trim()) return showToast('⚠️ حدّد تاريخ الحادث أو وصفه');
    try {
      await addAccidentReport(currentVehicle.id, {
        date: $('accDate').value, place: $('accPlace').value, driver: $('accDriver').value,
        description: $('accDesc').value, damage: $('accDamage').value, actions: $('accActions').value,
      }, profile);
      ['accDate','accPlace','accDriver','accDesc','accDamage','accActions'].forEach((id) => { $(id).value = ''; });
      showToast('🚨 وُثّق محضر الحادث');
    } catch (err) { console.error(err); showToast('❌ تعذّر التوثيق'); }
  };

  // ─── التنقل بين السجلّ والنموذج ─────────────────────────────────────
  function showView(view) {
    $('registryView').style.display = view === 'registry' ? '' : 'none';
    $('formView').style.display = view === 'form' ? '' : 'none';
    $('registryTopActions').style.display = view === 'registry' ? '' : 'none';
    $('formTopActions').style.display = view === 'form' ? '' : 'none';
    window.scrollTo({ top: 0 });
  }
  window.backToRegistry = function () { showView('registry'); };

  window.startNewInspection = function () {
    fillForm(emptyInspection());
    setDefaultDateTime();
    showView('form');
  };
  window.newInspectionFor = function (vehicleId) {
    const v = vehicles.find((x) => x.id === vehicleId);
    const insp = emptyInspection();
    if (v) {
      insp.info = {
        category: v.category || 'سيارة إدارية', plateNo: v.plateNo || '', brand: v.brand || '',
        model: v.model || '', year: v.year || '', color: v.color || '', vin: v.vin || '',
        engineNo: v.engineNo || '', fuelType: v.fuelType || '', department: v.department || '',
        receivedFrom: v.receivedFrom || '', odometer: v.odometer || '', licExpiry: v.licExpiry || '',
        insNo: v.insNo || '', insExpiry: v.insExpiry || '', payload: v.payload || '',
      };
    }
    fillForm(insp);
    setDefaultDateTime();
    showView('form');
  };
  window.openLastInspection = async function (vehicleId) {
    const v = vehicles.find((x) => x.id === vehicleId);
    const inspId = v?.lastInspection?.inspId;
    if (!inspId) return showToast('لا فحص محفوظًا لهذه المركبة بعد');
    window.openInspectionDoc(vehicleId, inspId);
  };
  window.openInspectionDoc = async function (vehicleId, inspId) {
    try {
      const doc = await getInspection(vehicleId, inspId);
      if (!doc) return showToast('❌ الفحص غير موجود');
      closeVehicleFile();
      fillForm(doc);
      showView('form');
      showToast(`📋 فُتح الفحص ${doc.info?.formNo || inspId}`);
    } catch (err) { console.error(err); showToast('❌ تعذّر فتح الفحص'); }
  };

  // ─── رسم أقسام الفحص من النموذج الموحّد ─────────────────────────────
  function makeRadios(id) {
    return `<div class="radio-group">
      <div class="radio-btn ok-v"><input type="radio" name="status_${id}" id="${id}_ok" value="سليم" onchange="updateSummary()"><label for="${id}_ok">✅ سليم</label></div>
      <div class="radio-btn warn-v"><input type="radio" name="status_${id}" id="${id}_warn" value="يحتاج متابعة" onchange="updateSummary()"><label for="${id}_warn">⚠️ متابعة</label></div>
      <div class="radio-btn bad-v"><input type="radio" name="status_${id}" id="${id}_bad" value="معطل" onchange="updateSummary()"><label for="${id}_bad">❌ معطل</label></div>
      <div class="radio-btn na-v"><input type="radio" name="status_${id}" id="${id}_na" value="لا ينطبق" onchange="updateSummary()"><label for="${id}_na">— لا ينطبق</label></div>
    </div>`;
  }
  function renderSections() {
    $('inspectionSections').innerHTML = SECTIONS.map((sec) => `
      <div class="section-card" ${sec.key === 'trans' ? 'id="transportSection"' : ''}>
        <div class="section-header-v">
          <div class="section-header-left"><div class="s-icon">${sec.icon}</div><h3>${sec.num} - ${sec.title}</h3></div>
          <button class="section-all-ok-btn" onclick="markSectionOk('${sec.key}')">✅ كل سليم</button>
        </div>
        <div class="section-body"><table class="insp-table">
          <thead><tr><th>#</th><th>بند الفحص</th><th style="text-align:center;min-width:230px;">الحالة</th><th style="min-width:150px;">ملاحظات</th></tr></thead>
          <tbody>${sec.items.map((item, i) => `
            <tr><td>${i + 1}</td><td class="row-label">${item.label}</td><td>${makeRadios(item.id)}</td>
            <td><input class="notes-input" type="text" name="notes_${item.id}" placeholder="ملاحظة..."></td></tr>`).join('')}
          </tbody>
        </table></div>
      </div>`).join('');
  }
  function renderTires() {
    $('tiresGrid').innerHTML = TIRE_POSITIONS.map((t) => `
      <div class="tire-item">
        <div class="tire-label">${t.icon} ${t.label}</div>
        <div class="tire-fields">
          <div class="field-group"><label>المقاس</label><input type="text" name="tire_size_${t.id}" placeholder="225/75R16"></div>
          <div class="field-group"><label>العمق (ملم)</label><input type="number" name="tire_depth_${t.id}" placeholder="5" min="0" max="12" step="0.5"></div>
          <div class="field-group"><label>الضغط (PSI)</label><input type="number" name="tire_pressure_${t.id}" placeholder="35" min="0" max="120"></div>
          <div class="field-group"><label>الحالة</label><select name="tire_cond_${t.id}"><option value="">اختر...</option><option>جيد</option><option>مقبول</option><option>يحتاج تغيير</option></select></div>
        </div>
      </div>`).join('');
  }

  // ─── قراءة/تعبئة النموذج ───────────────────────────────────────────
  const getVal = (name) => q(`[name="${name}"]`)?.value?.trim() || '';
  const getRadio = (name) => q(`input[name="${name}"]:checked`)?.value || '';
  function setVal(name, value) { const el = q(`[name="${name}"]`); if (el) el.value = value ?? ''; }
  function setRadio(name, value) {
    document.querySelectorAll(`input[name="${name}"]`).forEach((r) => { r.checked = r.value === value; });
  }

  function collectInspection() {
    const insp = emptyInspection();
    insp.info.category = getRadio('vehicleCategory') || 'سيارة إدارية';
    for (const f of INFO_FIELDS) { const v = getVal(f.name); if (v) insp.info[f.name] = v; }
    for (const it of ALL_ITEMS) {
      const status = getRadio(`status_${it.id}`);
      const notes = getVal(`notes_${it.id}`);
      if (status || notes) insp.items[it.id] = { ...(status ? { status } : {}), ...(notes ? { notes } : {}) };
    }
    for (const t of TIRE_POSITIONS) {
      const tire = {};
      for (const [k, field] of [['size', 'tire_size_'], ['depth', 'tire_depth_'], ['pressure', 'tire_pressure_'], ['cond', 'tire_cond_']]) {
        const v = getVal(field + t.id);
        if (v) tire[k] = v;
      }
      if (Object.keys(tire).length) insp.tires[t.id] = tire;
    }
    for (const f of SAFETY_FIELDS) { const v = getVal(f.name); if (v) insp.safety[f.name] = v; }
    for (const f of ACCESSORY_FIELDS) { const v = getVal(f.name); if (v) insp.accessories[f.name] = v; }
    insp.overallStatus = getRadio('overallStatus');
    insp.generalNotes = getVal('generalNotes');
    insp.signatures = { mechanic: getVal('sigMechanic'), receiver: getVal('sigReceiver'), supervisor: getVal('sigSupervisor') };
    return insp;
  }

  function fillForm(insp) {
    // تفريغ
    document.querySelectorAll('#formView input:not([type="radio"]), #formView textarea, #formView select').forEach((el) => { el.value = ''; });
    document.querySelectorAll('#formView input[type="radio"]').forEach((el) => { el.checked = false; });
    // تعبئة
    setRadio('vehicleCategory', insp?.info?.category || 'سيارة إدارية');
    for (const f of INFO_FIELDS) setVal(f.name, insp?.info?.[f.name] || '');
    for (const it of ALL_ITEMS) {
      const entry = insp?.items?.[it.id];
      if (entry?.status) setRadio(`status_${it.id}`, entry.status);
      setVal(`notes_${it.id}`, entry?.notes || '');
    }
    for (const t of TIRE_POSITIONS) {
      const tire = insp?.tires?.[t.id] || {};
      setVal(`tire_size_${t.id}`, tire.size || '');
      setVal(`tire_depth_${t.id}`, tire.depth || '');
      setVal(`tire_pressure_${t.id}`, tire.pressure || '');
      setVal(`tire_cond_${t.id}`, tire.cond || '');
    }
    for (const f of SAFETY_FIELDS) setVal(f.name, insp?.safety?.[f.name] || '');
    for (const f of ACCESSORY_FIELDS) setVal(f.name, insp?.accessories?.[f.name] || '');
    if (insp?.overallStatus) setRadio('overallStatus', insp.overallStatus);
    setVal('generalNotes', insp?.generalNotes || '');
    setVal('sigMechanic', insp?.signatures?.mechanic || '');
    setVal('sigReceiver', insp?.signatures?.receiver || '');
    setVal('sigSupervisor', insp?.signatures?.supervisor || '');
    $('formNumber').textContent = insp?.info?.formNo || '---';
    updateLiveDate();
    toggleVehicleType();
    updateSummary();
  }

  // ─── الملخّص (من الوحدة المُختبَرة — بنود النوع المعنيّة فقط) ────────
  function updateSummary() {
    const s = summarize(collectInspection());
    $('cnt-ok').textContent = s.ok;
    $('cnt-warn').textContent = s.warn;
    $('cnt-bad').textContent = s.bad;
    $('cnt-na').textContent = s.na;
    $('progressBar').style.width = s.pct + '%';
    $('progressLabel').textContent = s.pct + '%';
  }
  window.markAllOk = function () {
    const category = getRadio('vehicleCategory');
    const withTrans = TRANSPORT_CATEGORIES.includes(category);
    for (const it of ALL_ITEMS) {
      if (!withTrans && it.sectionKey === 'trans') continue;
      const r = $(`${it.id}_ok`);
      if (r) r.checked = true;
    }
    updateSummary();
    showToast('✅ حُدّدت جميع البنود كسليم');
  };
  window.markSectionOk = function (secKey) {
    const sec = SECTIONS.find((s) => s.key === secKey);
    (sec?.items || []).forEach((it) => { const r = $(`${it.id}_ok`); if (r) r.checked = true; });
    updateSummary();
    showToast('✅ حُدّد القسم كسليم');
  };
  function updateLiveDate() { $('liveDate').textContent = $('inspDate').value || '---'; }
  function toggleVehicleType() {
    const val = getRadio('vehicleCategory');
    const el = $('transportSection');
    if (el) el.style.display = TRANSPORT_CATEGORIES.includes(val) ? '' : 'none';
    updateSummary();
  }
  function setDefaultDateTime() {
    const now = new Date();
    $('inspDate').value = now.toISOString().split('T')[0];
    $('inspTime').value = now.toTimeString().slice(0, 5);
    updateLiveDate();
  }

  // ─── الحفظ السحابي (الرقم الرسمي يُحجز لحظة الحفظ الأول) ─────────────
  window.saveInspectionToCloud = async function () {
    if (!canWrite) return showToast('⛔ صلاحية الكتابة لدور الحركة والمديرَين فقط');
    const insp = collectInspection();
    if (!insp.info.plateNo && !insp.info.vin) return showToast('⚠️ أدخل رقم اللوحة (أو الهيكل) قبل الحفظ');
    try {
      if (!insp.info.formNo) {
        const { number } = await reserveInspectionNumber();
        insp.info.formNo = number;
        setVal('formNo', number);
        $('formNumber').textContent = number;
      }
      const { vehicleId } = await saveInspection(insp, { profile });
      showToast(`☁️ حُفظ الفحص ${insp.info.formNo} للمركبة ${insp.info.plateNo || vehicleId}`);
    } catch (err) {
      console.error(err);
      const offline = !navigator.onLine || String(err?.message || '').includes('offline');
      showToast(offline
        ? '📡 الترقيم الرسمي يحتاج اتصالًا — أعد المحاولة عند عودة الشبكة'
        : '❌ تعذّر الحفظ: ' + (err?.code || err?.message || 'خطأ غير معروف'));
    }
  };

  // ─── الطباعة وPDF — قالب واحد بهوية «إنجاز المشارق» ─────────────────
  function statusClass(status) {
    return status === 'سليم' ? 'ok' : status === 'يحتاج متابعة' ? 'warn' : status === 'معطل' ? 'bad' : 'na';
  }
  function pageShell(inner, pageNo, insp) {
    return `<div class="print-page" style="background-image:url('${LETTERHEAD_URL}')">
      ${inner}
      <div class="pp-footer">
        <span>نموذج ${esc(insp.info?.formNo || '—')} · ${esc(insp.info?.plateNo || '')}</span>
        <span>Brandzo Hub — نظام جرد المركبات · صفحة ${pageNo}</span>
      </div>
    </div>`;
  }
  function infoCells(pairs) {
    return `<div class="pp-grid">${pairs.map(([l, v]) => `<div class="cell lbl">${esc(l)}</div><div class="cell">${esc(v || '—')}</div>`).join('')}</div>`;
  }
  function buildPrintPages(insp) {
    const s = summarize(insp);
    const g = (n) => insp.info?.[n] || '';
    const pages = [];

    // صفحة ١: البيانات + الملخّص + الحكم + التوقيعات
    pages.push(`
      <div class="pp-title"><h1>نموذج استلام وفحص المركبة</h1><div class="en">Vehicle Receiving &amp; Inspection Report</div></div>
      <div class="pp-meta">
        <div><b>رقم النموذج:</b> ${esc(g('formNo') || '—')}</div>
        <div><b>التاريخ:</b> ${esc(g('inspDate') || '—')} ${esc(g('inspTime'))}</div>
        <div><b>الجهة:</b> ${esc(g('department') || '—')}</div>
        <div><b>النوع:</b> ${esc(insp.info?.category || '—')}</div>
      </div>
      <div class="pp-sec-title">بيانات المركبة</div>
      ${infoCells([
        ['رقم اللوحة', g('plateNo')], ['الماركة', g('brand')],
        ['الموديل', g('model')], ['سنة الصنع', g('year')],
        ['اللون', g('color')], ['نوع الوقود', g('fuelType')],
        ['رقم الهيكل (VIN)', g('vin')], ['رقم المحرك', g('engineNo')],
      ])}
      <div class="pp-sec-title">بيانات التشغيل والتسجيل</div>
      ${infoCells([
        ['العداد الحالي (كم)', g('odometer')], ['آخر صيانة عند (كم)', g('lastServiceKm')],
        ['تاريخ آخر صيانة', g('lastService')], ['انتهاء الرخصة', g('licExpiry')],
        ['المستلم من', g('receivedFrom')], ['رقم وثيقة التأمين', g('insNo')],
        ['انتهاء التأمين', g('insExpiry')], ['الحمولة (طن)', g('payload')],
      ])}
      <div class="pp-sec-title">ملخّص نتائج الفحص (${s.done} من ${s.total} بندًا — ${s.pct}%)</div>
      <div class="pp-sum">
        <div style="color:#00976a">✅ سليم: ${s.ok}</div>
        <div style="color:#b45309">⚠️ متابعة: ${s.warn}</div>
        <div style="color:#b91c1c">❌ معطل: ${s.bad}</div>
        <div style="color:#64748b">— لا ينطبق: ${s.na}</div>
      </div>
      <div class="pp-verdict">الحكم العام: ${esc(insp.overallStatus || '— لم يُحدَّد —')}</div>
      <div class="pp-sec-title">الملاحظات العامة والإجراءات المطلوبة</div>
      <div class="pp-notes">${esc(insp.generalNotes || '—')}</div>
      <div class="pp-sigs">
        <div class="pp-sig"><div class="line">${esc(insp.signatures?.mechanic || '')}</div><div class="who">الفاحص الميكانيكي</div></div>
        <div class="pp-sig"><div class="line">${esc(insp.signatures?.receiver || '')}</div><div class="who">المستلم</div></div>
        <div class="pp-sig"><div class="line">${esc(insp.signatures?.supervisor || '')}</div><div class="who">المسؤول / المشرف</div></div>
      </div>`);

    // صفحات النتائج: صفوف الأقسام والبنود مقسّمة
    const withTrans = TRANSPORT_CATEGORIES.includes(insp.info?.category);
    const rows = [];
    for (const sec of SECTIONS) {
      if (sec.key === 'trans' && !withTrans) continue;
      rows.push({ sec: true, label: `${sec.num} — ${sec.title}` });
      for (const item of sec.items) {
        const e = insp.items?.[item.id] || {};
        rows.push({ label: item.label, status: e.status || '—', notes: e.notes || '' });
      }
    }
    const PER_PAGE = 34;
    for (let i = 0; i < rows.length; i += PER_PAGE) {
      const chunk = rows.slice(i, i + PER_PAGE);
      pages.push(`
        <div class="pp-title"><h1>نتائج الفحص الفني${i ? ' (تتمة)' : ''}</h1><div class="en">${esc(g('plateNo'))} · ${esc((g('brand') + ' ' + g('model')).trim())}</div></div>
        <table class="pp-table">
          <thead><tr><th style="width:52%">بند الفحص</th><th style="width:16%">الحالة</th><th>الملاحظات</th></tr></thead>
          <tbody>${chunk.map((r) => r.sec
            ? `<tr class="sec-row"><td colspan="3">${esc(r.label)}</td></tr>`
            : `<tr><td>${esc(r.label)}</td><td class="pp-status ${statusClass(r.status)}">${esc(r.status)}</td><td>${esc(r.notes)}</td></tr>`
          ).join('')}</tbody>
        </table>`);
    }

    // الصفحة الأخيرة: الإطارات + السلامة + الملحقات
    pages.push(`
      <div class="pp-title"><h1>الإطارات والملحقات والوثائق</h1><div class="en">${esc(g('plateNo'))}</div></div>
      <div class="pp-sec-title">الإطارات والعجلات</div>
      <table class="pp-table">
        <thead><tr><th>الإطار</th><th>المقاس</th><th>العمق (ملم)</th><th>الضغط (PSI)</th><th>الحالة</th></tr></thead>
        <tbody>${TIRE_POSITIONS.map((t) => {
          const e = insp.tires?.[t.id] || {};
          return `<tr><td>${esc(t.label)}</td><td>${esc(e.size || '—')}</td><td>${esc(e.depth || '—')}</td><td>${esc(e.pressure || '—')}</td><td>${esc(e.cond || '—')}</td></tr>`;
        }).join('')}</tbody>
      </table>
      <div class="pp-sec-title">ملحقات السلامة</div>
      ${infoCells(SAFETY_FIELDS.map((f) => [f.label, insp.safety?.[f.name] || '—']))}
      <div class="pp-sec-title">الملحقات والوثائق</div>
      ${infoCells(ACCESSORY_FIELDS.map((f) => [f.label, insp.accessories?.[f.name] || '—']))}`);

    return pages.map((inner, i) => pageShell(inner, i + 1, insp)).join('');
  }

  function renderPrintArea() {
    const insp = collectInspection();
    $('printArea').innerHTML = buildPrintPages(insp);
    return insp;
  }

  window.printReport = function () {
    renderPrintArea();
    // تُمهل الصور لحظة للتحميل قبل فتح نافذة الطباعة
    setTimeout(() => window.print(), 350);
  };

  window.exportPDF = async function () {
    const insp = renderPrintArea();
    showToast('📄 جارٍ توليد PDF بهوية إنجاز المشارق…');
    try {
      const mod = await import('html2pdf.js');
      const html2pdf = mod.default || mod;
      const plate = (insp.info?.plateNo || 'مركبة').replace(/\s+/g, '-');
      const date = insp.info?.inspDate || new Date().toISOString().split('T')[0];
      await html2pdf()
        .set({
          margin: 0,
          filename: `فحص_${plate}_${date}.pdf`,
          image: { type: 'jpeg', quality: 0.95 },
          html2canvas: { scale: 2, useCORS: true },
          jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' },
          pagebreak: { mode: ['css', 'legacy'] },
        })
        .from($('printArea'))
        .save();
      showToast('✅ صدر ملف PDF');
    } catch (err) {
      console.error(err);
      showToast('❌ تعذّر توليد PDF — جرّب «طباعة» واختر الحفظ PDF');
    }
  };

  // ─── إكسل: التصدير الكامل (نسخة احتياطية بلا فقد) ────────────────────
  window.exportExcel = function () {
    const insp = collectInspection();
    const sheets = inspectionToSheets(insp);
    const wb = XLSX.utils.book_new();
    const mk = (rows, cols) => { const ws = XLSX.utils.aoa_to_sheet(rows); ws['!cols'] = cols; return ws; };
    XLSX.utils.book_append_sheet(wb, mk(sheets.info, [{ wch: 30 }, { wch: 28 }, { wch: 30 }, { wch: 28 }]), SHEET_NAMES.info);
    XLSX.utils.book_append_sheet(wb, mk(sheets.results, [{ wch: 26 }, { wch: 45 }, { wch: 18 }, { wch: 38 }]), SHEET_NAMES.results);
    XLSX.utils.book_append_sheet(wb, mk(sheets.tires, [{ wch: 24 }, { wch: 18 }, { wch: 14 }, { wch: 14 }, { wch: 18 }]), SHEET_NAMES.tires);
    XLSX.utils.book_append_sheet(wb, mk(sheets.summary, [{ wch: 30 }, { wch: 16 }, { wch: 14 }]), SHEET_NAMES.summary);
    const plate = (insp.info?.plateNo || 'غير-محدد').replace(/\s+/g, '-');
    const date = insp.info?.inspDate || new Date().toISOString().split('T')[0];
    XLSX.writeFile(wb, `Brandzo_فحص_${plate}_${date}.xlsx`);
    showToast('📊 صدرت النسخة الاحتياطية الكاملة (شاملة الملحقات)');
  };

  window.exportRegistryExcel = function () {
    if (!vehicles.length) return showToast('السجلّ فارغ — لا شيء للتصدير');
    const rows = [
      ['سجلّ الأسطول — Brandzo (لحظة التصدير: ' + new Date().toISOString().slice(0, 16).replace('T', ' ') + ')'],
      [],
      ['اللوحة', 'النوع', 'الماركة', 'الموديل', 'السنة', 'اللون', 'الهيكل', 'الجهة', 'المستلم', 'العداد', 'انتهاء الرخصة', 'انتهاء التأمين', 'آخر فحص', 'حكم آخر فحص', 'نسبة الفحص', 'صيانة مفتوحة', 'آخر زيت', 'استحقاق الزيت', 'عدد الحوادث'],
      ...vehicles.map((v) => [
        v.plateNo || v.id, v.category || '', v.brand || '', v.model || '', v.year || '', v.color || '',
        v.vin || '', v.department || '', v.receivedFrom || '', v.odometer || '',
        v.licExpiry || '', v.insExpiry || '',
        v.lastInspection?.date || '', v.lastInspection?.overallStatus || '',
        v.lastInspection?.pct != null ? v.lastInspection.pct + '%' : '',
        Number(v.openMaintenance) || 0,
        v.lastOilChange?.date || '', v.lastOilChange?.nextDate || v.lastOilChange?.nextKm || '',
        Number(v.accidentCount) || 0,
      ]),
    ];
    const wb = XLSX.utils.book_new();
    const ws = XLSX.utils.aoa_to_sheet(rows);
    ws['!cols'] = rows[2].map((_, i) => ({ wch: i === 0 ? 16 : 14 }));
    XLSX.utils.book_append_sheet(wb, ws, 'سجل الأسطول');
    XLSX.writeFile(wb, `Brandzo_سجل_الأسطول_${new Date().toISOString().slice(0, 10)}.xlsx`);
    showToast('📊 صدر سجلّ الأسطول');
  };

  // ─── استيراد ملف واحد → النموذج ─────────────────────────────────────
  window.openImport = () => $('importOverlay').classList.add('active');
  function closeImport() { $('importOverlay').classList.remove('active'); }
  function wireDropZone(zoneId, handler) {
    const zone = $(zoneId);
    if (!zone) return;
    zone.addEventListener('dragover', (e) => { e.preventDefault(); zone.classList.add('dragging'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('dragging'));
    zone.addEventListener('drop', (e) => {
      e.preventDefault();
      zone.classList.remove('dragging');
      handler([...e.dataTransfer.files]);
    });
  }
  function readWorkbook(file) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = (e) => {
        try { resolve(XLSX.read(new Uint8Array(e.target.result), { type: 'array', raw: false })); }
        catch (err) { reject(err); }
      };
      reader.onerror = reject;
      reader.readAsArrayBuffer(file);
    });
  }
  function parseInspectionFile(wb) {
    const sheets = workbookToSheets(wb, (ws) => XLSX.utils.sheet_to_json(ws, { header: 1, defval: '', raw: false }));
    if (!sheets.info) return null;
    return sheetsToInspection(sheets);
  }
  window.handleImportFile = async function (event) {
    const file = event.target.files[0];
    if (!file) return;
    try {
      const insp = parseInspectionFile(await readWorkbook(file));
      if (!insp) return showToast('⚠️ الملف ليس من هذا النظام (لا ورقة «البيانات الأساسية»)');
      fillForm(insp);
      closeImport();
      showToast('✅ استُورد الملف إلى النموذج — راجِعه ثم «حفظ في السحابة»');
    } catch (err) { console.error(err); showToast('❌ خطأ في قراءة الملف'); }
    event.target.value = '';
  };
  wireDropZone('dropZone', async (files) => {
    if (files[0]) {
      try {
        const insp = parseInspectionFile(await readWorkbook(files[0]));
        if (!insp) return showToast('⚠️ الملف ليس من هذا النظام');
        fillForm(insp); closeImport();
        showToast('✅ استُورد الملف إلى النموذج');
      } catch (err) { console.error(err); showToast('❌ خطأ في قراءة الملف'); }
    }
  });

  // ─── استيراد ملفات متعددة → السحابة مباشرة ──────────────────────────
  window.openCloudImport = () => { $('cloudImportStatus').textContent = ''; $('cloudImportOverlay').classList.add('active'); };
  window.closeCloudImport = () => $('cloudImportOverlay').classList.remove('active');
  async function importFilesToCloud(files) {
    if (!canWrite) return showToast('⛔ صلاحية الكتابة لدور الحركة والمديرَين فقط');
    const xlsxFiles = files.filter((f) => /\.xlsx?$/i.test(f.name));
    if (!xlsxFiles.length) return showToast('⚠️ اختر ملفات .xlsx');
    const status = $('cloudImportStatus');
    const records = [];
    const skipped = [];
    for (const f of xlsxFiles) {
      status.textContent = `⏳ قراءة ${f.name}…`;
      try {
        const insp = parseInspectionFile(await readWorkbook(f));
        if (insp && (insp.info.plateNo || insp.info.vin)) records.push({ inspection: insp });
        else skipped.push(f.name);
      } catch { skipped.push(f.name); }
    }
    if (!records.length) { status.textContent = '❌ لا ملف صالحًا بين المختار'; return; }
    if (!confirm(`سيُرفع ${records.length} فحصًا إلى السحابة${skipped.length ? ` (تُرك ${skipped.length} ملفًا غير صالح)` : ''}. متابعة؟`)) { status.textContent = ''; return; }
    try {
      const n = await uploadInspectionsBatch(records, {
        profile,
        source: 'excel',
        onProgress: (done, total) => { status.textContent = `☁️ رفع ${done}/${total}…`; },
      });
      status.textContent = `✅ رُفع ${n} فحصًا${skipped.length ? ` — تُرك: ${skipped.join('، ')}` : ''}`;
      showToast(`✅ رُفعت ${n} مركبة/فحصًا إلى سجلّ الأسطول`);
    } catch (err) {
      console.error(err);
      status.textContent = '❌ تعذّر الرفع: ' + (err?.code || err?.message || '');
    }
  }
  window.handleCloudFiles = (event) => { importFilesToCloud([...event.target.files]); event.target.value = ''; };
  wireDropZone('cloudDropZone', importFilesToCloud);

  // ─── مستخرج البيانات (ميزة قائمة من النسخة السابقة — كما هي) ─────────
  window.openExtractor = function () {
    $('extractorResults').style.display = 'none';
    $('extractorResultsBody').innerHTML = '';
    $('extractorFileInput').value = '';
    $('extractorOverlay').classList.add('active');
  };
  window.closeExtractor = () => $('extractorOverlay').classList.remove('active');
  window.handleExtractorFile = async function (event) {
    const file = event.target.files[0];
    if (!file) return;
    try {
      const wb = await readWorkbook(file);
      const TARGET_FIELDS = {
        vehicleType: ['نوع السيارة', 'نوع المركبة', 'نوع الاليه', 'نوع الآلية', 'نوع المركبه', 'vehicle type', 'type'],
        plateNo: ['رقم اللوحة', 'رقم اللوحه', 'لوحة', 'لوحه', 'plate'],
        receiverName: ['اسم المستلم', 'المستلم', 'مستلم', 'receiver', 'received by'],
        chassisNo: ['رقم الهيكل', 'رقم الشاسيه', 'رقم الشاسي', 'هيكل', 'chassis', 'vin'],
        department: ['الجهة', 'الإدارة', 'الادارة', 'القسم', 'قسم', 'department', 'dept'],
      };
      const extracted = [];
      wb.SheetNames.forEach((sheetName) => {
        const rows = XLSX.utils.sheet_to_json(wb.Sheets[sheetName], { header: 1, defval: '', raw: false });
        if (rows.length < 2) return;
        let headerRowIdx = -1, headerRow = [];
        for (let i = 0; i < Math.min(5, rows.length); i++) {
          if (rows[i].filter((c) => String(c).trim() !== '').length >= 2) {
            headerRowIdx = i;
            headerRow = rows[i].map((h) => String(h || '').trim().toLowerCase());
            break;
          }
        }
        if (headerRowIdx < 0) return;
        const colMap = {};
        Object.entries(TARGET_FIELDS).forEach(([field, aliases]) => {
          const idx = headerRow.findIndex((h) => aliases.some((a) => h.includes(a.toLowerCase())));
          if (idx >= 0) colMap[field] = idx;
        });
        if (Object.keys(colMap).length < 2) return;
        rows.slice(headerRowIdx + 1).filter((r) => r.some((c) => String(c).trim() !== '')).forEach((row, rowIdx) => {
          const rec = {};
          let hasData = false;
          Object.entries(colMap).forEach(([field, colIdx]) => {
            const val = String(row[colIdx] || '').trim();
            if (val && val !== 'undefined') { rec[field] = val; hasData = true; } else rec[field] = '—';
          });
          if (hasData) extracted.push({ ...rec, _sheet: sheetName, _row: rowIdx + 1 });
        });
      });
      const fieldLabels = { vehicleType: 'نوع السيارة', plateNo: 'رقم اللوحة', receiverName: 'اسم المستلم', chassisNo: 'رقم الهيكل', department: 'الجهة / الإدارة' };
      $('extractorResultsTitle').textContent = extracted.length ? `تم استخراج ${extracted.length} سجل من الملف` : 'النتائج';
      $('extractorResultsBody').innerHTML = extracted.length
        ? extracted.map((rec, i) => `<div class="ext-record">
            <div class="ext-record-header">سجل ${i + 1}${rec._sheet ? ' — ورقة: ' + esc(rec._sheet) : ''}</div>
            ${Object.entries(fieldLabels).map(([key, label]) => `<div class="ext-field-label">${label}</div><div class="ext-field-value">${esc(rec[key] || '—')}</div>`).join('')}
          </div>`).join('')
        : '<div class="reg-empty">⚠️ لم يُعثر على البيانات المطلوبة في الملف</div>';
      $('extractorResults').style.display = 'block';
      if (extracted.length) showToast(`✅ استُخرج ${extracted.length} سجل`);
    } catch (err) { console.error(err); showToast('❌ خطأ في معالجة الملف'); }
    event.target.value = '';
  };

  // إتاحة الدوال لمعالجات onclick/oninput في القالب
  window.renderRegistry = renderRegistry;
  window.switchVehTab = switchVehTab;
  window.closeVehicleFile = closeVehicleFile;
  window.updateSummary = updateSummary;
  window.updateLiveDate = updateLiveDate;
  window.toggleVehicleType = toggleVehicleType;
  window.closeImport = closeImport;

  // ─── الإقلاع ────────────────────────────────────────────────────────
  renderSections();
  renderTires();
  toggleVehicleType();
  updateSummary();
  setCloud(navigator.onLine ? 'online' : 'offline', navigator.onLine ? 'جارٍ الاتصال…' : 'بلا إنترنت');
</script>
</DashboardLayout>
