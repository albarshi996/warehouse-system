window.handleExtractorFile = function(event){const f=event.target.files[0];if(f)processExtractorFile(f);}

function processExtractorFile(file) {
  if(!file.name.match(/\.xlsx?$/i)){showToast('⚠️ يرجى اختيار ملف Excel صحيح');return;}
  const reader=new FileReader();
  reader.onload=function(e){
    try{
      const wb=XLSX.read(new Uint8Array(e.target.result),{type:'array',cellDates:true,raw:false});
      const extracted=[];

      // Strategy: try to find data across all sheets
      // Look for columns matching our target fields using flexible header detection
      const TARGET_FIELDS={
        vehicleType:   ['نوع السيارة','نوع المركبة','نوع الاليه','نوع الآلية','نوع المركبه','vehicle type','type'],
        plateNo:       ['رقم اللوحة','رقم اللوحه','لوحة','لوحه','plate','plate no','plate number'],
        receiverName:  ['اسم المستلم','المستلم','مستلم','اسم المستخدم','receiver','received by','اسم المستلم من'],
        chassisNo:     ['رقم الهيكل','رقم الشاسيه','رقم الشاسي','رقم هيكل','هيكل','chassis','vin','chassis no'],
        department:    ['الجهة','الإدارة','الادارة','جهة','القسم','قسم','department','dept','الجهة / الإدارة'],
      };

      wb.SheetNames.forEach(sheetName=>{
        const ws=wb.Sheets[sheetName];
        const rows=XLSX.utils.sheet_to_json(ws,{header:1,defval:'',raw:false});
        if(rows.length<2) return;

        // Find header row (first row with multiple non-empty cells)
        let headerRowIdx=-1;
        let headerRow=[];
        for(let i=0;i<Math.min(5,rows.length);i++){
          const nonEmpty=rows[i].filter(c=>String(c).trim()!='');
          if(nonEmpty.length>=2){headerRowIdx=i;headerRow=rows[i].map(h=>String(h||'').trim().toLowerCase());break;}
        }
        if(headerRowIdx<0) return;

        // Map target fields to column indices
        const colMap={};
        Object.entries(TARGET_FIELDS).forEach(([field,aliases])=>{
          const idx=headerRow.findIndex(h=>aliases.some(a=>h.includes(a.toLowerCase())));
          if(idx>=0) colMap[field]=idx;
        });

        // Need at least 2 matching columns to proceed
        if(Object.keys(colMap).length<2) return;

        const dataRows=rows.slice(headerRowIdx+1).filter(r=>r.some(c=>String(c).trim()!=''));
        dataRows.forEach((row,rowIdx)=>{
          const rec={};
          let hasData=false;
          Object.entries(colMap).forEach(([field,colIdx])=>{
            const val=String(row[colIdx]||'').trim();
            if(val&&val!='undefined') {rec[field]=val;hasData=true;}
            else rec[field]='—';
          });
          if(hasData) extracted.push({...rec, _sheet:sheetName, _row:rowIdx+1});
        });
      });

      // Display results vertically stacked
      const resultsDiv=document.getElementById('extractorResults');
      const bodyDiv=document.getElementById('extractorResultsBody');
      const titleDiv=document.getElementById('extractorResultsTitle');

      if(!extracted.length){
        bodyDiv.innerHTML='<div class="ext-empty">⚠️ لم يتم العثور على البيانات المطلوبة في الملف.<br>تأكد أن الملف يحتوي على أعمدة مناسبة (نوع السيارة، رقم اللوحة، المستلم، رقم الهيكل، الجهة).</div>';
        titleDiv.textContent='النتائج';
        resultsDiv.style.display='block';
        return;
      }

      titleDiv.textContent=`تم استخراج ${extracted.length} سجل من الملف`;

      const fieldLabels={vehicleType:'نوع السيارة',plateNo:'رقم اللوحة',receiverName:'اسم المستلم',chassisNo:'رقم الهيكل',department:'الجهة / الإدارة'};

      bodyDiv.innerHTML=extracted.map((rec,i)=>`
        <div class="ext-record">
          <div class="ext-record-header">سجل ${i+1}${rec._sheet?' — ورقة: '+rec._sheet:''}</div>
          ${Object.entries(fieldLabels).map(([key,label])=>`
            <div class="ext-field">
              <div class="ext-field-label">${label}</div>
              <div class="ext-field-value">${rec[key]||'—'}</div>
            </div>`).join('')}
        </div>`).join('');

      resultsDiv.style.display='block';
      showToast(`✅ تم استخراج ${extracted.length} سجل بنجاح`);
    }catch(err){showToast('❌ خطأ في معالجة الملف');console.error(err);}
  };
  reader.readAsArrayBuffer(file);
}

