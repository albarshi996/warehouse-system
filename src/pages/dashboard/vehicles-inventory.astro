---
/**
 * جرد المركبات — سجلّ الأسطول الحيّ (إدارة الحركة).
 *
 * تحوّل من نموذج فحص منفرد يُحفظ ملفات إكسل متفرّقة إلى نظام سحابي مشترك
 * بين المخازن والحركة والموارد البشرية:
 *   - سجلّ أسطول حيّ من Firestore (تحديث لحظي onSnapshot).
 *   - نموذج الفحص الكامل يُحفظ سحابيًّا برقم تسلسلي رسمي VINSP-سنة-تسلسل.
 *   - ملف لكل مركبة: تاريخ الفحوصات + طلبات الصيانة + الزيوت + محاضر الحوادث.
 *   - الطباعة وPDF من قالب واحد بهوية «إنجاز المشارق» المعتمدة.
 *   - الإكسل صار نسخة احتياطية: تصدير كامل بلا فقد + استيراد ملفات قديمة
 *     مباشرةً إلى السحابة.
 *
 * الوصول: دور «الحركة» (fleet) محصور بهذه الصفحة (pageAccess.js) ويكتب فيها؛
 * المديران يكتبان؛ بقية المصادقين مشاهدة فقط (قواعد Firestore تفرض ذلك).
 * المنطق الخالص في `services/vehicles/` (مُختبَر وحدويًّا) — هنا الواجهة فقط.
 */
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Brandzo | جرد المركبات">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;900&family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">

<style is:inline>
  :root {
    --primary-v: #0d1b2a;
    --primary2-v: #1b3a5c;
    --accent-v: #f0a500;
    --accent2-v: #ffd166;
    --accent-glow: rgba(240,165,0,0.25);
    --border-v: #d4dce8;
    --ok-v: #00b87a;
    --warn-v: #f59e0b;
    --bad-v: #ef4444;
    --na-v: #94a3b8;
    --text-v: #1e293b;
    --surface-v: #f8fafc;
  }
  .vehicles-container { font-family: 'Tajawal', 'Cairo', sans-serif; background: linear-gradient(135deg, #e8edf5 0%, #f0f4fb 100%); color: var(--text-v); min-height: 100vh; position: relative; }
  .screen-bar { background: var(--primary-v); padding: 10px 24px; display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; position: sticky; top: 0; z-index: 200; box-shadow: 0 4px 20px rgba(0,0,0,0.35); }
  .screen-bar::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--accent-v), var(--accent2-v), var(--accent-v)); }
  .bar-brand { display: flex; align-items: center; gap: 14px; }
  .brand-logo-v { background: linear-gradient(135deg, var(--accent-v), var(--accent2-v)); border-radius: 10px; padding: 7px 14px; font-family: 'Cairo', sans-serif; font-size: 1.3rem; font-weight: 900; color: var(--primary-v); letter-spacing: -0.5px; box-shadow: 0 3px 12px var(--accent-glow); }
  .brand-divider { width: 1.5px; height: 28px; background: rgba(255,255,255,0.2); }
  .bar-title { color: rgba(255,255,255,0.85); font-size: 0.95rem; font-weight: 600; }
  .cloud-chip { display: inline-flex; align-items: center; gap: 7px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12); color: rgba(255,255,255,0.85); border-radius: 20px; padding: 6px 14px; font-size: 0.78rem; font-weight: 700; }
  .cloud-chip .dot { width: 9px; height: 9px; border-radius: 50%; background: var(--na-v); box-shadow: 0 0 8px currentColor; }
  .cloud-chip.online .dot { background: var(--ok-v); color: var(--ok-v); }
  .cloud-chip.pending .dot { background: var(--warn-v); color: var(--warn-v); }
  .cloud-chip.offline .dot { background: var(--bad-v); color: var(--bad-v); }
  .btn-group { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
  .btn-v { padding: 9px 16px; border-radius: 9px; border: none; cursor: pointer; font-family: 'Tajawal', sans-serif; font-size: 0.86rem; font-weight: 700; display: inline-flex; align-items: center; gap: 7px; transition: all 0.2s ease; position: relative; overflow: hidden; }
  .btn-v:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.25); }
  .btn-v:active { transform: translateY(0); }
  .btn-v:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .btn-save { background: linear-gradient(135deg, #0ea5e9, #0369a1); color: white; box-shadow: 0 3px 12px rgba(14,165,233,0.4); }
  .btn-ok-all { background: linear-gradient(135deg, #00b87a, #00976a); color: white; box-shadow: 0 3px 12px rgba(0,184,122,0.4); }
  .btn-import { background: linear-gradient(135deg, #3b82f6, #2563eb); color: white; box-shadow: 0 3px 12px rgba(59,130,246,0.4); }
  .btn-extractor { background: linear-gradient(135deg, #7c3aed, #6d28d9); color: white; box-shadow: 0 3px 12px rgba(124,58,237,0.4); }
  .btn-pdf { background: linear-gradient(135deg, #ef4444, #dc2626); color: white; box-shadow: 0 3px 12px rgba(239,68,68,0.4); }
  .btn-excel-v { background: linear-gradient(135deg, #059669, #047857); color: white; box-shadow: 0 3px 12px rgba(5,150,105,0.4); }
  .btn-seed { background: linear-gradient(135deg, #d97706, #b45309); color: white; box-shadow: 0 3px 12px rgba(217,119,6,0.4); }
  .btn-reset { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.85); border: 1px solid rgba(255,255,255,0.2); }
  .btn-light { background: white; color: var(--primary-v); border: 1.5px solid var(--border-v); }
  .btn-print { background: linear-gradient(135deg, var(--accent-v), var(--accent2-v)); color: var(--primary-v); box-shadow: 0 3px 12px var(--accent-glow); }
  .form-wrapper { max-width: 1100px; margin: 24px auto; padding: 0 20px 70px; }
  .header-card { background: var(--primary-v); border-radius: 18px; padding: 26px 34px; margin-bottom: 22px; position: relative; overflow: hidden; box-shadow: 0 12px 40px rgba(13,27,42,0.4); }
  .header-card::before { content: ''; position: absolute; top: -60px; left: -60px; width: 280px; height: 280px; background: radial-gradient(circle, rgba(240,165,0,0.18) 0%, transparent 70%); border-radius: 50%; }
  .header-inner { display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap; position: relative; z-index: 1; }
  .header-branding { display: flex; align-items: center; gap: 18px; }
  .header-logo-block { background: linear-gradient(135deg, var(--accent-v), var(--accent2-v)); border-radius: 14px; padding: 12px 20px; box-shadow: 0 6px 24px rgba(240,165,0,0.4); }
  .header-logo-block span { font-family: 'Cairo', sans-serif; font-size: 1.5rem; font-weight: 900; color: var(--primary-v); letter-spacing: -1px; }
  .header-text h2 { font-size: 1.55rem; font-weight: 900; color: white; margin-bottom: 3px; line-height: 1.2; }
  .header-text p { color: rgba(255,255,255,0.55); font-size: 0.85rem; }
  .header-meta { display: flex; gap: 12px; flex-wrap: wrap; }
  .meta-badge { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 10px 18px; text-align: center; backdrop-filter: blur(8px); min-width: 90px; }
  .meta-badge .num { font-size: 1.5rem; font-weight: 900; color: var(--accent-v); line-height: 1.2; font-family: 'Cairo', sans-serif; }
  .meta-badge .lbl { font-size: 0.72rem; opacity: 0.65; color: white; margin-top: 3px; }
  .summary-bar { background: var(--primary2-v); border-radius: 14px; padding: 14px 22px; display: flex; gap: 12px; align-items: center; margin-bottom: 20px; flex-wrap: wrap; box-shadow: 0 4px 20px rgba(13,27,42,0.2); border: 1px solid rgba(255,255,255,0.07); }
  .sum-label { color: rgba(255,255,255,0.5); font-size: 0.8rem; font-weight: 700; margin-left: auto; letter-spacing: 0.05em; }
  .sum-item { display: flex; align-items: center; gap: 9px; background: rgba(255,255,255,0.07); border-radius: 10px; padding: 8px 15px; border: 1px solid rgba(255,255,255,0.06); }
  .sum-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; box-shadow: 0 0 8px currentColor; }
  .sum-item .sum-text { color: rgba(255,255,255,0.7); font-size: 0.82rem; font-weight: 600; }
  .sum-item .count { font-size: 1.25rem; font-weight: 900; color: white; font-family: 'Cairo', sans-serif; }
  .section-card { background: white; border-radius: 16px; margin-bottom: 20px; box-shadow: 0 3px 16px rgba(0,0,0,0.07); overflow: hidden; border: 1px solid rgba(0,0,0,0.05); }
  .section-header-v { background: linear-gradient(135deg, var(--primary-v) 0%, var(--primary2-v) 100%); padding: 13px 22px; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .section-header-left { display: flex; align-items: center; gap: 12px; }
  .s-icon { width: 34px; height: 34px; background: linear-gradient(135deg, var(--accent-v), var(--accent2-v)); border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 1rem; box-shadow: 0 3px 10px rgba(240,165,0,0.4); flex-shrink: 0; }
  .section-header-v h3 { color: white; font-size: 1.02rem; font-weight: 700; }
  .section-all-ok-btn { background: rgba(0,184,122,0.2); color: #6effd0; border: 1px solid rgba(0,184,122,0.4); border-radius: 8px; padding: 6px 14px; font-family: 'Tajawal', sans-serif; font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: all 0.2s; }
  .section-all-ok-btn:hover { background: rgba(0,184,122,0.35); }
  .section-body { padding: 22px; }
  .fields-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .fields-grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
  .fields-grid.cols-4 { grid-template-columns: repeat(4, 1fr); }
  .fields-grid.cols-1 { grid-template-columns: 1fr; }
  .field-group { display: flex; flex-direction: column; gap: 5px; }
  .field-group label { font-size: 0.78rem; font-weight: 700; color: #64748b; letter-spacing: 0.02em; }
  .field-group input, .field-group select, .field-group textarea { border: 1.5px solid var(--border-v); border-radius: 9px; padding: 9px 13px; font-family: 'Tajawal', sans-serif; font-size: 0.95rem; color: var(--text-v); transition: all 0.2s; background: var(--surface-v); width: 100%; }
  .field-group input:focus, .field-group select:focus, .field-group textarea:focus { outline: none; border-color: var(--accent-v); box-shadow: 0 0 0 4px rgba(240,165,0,0.12); background: white; }
  .field-group textarea { resize: vertical; min-height: 75px; }
  .insp-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  .insp-table thead tr { background: linear-gradient(135deg, var(--primary-v), var(--primary2-v)); color: white; }
  .insp-table th { padding: 11px 14px; font-weight: 700; text-align: right; font-size: 0.83rem; }
  .insp-table th:first-child { width: 36px; text-align: center; }
  .insp-table tbody tr { border-bottom: 1px solid #edf0f5; }
  .insp-table tbody tr:hover { background: #f8fbff; }
  .insp-table td { padding: 9px 14px; vertical-align: middle; }
  .insp-table td:first-child { text-align: center; font-size: 0.72rem; color: #aab4c2; font-weight: 900; font-family: 'Cairo', sans-serif; }
  .row-label { font-size: 0.88rem; font-weight: 500; color: var(--text-v); line-height: 1.4; }
  .radio-group { display: flex; gap: 5px; justify-content: center; flex-wrap: wrap; }
  .radio-btn { position: relative; }
  .radio-btn input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }
  .radio-btn label { display: inline-flex; align-items: center; justify-content: center; padding: 5px 12px; border-radius: 20px; font-size: 0.77rem; font-weight: 700; cursor: pointer; border: 1.5px solid #d8dfe9; background: #f8fafc; transition: all 0.16s; white-space: nowrap; min-width: 52px; user-select: none; }
  .radio-btn input[type="radio"]:checked + label { border-color: transparent; color: white; box-shadow: 0 3px 10px rgba(0,0,0,0.2); transform: scale(1.05); }
  .radio-btn.ok-v input[type="radio"]:checked + label { background: linear-gradient(135deg, var(--ok-v), #00976a); }
  .radio-btn.warn-v input[type="radio"]:checked + label { background: linear-gradient(135deg, #f59e0b, #d97706); }
  .radio-btn.bad-v input[type="radio"]:checked + label { background: linear-gradient(135deg, var(--bad-v), #dc2626); }
  .radio-btn.na-v input[type="radio"]:checked + label { background: linear-gradient(135deg, #94a3b8, #64748b); }
  .radio-btn label:hover { border-color: #94a3b8; background: #f1f5f9; }
  .notes-input { border: 1.5px solid var(--border-v); border-radius: 7px; padding: 7px 11px; font-family: 'Tajawal', sans-serif; font-size: 0.82rem; width: 100%; min-width: 120px; background: var(--surface-v); color: var(--text-v); }
  .notes-input:focus { outline: none; border-color: var(--accent-v); background: white; }
  .tires-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .tire-item { border: 2px solid var(--border-v); border-radius: 12px; padding: 16px; background: var(--surface-v); }
  .tire-label { font-size: 0.88rem; font-weight: 800; color: var(--primary-v); margin-bottom: 12px; }
  .tire-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .sig-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .sig-box { border: 1.5px solid var(--border-v); border-radius: 12px; padding: 18px; text-align: center; background: var(--surface-v); }
  .sig-line { border-bottom: 2px dashed #c8d4e0; height: 50px; margin-bottom: 12px; }
  .sig-box label { font-size: 0.78rem; font-weight: 800; color: #64748b; display: block; margin-bottom: 6px; }
  .sig-box input { border: none; background: transparent; width: 100%; text-align: center; font-family: 'Tajawal', sans-serif; font-size: 0.92rem; color: var(--text-v); }
  .sig-box input:focus { outline: none; }
  .type-toggle { display: flex; background: var(--surface-v); border-radius: 12px; padding: 5px; border: 1.5px solid var(--border-v); width: fit-content; gap: 2px; flex-wrap: wrap; }
  .type-toggle label { padding: 9px 20px; border-radius: 9px; font-size: 0.9rem; font-weight: 700; cursor: pointer; color: #7a8a9e; transition: all 0.2s; user-select: none; }
  .type-toggle input[type="radio"] { display: none; }
  .type-toggle input[type="radio"]:checked + label { background: var(--primary-v); color: white; }
  .divider { border: none; border-top: 1.5px solid #edf2f8; margin: 18px 0; }
  .section-sub { font-size: 0.82rem; font-weight: 800; color: var(--accent-v); margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
  .section-sub::after { content: ''; flex: 1; border-top: 1.5px solid #edf2f8; }
  .overall-status { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
  .status-opt { position: relative; }
  .status-opt input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }
  .status-opt label { display: inline-flex; align-items: center; gap: 7px; padding: 12px 22px; border-radius: 30px; font-size: 0.92rem; font-weight: 700; cursor: pointer; border: 2px solid #d8dfe9; background: white; transition: all 0.2s; }
  .status-opt.ok-v input:checked + label { border-color: var(--ok-v); background: linear-gradient(135deg, var(--ok-v), #00976a); color: white; }
  .status-opt.cond input:checked + label { border-color: #f59e0b; background: linear-gradient(135deg, #f59e0b, #d97706); color: white; }
  .status-opt.rej input:checked + label { border-color: var(--bad-v); background: linear-gradient(135deg, var(--bad-v), #dc2626); color: white; }

  /* ═══ سجلّ الأسطول ═══ */
  .reg-actions { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin-bottom: 18px; }
  .reg-search { flex: 1; min-width: 220px; border: 1.5px solid var(--border-v); border-radius: 10px; padding: 10px 14px; font-family: 'Tajawal', sans-serif; font-size: 0.92rem; background: white; }
  .reg-search:focus { outline: none; border-color: var(--accent-v); box-shadow: 0 0 0 4px rgba(240,165,0,0.12); }
  .reg-table { width: 100%; border-collapse: collapse; font-size: 0.86rem; }
  .reg-table thead tr { background: linear-gradient(135deg, var(--primary-v), var(--primary2-v)); color: white; }
  .reg-table th { padding: 11px 12px; text-align: right; font-size: 0.8rem; font-weight: 700; white-space: nowrap; }
  .reg-table td { padding: 9px 12px; border-bottom: 1px solid #edf0f5; vertical-align: middle; }
  .reg-table tbody tr:hover { background: #f8fbff; }
  .reg-plate { font-family: 'Cairo', sans-serif; font-weight: 800; color: var(--primary-v); white-space: nowrap; }
  .badge { display: inline-flex; align-items: center; gap: 5px; border-radius: 14px; padding: 3px 10px; font-size: 0.74rem; font-weight: 800; white-space: nowrap; }
  .badge.ok { background: rgba(0,184,122,0.12); color: #00976a; }
  .badge.cond { background: rgba(245,158,11,0.14); color: #b45309; }
  .badge.rej { background: rgba(239,68,68,0.12); color: #b91c1c; }
  .badge.na { background: rgba(148,163,184,0.18); color: #475569; }
  .badge.alert { background: rgba(239,68,68,0.12); color: #b91c1c; }
  .badge.oil { background: rgba(217,119,6,0.14); color: #92400e; }
  .row-actions { display: flex; gap: 6px; white-space: nowrap; }
  .mini-btn { border: 1.5px solid var(--border-v); background: white; border-radius: 8px; padding: 5px 10px; font-family: 'Tajawal', sans-serif; font-size: 0.78rem; font-weight: 700; cursor: pointer; color: var(--primary-v); transition: all 0.15s; }
  .mini-btn:hover { border-color: var(--accent-v); background: #fffbeb; }
  .reg-empty { text-align: center; padding: 46px 20px; color: #94a3b8; font-size: 0.95rem; line-height: 2; }

  /* ═══ ملف المركبة (نافذة) ═══ */
  .veh-overlay { display: none; position: fixed; inset: 0; background: rgba(13,27,42,0.72); z-index: 500; align-items: center; justify-content: center; backdrop-filter: blur(6px); padding: 20px; }
  .veh-overlay.active { display: flex; }
  .veh-modal { background: white; border-radius: 20px; width: min(860px, 96vw); max-height: 88vh; overflow-y: auto; box-shadow: 0 30px 80px rgba(0,0,0,0.4); }
  .veh-modal-head { background: linear-gradient(135deg, var(--primary-v), var(--primary2-v)); color: white; padding: 18px 24px; border-radius: 20px 20px 0 0; display: flex; justify-content: space-between; align-items: center; gap: 12px; position: sticky; top: 0; z-index: 2; }
  .veh-modal-head h3 { font-size: 1.05rem; font-weight: 800; }
  .veh-modal-head .sub { font-size: 0.78rem; opacity: 0.65; margin-top: 2px; }
  .veh-close { background: rgba(255,255,255,0.12); border: none; color: white; border-radius: 8px; padding: 6px 12px; cursor: pointer; font-family: 'Tajawal', sans-serif; font-weight: 700; }
  .veh-tabs { display: flex; gap: 4px; padding: 12px 20px 0; border-bottom: 1.5px solid #edf0f5; flex-wrap: wrap; }
  .veh-tab { border: none; background: transparent; padding: 9px 16px; border-radius: 10px 10px 0 0; font-family: 'Tajawal', sans-serif; font-size: 0.88rem; font-weight: 700; color: #64748b; cursor: pointer; border-bottom: 3px solid transparent; }
  .veh-tab.active { color: var(--primary-v); border-bottom-color: var(--accent-v); background: #fffbeb; }
  .veh-tab-body { padding: 18px 22px 24px; }
  .veh-list-item { border: 1.5px solid #e2e8f0; border-radius: 12px; padding: 12px 16px; margin-bottom: 10px; display: flex; justify-content: space-between; gap: 12px; align-items: center; flex-wrap: wrap; background: var(--surface-v); }
  .veh-list-item .main { font-size: 0.9rem; font-weight: 700; color: var(--text-v); }
  .veh-list-item .meta { font-size: 0.76rem; color: #64748b; margin-top: 3px; line-height: 1.7; }
  .veh-add-form { border: 2px dashed var(--border-v); border-radius: 12px; padding: 16px; margin-bottom: 16px; background: #fffdf5; }
  .veh-add-form h4 { font-size: 0.85rem; font-weight: 800; color: var(--primary-v); margin-bottom: 12px; }

  /* ═══ نوافذ الاستيراد ═══ */
  .import-overlay { display: none; position: fixed; inset: 0; background: rgba(13,27,42,0.7); z-index: 500; align-items: center; justify-content: center; backdrop-filter: blur(6px); }
  .import-overlay.active { display: flex; }
  .import-modal { background: white; border-radius: 20px; padding: 32px 36px; max-width: 520px; width: 92%; max-height: 85vh; overflow-y: auto; box-shadow: 0 30px 80px rgba(0,0,0,0.4); text-align: center; animation: modalIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
  @keyframes modalIn { from { opacity: 0; transform: scale(0.85) translateY(20px); } to { opacity: 1; transform: scale(1) translateY(0); } }
  .import-modal .modal-icon { width: 64px; height: 64px; background: linear-gradient(135deg, #3b82f6, #2563eb); border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 18px; }
  .import-modal h3 { font-size: 1.25rem; font-weight: 800; color: var(--primary-v); margin-bottom: 8px; }
  .import-modal p { color: #64748b; font-size: 0.88rem; margin-bottom: 20px; line-height: 1.6; }
  .import-drop-zone { border: 2px dashed #d4dce8; border-radius: 14px; padding: 26px; margin-bottom: 18px; cursor: pointer; transition: all 0.2s; background: #f8fafc; }
