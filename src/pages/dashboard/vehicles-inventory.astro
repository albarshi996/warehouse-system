      <div class="fields-grid cols-1">
        <div class="field-group"><label>الملاحظات العامة والإجراءات المطلوبة</label><textarea name="generalNotes" rows="4" placeholder="اكتب ملاحظاتك وأي إجراءات مطلوبة..."></textarea></div>
      </div>
