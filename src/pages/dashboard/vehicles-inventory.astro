const extDropZone=document.getElementById('extDropZone');
if (extDropZone) {
  extDropZone.addEventListener('dragover',e=>{e.preventDefault();extDropZone.classList.add('dragging');});
  extDropZone.addEventListener('dragleave',()=>extDropZone.classList.remove('dragging'));
