
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>خريطة التجزئة — بنغازي 2026</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <style>
    :root {
      --bg-base:        #0d1117;
      --bg-surface:     #161b22;
      --bg-card:        #1c2128;
      --bg-hover:       #21262d;
      --border:         #30363d;
      --border-subtle:  #21262d;
      --text-primary:   #e6edf3;
      --text-secondary: #8b949e;
      --text-muted:     #484f58;
      --accent-blue:    #2188ff;
      --accent-blue-dim:#1a3d6e;
      --accent-green:   #3fb950;
      --accent-green-dim:#1a3a24;
      --accent-orange:  #d29922;
      --accent-orange-dim:#3d2e0a;
      --accent-red:     #f85149;
      --accent-red-dim: #3d1a1a;
      --accent-purple:  #bc8cff;
      --accent-purple-dim: #2d1e4a;
      --radius: 8px;
      --radius-sm: 5px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'IBM Plex Sans Arabic', sans-serif;
      background: var(--bg-base);
      color: var(--text-primary);
      direction: rtl;
      overflow: hidden;
      height: 100vh;
    }

    /* ── Top Header ─────────────────────────────────────────── */
    #top-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 20px;
      background: var(--bg-surface);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      gap: 12px;
    }
    .header-brand {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .header-logo {
      width: 32px; height: 32px;
      border-radius: 6px;
      background: linear-gradient(135deg, var(--accent-blue), #0a4d8c);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
    }
    .header-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--text-primary);
    }
    .header-subtitle {
      font-size: 10px;
      color: var(--text-muted);
      letter-spacing: .3px;
    }
    .header-authors {
      font-size: 10px;
      color: var(--text-secondary);
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 5px 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .author-sep { color: var(--text-muted); }

    /* ── Root Layout ────────────────────────────────────────── */
    #rh-root {
      display: flex;
      flex-direction: column;
      height: calc(100vh - 53px);
      gap: 0;
      overflow: hidden;
    }

    /* ── Stat Cards ─────────────────────────────────────────── */
    #rh-stat-row {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 10px;
      padding: 12px 16px 10px;
      flex-shrink: 0;
      background: var(--bg-base);
    }
    .rh-stat {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 12px 14px;
      display: flex; flex-direction: column; gap: 4px;
      position: relative; overflow: hidden; transition: border-color .2s;
    }
    .rh-stat::before {
      content: ''; position: absolute; top: 0; right: 0;
      width: 3px; height: 100%;
      border-radius: 0 var(--radius) var(--radius) 0;
    }
    .rh-stat.blue::before   { background: var(--accent-blue); }
    .rh-stat.green::before  { background: var(--accent-green); }
    .rh-stat.orange::before { background: var(--accent-orange); }
    .rh-stat.red::before    { background: var(--accent-red); }
    .rh-stat.purple::before { background: var(--accent-purple); }
    .rh-stat:hover { border-color: var(--accent-blue); }
    .s-label { font-size: 10px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: .5px; font-weight: 500; }
    .s-val   { font-size: 24px; font-weight: 700; font-family: 'JetBrains Mono', monospace; line-height: 1.1; }
    .rh-stat.blue   .s-val { color: var(--accent-blue); }
    .rh-stat.green  .s-val { color: var(--accent-green); }
    .rh-stat.orange .s-val { color: var(--accent-orange); }
    .rh-stat.red    .s-val { color: var(--accent-red); }
    .rh-stat.purple .s-val { color: var(--accent-purple); }
    .s-sub { font-size: 10px; color: var(--text-muted); }

    /* ── Main Split ─────────────────────────────────────────── */
    #rh-split {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr 420px;
      gap: 10px;
      padding: 0 16px 12px;
      overflow: hidden;
      min-height: 0;
    }

    /* ── Map Panel ──────────────────────────────────────────── */
    #rh-map-panel {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      position: relative;
      display: flex; flex-direction: column;
    }
    .ph {
      padding: 9px 14px;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      flex-shrink: 0;
      background: var(--bg-surface);
      gap: 8px;
    }
    .ph-title { font-size: 12px; font-weight: 600; display: flex; align-items: center; gap: 7px; }
    .pulse-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent-green); animation: rhPulse 2s infinite; }
    @keyframes rhPulse { 0%,100%{opacity:1} 50%{opacity:.3} }
    #rh-map { flex: 1; min-height: 0; }

    .rh-legend {
      position: absolute; bottom: 14px; left: 14px;
      background: rgba(22,27,34,0.95);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 10px 13px;
      z-index: 1000; font-size: 11px;
      backdrop-filter: blur(6px);
    }
    .rh-legend.right { left: auto; right: 14px; }
    .leg-title { color: var(--text-muted); font-size: 9px; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 6px; }
    .leg-row   { display: flex; align-items: center; gap: 6px; color: var(--text-secondary); padding: 2px 0; font-size: 10px; }
    .leg-dot   { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

    /* ── Table Panel ────────────────────────────────────────── */
    #rh-table-panel {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      display: flex; flex-direction: column;
      overflow: hidden;
    }
    #rh-table-panel .ph { flex-direction: column; align-items: stretch; gap: 7px; }
    #rh-search-wrap { position: relative; }
    #rh-search {
      width: 100%;
      background: var(--bg-base);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      color: var(--text-primary);
      font-family: 'IBM Plex Sans Arabic', sans-serif;
      font-size: 12px;
      padding: 7px 30px 7px 10px;
      outline: none;
      transition: border-color .15s;
      direction: rtl;
    }
    #rh-search::placeholder { color: var(--text-muted); }
    #rh-search:focus { border-color: var(--accent-blue); }
    .srch-icon { position: absolute; left: 9px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 12px; pointer-events: none; }

    #rh-filters {
      display: flex; gap: 5px; flex-wrap: wrap;
      padding: 6px 14px;
      border-bottom: 1px solid var(--border-subtle);
      flex-shrink: 0;
    }
    .fp {
      font-size: 10px; padding: 3px 9px; border-radius: 20px;
      border: 1px solid var(--border); background: transparent;
      color: var(--text-secondary); cursor: pointer;
      font-family: 'IBM Plex Sans Arabic', sans-serif;
      transition: all .15s;
    }
    .fp.active    { border-color: var(--accent-blue); background: var(--accent-blue-dim); color: var(--accent-blue); }
    .fp:hover:not(.active) { border-color: var(--text-muted); color: var(--text-primary); }

    /* Sector filter pills */
    #rh-sector-filters {
      display: flex; gap: 5px; flex-wrap: wrap;
      padding: 5px 14px;
      border-bottom: 1px solid var(--border-subtle);
      flex-shrink: 0;
    }
    .sector-pill {
      font-size: 9px; padding: 2px 8px; border-radius: 20px;
      border: 1px solid var(--border); background: transparent;
      color: var(--text-muted); cursor: pointer;
      font-family: 'IBM Plex Sans Arabic', sans-serif;
      transition: all .15s; white-space: nowrap;
    }
    .sector-pill.active { border-color: var(--accent-purple); background: var(--accent-purple-dim); color: var(--accent-purple); }
    .sector-pill:hover:not(.active) { color: var(--text-secondary); border-color: var(--text-muted); }

    #rh-tscroll {
      flex: 1; overflow-y: auto; overflow-x: hidden;
      scrollbar-width: thin; scrollbar-color: var(--border) transparent;
    }
    #rh-tscroll::-webkit-scrollbar { width: 4px; }
    #rh-tscroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }

    table.rh-table { width: 100%; border-collapse: collapse; font-size: 11px; }
    .rh-table thead th {
      padding: 7px 6px;
      text-align: right; color: var(--text-muted);
      font-weight: 500; font-size: 9px; text-transform: uppercase; letter-spacing: .4px;
      border-bottom: 1px solid var(--border);
      position: sticky; top: 0; background: var(--bg-card); z-index: 2;
    }
    .rh-table tbody tr { border-bottom: 1px solid var(--border-subtle); cursor: pointer; transition: background .1s; }
    .rh-table tbody tr:hover    { background: var(--bg-hover); }
    .rh-table tbody tr.selected { background: var(--accent-blue-dim); }
    .rh-table tbody td { padding: 6px 6px; color: var(--text-secondary); white-space: nowrap; }
    .rh-table tbody td:first-child { color: var(--text-primary); font-weight: 500; }

    /* Badges */
    .badge { display: inline-flex; align-items: center; gap: 2px; padding: 1px 6px; border-radius: 20px; font-size: 9px; font-weight: 600; white-space: nowrap; }
    .badge-A   { background: #3d2e0a; color: #d29922; border: 1px solid #d2992244; }
    .badge-B   { background: var(--accent-blue-dim); color: var(--accent-blue); border: 1px solid #2188ff44; }
    .badge-C   { background: #21262d; color: #8b949e; border: 1px solid var(--border); }
    .badge-D   { background: var(--accent-purple-dim); color: var(--accent-purple); border: 1px solid #bc8cff44; }
    .badge-match-yes  { background: var(--accent-green-dim); color: var(--accent-green); border: 1px solid #3fb95044; }
    .badge-match-part { background: var(--accent-orange-dim); color: var(--accent-orange); border: 1px solid #d2992244; }
    .badge-match-no   { background: var(--accent-red-dim); color: var(--accent-red); border: 1px solid #f8514944; }

    .btn-act {
      background: transparent; border: 1px solid var(--border);
      color: var(--text-secondary); font-size: 9px; padding: 2px 6px;
      border-radius: var(--radius-sm); cursor: pointer; transition: all .15s; white-space: nowrap;
    }
    .btn-act:hover     { border-color: var(--accent-blue); color: var(--accent-blue); background: var(--accent-blue-dim); }
    .btn-act.edit:hover{ border-color: var(--accent-orange); color: var(--accent-orange); background: var(--accent-orange-dim); }

    #rh-sel-info {
      padding: 7px 12px;
      border-top: 1px solid var(--border);
      background: var(--bg-surface);
      display: flex; justify-content: space-between; align-items: center;
      font-size: 10px; color: var(--text-muted); flex-shrink: 0;
    }
    .rh-no-results { text-align: center; padding: 32px 20px; color: var(--text-muted); font-size: 12px; }

    /* ── Map tile ───────────────────────────────────────────── */
    .leaflet-tile { filter: brightness(0.65) saturate(0.35); }
    .leaflet-popup-content-wrapper {
      background: var(--bg-card) !important; color: var(--text-primary) !important;
      border: 1px solid var(--border) !important; border-radius: 8px !important;
      box-shadow: 0 8px 32px rgba(0,0,0,.6) !important;
      font-family: 'IBM Plex Sans Arabic', sans-serif !important; direction: rtl;
    }
    .leaflet-popup-tip { background: var(--bg-card) !important; }
    .leaflet-popup-close-button { color: var(--text-muted) !important; }
    .popup-title  { font-weight: 700; font-size: 13px; margin-bottom: 8px; color: var(--accent-blue); border-bottom: 1px solid var(--border); padding-bottom: 7px; }
    .popup-row    { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; padding: 3px 0; font-size: 11px; }
    .popup-row.section { margin: 5px 0 2px; border-top: 1px dashed var(--border); padding-top: 5px; }
    .pk { color: var(--text-muted); flex-shrink: 0; }
    .pv { color: var(--text-primary); font-weight: 500; text-align: left; }
    .pv-desc { color: var(--text-secondary); font-size: 10px; line-height: 1.4; max-width: 200px; }

    /* ── Header buttons ─────────────────────────────────────── */
    .btn-hdr {
      display: flex; align-items: center; gap: 5px;
      padding: 5px 11px; border-radius: var(--radius-sm);
      border: 1px solid var(--border); background: var(--bg-card);
      color: var(--text-secondary);
      font-family: 'IBM Plex Sans Arabic', sans-serif;
      font-size: 10px; cursor: pointer; transition: all .2s; white-space: nowrap;
    }
    .btn-hdr:hover        { border-color: var(--accent-blue); color: var(--accent-blue); background: var(--accent-blue-dim); }
    .btn-hdr.active-hex   { border-color: var(--accent-green); color: var(--accent-green); background: var(--accent-green-dim); }
    .btn-hdr.danger:hover { border-color: var(--accent-red); color: var(--accent-red); background: var(--accent-red-dim); }

    /* ── Fullscreen ─────────────────────────────────────────── */
    #rh-map-panel.rh-fullscreen {
      position: fixed !important; inset: 0 !important;
      z-index: 5000 !important; border-radius: 0 !important;
      width: 100vw !important; height: 100vh !important;
    }
    #rh-map-panel.rh-fullscreen #rh-map { height: calc(100vh - 44px) !important; }
    body.map-fullscreen-active { overflow: hidden; }

    /* ── Edit Modal ─────────────────────────────────────────── */
    #rh-modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.7); z-index: 9000;
      align-items: center; justify-content: center;
      padding: 20px; overflow-y: auto;
    }
    #rh-modal-overlay.open { display: flex; }
    #rh-modal {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 22px 26px; width: 500px;
      max-width: 95vw; max-height: 90vh; overflow-y: auto;
      direction: rtl; box-shadow: 0 20px 60px rgba(0,0,0,.8);
    }
    #rh-modal h3 { font-size: 14px; font-weight: 700; margin-bottom: 16px; border-bottom: 1px solid var(--border); padding-bottom: 10px; }
    .rh-field { display: flex; flex-direction: column; gap: 4px; margin-bottom: 12px; }
    .rh-field label { font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: .4px; }
    .rh-field input, .rh-field select, .rh-field textarea {
      background: var(--bg-base); border: 1px solid var(--border);
      border-radius: var(--radius-sm); color: var(--text-primary);
      font-family: 'IBM Plex Sans Arabic', sans-serif;
      font-size: 12px; padding: 7px 10px; outline: none; transition: border-color .15s;
    }
    .rh-field textarea { resize: vertical; min-height: 60px; }
    .rh-field input:focus, .rh-field select:focus, .rh-field textarea:focus { border-color: var(--accent-blue); }
    .rh-field select option { background: var(--bg-card); }
    .modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .rh-modal-actions { display: flex; gap: 10px; justify-content: flex-start; margin-top: 16px; }
    .btn-save   { padding: 8px 20px; border-radius: var(--radius-sm); border: none; background: var(--accent-blue); color: #fff; font-size: 12px; cursor: pointer; font-family: 'IBM Plex Sans Arabic', sans-serif; font-weight: 600; transition: opacity .2s; }
    .btn-save:hover { opacity: .85; }
    .btn-cancel { padding: 8px 16px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: transparent; color: var(--text-secondary); font-size: 12px; cursor: pointer; font-family: 'IBM Plex Sans Arabic', sans-serif; transition: all .15s; }
    .btn-cancel:hover { border-color: var(--text-muted); color: var(--text-primary); }

    /* ── Toast ──────────────────────────────────────────────── */
    #rh-toast {
      position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%) translateY(20px);
      background: var(--bg-surface); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 9px 18px;
      font-size: 12px; color: var(--text-primary); z-index: 9999;
      opacity: 0; transition: opacity .3s, transform .3s; pointer-events: none; white-space: nowrap;
    }
    #rh-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    #rh-toast.error   { border-color: var(--accent-red); color: var(--accent-red); }
    #rh-toast.success { border-color: var(--accent-green); color: var(--accent-green); }

    /* Responsive */
    @media (max-width: 900px) {
      #rh-split { grid-template-columns: 1fr; }
      #rh-stat-row { grid-template-columns: repeat(3, 1fr); }
    }
  </style>
</head>
<body>

<!-- ══ Top Header ══ -->
<div id="top-header">
  <div class="header-brand">
    <div class="header-logo">🗺️</div>
    <div>
      <div class="header-title">لوحة التجزئة الجغرافية — بنغازي 2026</div>
      <div class="header-subtitle">تحليل ديموغرافي وتجاري شامل · جميع أحياء المدينة</div>
    </div>
  </div>
  <div class="header-authors">
    <span>📋 إعداد:</span>
    <span>محمد البرشي</span>
    <span class="author-sep">·</span>
    <span>رمزي باش</span>
  </div>
</div>

<!-- ══ Root ══ -->
<div id="rh-root">

  <!-- Stat Cards -->
  <div id="rh-stat-row">
    <div class="rh-stat blue">
      <div class="s-label">الأحياء المرصودة</div>
      <div class="s-val" id="stat-total">—</div>
      <div class="s-sub">حي وتجمع في بنغازي</div>
    </div>
    <div class="rh-stat green">
      <div class="s-label">تطابق كامل</div>
      <div class="s-val" id="stat-match-full">—</div>
      <div class="s-sub">أسواق تخدم السكان</div>
    </div>
    <div class="rh-stat orange">
      <div class="s-label">تطابق جزئي</div>
      <div class="s-val" id="stat-match-partial">—</div>
      <div class="s-sub">تغطية غير مكتملة</div>
    </div>
    <div class="rh-stat red">
      <div class="s-label">غير مطابق</div>
      <div class="s-val" id="stat-match-none">—</div>
      <div class="s-sub">فجوات استثمارية</div>
    </div>
    <div class="rh-stat purple">
      <div class="s-label">إجمالي السكان</div>
      <div class="s-val" id="stat-pop">—</div>
      <div class="s-sub">مليون نسمة تقريباً</div>
    </div>
  </div>

  <!-- Split -->
  <div id="rh-split">

    <!-- Map Panel -->
    <div id="rh-map-panel">
      <div class="ph">
        <div class="ph-title">
          <span class="pulse-dot"></span>
          الخريطة التفاعلية — بنغازي الكبرى
        </div>
        <div style="display:flex;gap:7px;align-items:center;">
          <button class="btn-hdr" id="btn-fullscreen">⛶ تكبير</button>
          <button class="btn-hdr" id="btn-hex-toggle">⬡ خرائط سداسية</button>
          <button class="btn-hdr danger" id="btn-reset-data">↺ إعادة ضبط</button>
        </div>
      </div>
      <div id="rh-map"></div>
      <div class="rh-legend">
        <div class="leg-title">تطابق السوق</div>
        <div class="leg-row"><div class="leg-dot" style="background:#3fb950"></div> مطابق</div>
        <div class="leg-row"><div class="leg-dot" style="background:#d29922"></div> جزئي</div>
        <div class="leg-row"><div class="leg-dot" style="background:#f85149"></div> غير مطابق</div>
      </div>
      <div class="rh-legend right">
        <div class="leg-title">الفئات</div>
        <div class="leg-row"><div class="leg-dot" style="background:#d29922"></div> A — دخل مرتفع</div>
        <div class="leg-row"><div class="leg-dot" style="background:#2188ff"></div> B — لوجستي/مختلط</div>
        <div class="leg-row"><div class="leg-dot" style="background:#8b949e"></div> C — كثافة استهلاكية</div>
        <div class="leg-row"><div class="leg-dot" style="background:#bc8cff"></div> D — ضواحي توسع</div>
      </div>
    </div>

    <!-- Table Panel -->
    <div id="rh-table-panel">
      <div class="ph">
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <div class="ph-title">قائمة الأحياء</div>
          <span id="rh-row-count" style="font-size:10px;color:var(--text-muted)"></span>
        </div>
        <div id="rh-search-wrap">
          <span class="srch-icon">🔍</span>
          <input id="rh-search" type="text" placeholder="ابحث باسم الحي أو المنطقة..." />
        </div>
      </div>

      <!-- Class filters -->
      <div id="rh-filters">
        <button class="fp active" data-filter="all">الكل</button>
        <button class="fp" data-filter="A">فئة A</button>
        <button class="fp" data-filter="B">فئة B</button>
        <button class="fp" data-filter="C">فئة C</button>
