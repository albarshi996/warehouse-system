  let DATA = DEFAULT_DATA.map(d => ({...d}));

  // ── Toast ──────────────────────────────────────────────────────────────
  function showToast(msg, type = '') {
    const t = document.getElementById('rh-toast');
    t.textContent = msg;
    t.className = 'show' + (type ? ' ' + type : '');
    setTimeout(() => { t.className = ''; }, 3000);
  }

  // ── localStorage ──────────────────────────────────────────────────────
  const LS_KEY = 'benghazi_hub_v3';
  function loadFromStorage() {
    try {
      const saved = localStorage.getItem(LS_KEY);
      if (!saved) return;
      const overrides = JSON.parse(saved);
      overrides.forEach(o => {
        const idx = DATA.findIndex(d => d.id === o.id);
        if (idx !== -1) DATA[idx] = {...DATA[idx], ...o};
      });
      updateStats(); renderTable(); rebuildMarkers();
    } catch (e) { console.warn('Load error:', e); }
  }
  function saveToStorage(rec) {
    try {
      let arr = [];
      const ex = localStorage.getItem(LS_KEY);
      if (ex) arr = JSON.parse(ex);
      const idx = arr.findIndex(o => o.id === rec.id);
      if (idx !== -1) arr[idx] = rec; else arr.push(rec);
      localStorage.setItem(LS_KEY, JSON.stringify(arr));
    } catch (e) { showToast('❌ فشل الحفظ', 'error'); }
  }
  function resetToDefaults() {
    DATA = DEFAULT_DATA.map(d => ({...d}));
    try { localStorage.removeItem(LS_KEY); } catch (e) {}
    updateStats(); renderTable(); rebuildMarkers();
    if (hexActive) renderHexLayer();
    showToast('✓ تمت إعادة ضبط البيانات', 'success');
  }

  // ── Stats ──────────────────────────────────────────────────────────────
  function updateStats() {
    document.getElementById('stat-total').textContent = DATA.length;
    document.getElementById('stat-match-full').textContent = DATA.filter(d => d.market_match === 'مطابق').length;
    document.getElementById('stat-match-partial').textContent = DATA.filter(d => d.market_match === 'جزئي').length;
    document.getElementById('stat-match-none').textContent = DATA.filter(d => d.market_match === 'غير مطابق').length;
    const totalPop = DATA.reduce((s, d) => s + (d.population || 0), 0);
    document.getElementById('stat-pop').textContent = (totalPop / 1000000).toFixed(2) + 'م';
  }

  // ── Map ──────────────────────────────────────────────────────────────
  const rhMap = L.map('rh-map', { zoomControl: false }).setView([32.095, 20.12], 11);
  L.control.zoom({ position: 'topleft' }).addTo(rhMap);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap', maxZoom: 18
  }).addTo(rhMap);

  const fsControl = L.control({ position: 'topright' });
  fsControl.onAdd = function () {
    const btn = L.DomUtil.create('button', 'leaflet-bar leaflet-control rh-fs-btn');
    btn.innerHTML = '⛶';
    btn.title = 'تكبير الخريطة';
    btn.style.cssText = `
      width:34px;height:34px;line-height:34px;text-align:center;
      background:#1c2128;color:#e6edf3;border:1px solid #30363d;
      border-radius:6px;cursor:pointer;font-size:16px;
      display:block;margin:0;
    `;
    L.DomEvent.on(btn, 'click', function(e) {
      L.DomEvent.stopPropagation(e);
      document.getElementById('btn-fullscreen').click();
    });
    return btn;
  };
  fsControl.addTo(rhMap);

  // Fullscreen
  let mapFS = false;
  document.getElementById('btn-fullscreen').addEventListener('click', () => {
    mapFS = !mapFS;
    const panel = document.getElementById('rh-map-panel');
    const btn   = document.getElementById('btn-fullscreen');
    if (mapFS) {
      panel.classList.add('rh-fullscreen');
      document.body.classList.add('map-fullscreen-active');
      btn.textContent = '✕ تصغير';
      btn.classList.add('active-hex');
    } else {
      panel.classList.remove('rh-fullscreen');
      document.body.classList.remove('map-fullscreen-active');
      btn.textContent = '⛶ تكبير';
      btn.classList.remove('active-hex');
    }
    setTimeout(() => rhMap.invalidateSize(), 100);
  });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && mapFS) document.getElementById('btn-fullscreen').click();
  });

  function matchColor(match) {
    if (match === 'غير مطابق') return '#f85149';
    if (match === 'جزئي')       return '#d29922';
    return '#3fb950';
  }

  function incomeLabel(income) {
    const map = { 'مرتفع': '💰 مرتفع', 'متوسط-جيد': '💵 متوسط-جيد', 'متوسط': '💴 متوسط', 'متباين': '💱 متباين' };
    return map[income] || income;
  }

  function infraLabel(infra) {
    const map = { 'ممتاز': '🟢 ممتازة', 'جيد': '🔵 جيدة', 'متوسط': '🟡 متوسطة', 'قديمة': '🔴 قديمة', 'قيد التطور': '🟠 قيد التطور' };
    return map[infra] || infra;
  }

  function sectorLabel(s) {
    const map = { 1: 'وسط البلد', 2: 'مناطق راقية', 3: 'كثافة FMCG', 4: 'لوجستي', 5: 'ضواحي توسع' };
    return map[s] || s;
  }

  function buildPopup(d) {
    const segBadges = (d.segments_present || []).map(s => {
      const cls = s === 'A' ? 'badge-A' : s === 'B' ? 'badge-B' : s === 'D' ? 'badge-D' : 'badge-C';
      return `<span class="badge ${cls}">${s}</span>`;
    }).join(' ');
    return `<div style="min-width:220px;padding:2px">
      <div class="popup-title">📍 ${d.neighborhood}</div>
      <div class="popup-row"><span class="pk">القطاع</span><span class="pv">${sectorLabel(d.sector)}</span></div>
      <div class="popup-row"><span class="pk">الفئات</span><span class="pv">${segBadges}</span></div>
      <div class="popup-row"><span class="pk">تطابق السوق</span><span class="pv" style="color:${matchColor(d.market_match)}">${d.market_match}</span></div>
      <div class="popup-row section"><span class="pk">المؤشرات الحيوية</span></div>
      <div class="popup-row"><span class="pk">👥 عدد السكان</span><span class="pv">${d.population.toLocaleString('ar-EG')}</span></div>
      <div class="popup-row"><span class="pk">💰 الدخل</span><span class="pv">${incomeLabel(d.income)}</span></div>
      <div class="popup-row"><span class="pk">🚦 المرور</span><span class="pv">${d.flow}</span></div>
      <div class="popup-row"><span class="pk">🏗️ البنية</span><span class="pv">${infraLabel(d.infra)}</span></div>
      <div class="popup-row section"><span class="pk">ملاحظات</span></div>
      <div style="padding:3px 0"><span class="pv-desc">${d.notes || '—'}</span></div>
    </div>`;
  }

  const markerLayer = L.layerGroup().addTo(rhMap);
  const markers = {};
  let selectedId = null;

  function rebuildMarkers() {
    markerLayer.clearLayers();
    DATA.forEach(d => {
      const color = matchColor(d.market_match);
      const icon = L.divIcon({
        className: '',
        html: `<div style="width:12px;height:12px;background:${color};border:2px solid rgba(255,255,255,0.2);border-radius:50%;box-shadow:0 0 6px ${color}88;cursor:pointer;"></div>`,
        iconSize: [12,12], iconAnchor: [6,6]
      });
      const marker = L.marker([d.lat, d.lng], { icon });
      marker.on('click', () => showNeighborhood(d, true));
      marker.bindPopup(buildPopup(d), { maxWidth: 280 });
      markers[d.id] = marker;
      if (!hexActive) markerLayer.addLayer(marker);
    });
  }

  function showNeighborhood(d, fromMap = false) {
    selectedId = d.id;
    document.querySelectorAll('#rh-tbody tr').forEach(r =>
      r.classList.toggle('selected', r.dataset.id == d.id)
    );
    const row = document.querySelector(`#rh-tbody tr[data-id="${d.id}"]`);
    if (row) row.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    document.getElementById('rh-sel-name').innerHTML =
      `<span style="color:var(--rh-text-primary);font-weight:600">${d.neighborhood}</span> · فئة ${d.class} · ${d.population.toLocaleString('ar-EG')} ساكن`;
    document.getElementById('rh-sel-detail').textContent = sectorLabel(d.sector);
    if (!fromMap) rhMap.setView([d.lat, d.lng], 14, { animate: true, duration: 0.8 });
    if (!hexActive && markers[d.id]) markers[d.id].openPopup();
  }

  // ── Hex Layer (District-Centered — سداسي واحد لكل حي على إحداثياته الفعلية) ──
  let hexActive = false;
  let hexLayer = null;

  const LAT_CORR = Math.cos(32.1 * Math.PI / 180); // ~0.848

  function hexPolygon(cLat, cLng, r) {
    const pts = [];
    for (let i = 0; i < 6; i++) {
      const angleDeg = 60 * i - 30;
      const a = (Math.PI / 180) * angleDeg;
      pts.push([
        cLng + (r / LAT_CORR) * Math.cos(a),
        cLat + r * Math.sin(a)
      ]);
    }
    pts.push(pts[0]);
    return pts;
  }

  function adaptiveRadius(d) {
    let minDist = Infinity;
    for (const other of DATA) {
      if (other.id === d.id) continue;
      const dlat = d.lat - other.lat;
      const dlng = (d.lng - other.lng) * LAT_CORR;
      const dist = Math.sqrt(dlat * dlat + dlng * dlng);
      if (dist < minDist) minDist = dist;
    }
    return Math.max(0.003, Math.min(0.007, minDist * 0.40));
  }

  function renderHexLayer() {
    if (hexLayer) { rhMap.removeLayer(hexLayer); hexLayer = null; }

    const features = DATA.map(d => ({
      type: 'Feature',
      properties: { id: d.id, match: d.market_match, data: d, pop: d.population },
      geometry: {
        type: 'Polygon',
        coordinates: [ hexPolygon(d.lat, d.lng, adaptiveRadius(d)) ]
      }
    }));

    const maxPop = Math.max(...DATA.map(d => d.population));

    hexLayer = L.geoJSON({ type: 'FeatureCollection', features }, {
      style: feat => {
        const ratio = feat.properties.pop / maxPop;
        const opacity = 0.45 + ratio * 0.35;
        return {
          fillColor:   matchColor(feat.properties.match),
          fillOpacity: opacity,
          color:       'rgba(255,255,255,0.25)',
          weight:      1.5
        };
      },
      onEachFeature: (feat, layer) => {
        const d = feat.properties.data;
        layer.bindPopup(buildPopup(d), { maxWidth: 280 });
        layer.bindTooltip(d.neighborhood, {
          permanent: true,
          direction: 'center',
          className: 'hex-label-tooltip'
        });
        layer.on('mouseover', function () {
          this.setStyle({ fillOpacity: 0.95, weight: 2.5, color: 'rgba(255,255,255,0.7)' });
        });
        layer.on('mouseout', function () { hexLayer.resetStyle(this); });
        layer.on('click', function () {
          showNeighborhood(d, true);
          this.openPopup();
        });
      }
    }).addTo(rhMap);
  }

  document.getElementById('btn-hex-toggle').addEventListener('click', () => {
    hexActive = !hexActive;
    const btn = document.getElementById('btn-hex-toggle');
    if (hexActive) {
      btn.classList.add('active-hex');
      btn.textContent = '📍 خريطة عادية';
      markerLayer.remove();
      renderHexLayer();
    } else {
      btn.classList.remove('active-hex');
      btn.textContent = '⬡ خرائط سداسية';
      if (hexLayer) { rhMap.removeLayer(hexLayer); hexLayer = null; }
      markerLayer.addTo(rhMap);
    }
  });

  document.getElementById('btn-reset-data').addEventListener('click', () => {
    if (confirm('هل تريد إعادة ضبط جميع البيانات للقيم الافتراضية؟')) resetToDefaults();
  });

  // ── Grid View للأحياء ──────────────────────────────────────────────────
  let gridActive = false;

  function renderGridCards() {
    const scroll = document.getElementById('rh-tscroll');
    scroll.classList.add('grid-view');
    // أخفِ الجدول
    const tbl = scroll.querySelector('table');
    const noRes = document.getElementById('rh-no-results');
    if (tbl) tbl.style.display = 'none';
    if (noRes) noRes.style.display = 'none';

    // أزل الـ grid القديم إن وُجد
    let grid = document.getElementById('rh-grid-cards');
    if (grid) grid.remove();

    grid = document.createElement('div');
    grid.id = 'rh-grid-cards';

    const filtered = DATA.filter(d => {
      if (currentFilter === 'none') return d.market_match === 'غير مطابق';
      if (currentFilter === 'partial') return d.market_match === 'جزئي';
      if (currentFilter !== 'all') return d.class === currentFilter;
      return true;
    }).filter(d => {
      if (currentSector !== 'all') return String(d.sector) === currentSector;
      return true;
    }).filter(d => {
      if (!searchVal) return true;
      return d.neighborhood.includes(searchVal);
    });

    filtered.forEach(d => {
      const card = document.createElement('div');
      card.className = 'district-card' + (d.id === selectedId ? ' selected' : '');
      card.dataset.id = d.id;
      card.innerHTML = `<div class="dc-dot" style="background:${matchColor(d.market_match)}"></div>
        <span class="dc-name">${d.neighborhood}</span>`;
      card.addEventListener('click', () => {
        document.querySelectorAll('.district-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        showNeighborhood(d, false);
      });
      grid.appendChild(card);
    });

    scroll.appendChild(grid);
    document.getElementById('rh-row-count').textContent = filtered.length + ' حي';
  }

  function destroyGridCards() {
    const scroll = document.getElementById('rh-tscroll');
    scroll.classList.remove('grid-view');
    const tbl = scroll.querySelector('table');
    if (tbl) tbl.style.display = '';
    const grid = document.getElementById('rh-grid-cards');
    if (grid) grid.remove();
  }

  document.getElementById('btn-grid-toggle').addEventListener('click', () => {
    gridActive = !gridActive;
    const btn = document.getElementById('btn-grid-toggle');
    if (gridActive) {
      btn.classList.add('active-hex');
      btn.textContent = '☰ جدول';
      renderGridCards();
    } else {
      btn.classList.remove('active-hex');
      btn.textContent = '⊞ شبكة الأحياء';
      destroyGridCards();
      renderTable();
    }
  });

  // ── Table ──────────────────────────────────────────────────────────────
  let currentFilter = 'all';
  let currentSector = 'all';
  let searchVal     = '';

  function segBadge(segments) {
    return (segments || []).map(s => {
      const cls = s === 'A' ? 'badge-A' : s === 'B' ? 'badge-B' : s === 'D' ? 'badge-D' : 'badge-C';
      return `<span class="badge ${cls}">${s}</span>`;
    }).join(' ');
  }
  function matchBadge(match) {
    if (match === 'مطابق')     return `<span class="badge badge-match-yes">${match}</span>`;
    if (match === 'جزئي')      return `<span class="badge badge-match-part">${match}</span>`;
    if (match === 'غير مطابق') return `<span class="badge badge-match-no">${match}</span>`;
    return `<span class="badge">${match}</span>`;
  }
  function infraBadge(infra) {
    const colors = { 'ممتاز': '#3fb950', 'جيد': '#2188ff', 'متوسط': '#d29922', 'قديمة': '#f85149', 'قيد التطور': '#bc8cff' };
    const c = colors[infra] || '#8b949e';
    return `<span style="color:${c};font-size:9px;">${infra}</span>`;
  }

  function renderTable() {
    const q = searchVal.trim();
    const filtered = DATA.filter(d => {
      if (q && !d.neighborhood.includes(q) && !d.notes.includes(q)) return false;
      if (currentSector !== 'all' && d.sector !== parseInt(currentSector)) return false;
      if (currentFilter === 'A') return (d.segments_present || []).includes('A');
      if (currentFilter === 'B') return (d.segments_present || []).includes('B');
      if (currentFilter === 'C') return (d.segments_present || []).includes('C');
      if (currentFilter === 'D') return d.class === 'D';
      if (currentFilter === 'none')    return d.market_match === 'غير مطابق';
      if (currentFilter === 'partial') return d.market_match === 'جزئي';
      return true;
    });

    document.getElementById('rh-row-count').textContent = `${filtered.length} / ${DATA.length}`;
    const tbody = document.getElementById('rh-tbody');
    const noRes = document.getElementById('rh-no-results');
    if (!filtered.length) { tbody.innerHTML = ''; noRes.style.display = 'block'; return; }
    noRes.style.display = 'none';

    tbody.innerHTML = filtered.map(d => `
      <tr data-id="${d.id}" class="${selectedId === d.id ? 'selected' : ''}">
        <td>${d.neighborhood}</td>
        <td><div style="display:flex;gap:3px">${segBadge(d.segments_present)}</div></td>
        <td style="font-family:'JetBrains Mono',monospace;font-size:9px">${(d.population/1000).toFixed(0)}k</td>
        <td style="font-size:9px">${d.income}</td>
        <td>${infraBadge(d.infra)}</td>
        <td>${matchBadge(d.market_match)}</td>
        <td style="display:flex;gap:3px">
          <button class="btn-act" data-pin="${d.id}">📍</button>
          <button class="btn-act edit" data-edit="${d.id}">✏️</button>
        </td>
      </tr>
    `).join('');

    tbody.querySelectorAll('tr').forEach(row => {
      row.addEventListener('click', e => {
        if (!e.target.closest('[data-pin]') && !e.target.closest('[data-edit]')) {
          const d = DATA.find(x => x.id == row.dataset.id);
          if (d) showNeighborhood(d, false);
        }
      });
    });
    tbody.querySelectorAll('[data-pin]').forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        const d = DATA.find(x => x.id == btn.dataset.pin);
        if (d) showNeighborhood(d, false);
      });
    });
    tbody.querySelectorAll('[data-edit]').forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        openEditModal(parseInt(btn.dataset.edit));
      });
    });
  }

  // ── Filters & Autocomplete ──────────────────────────────────────────────
  document.getElementById('rh-search').addEventListener('input', e => {
    searchVal = e.target.value;
    renderTable();
    const q = searchVal.trim();
    const ac = document.getElementById('rh-ac');
    if (!q) { ac.style.display = 'none'; return; }
    const hits = DATA.filter(d => d.neighborhood.includes(q)).slice(0, 8);
    if (!hits.length) { ac.style.display = 'none'; return; }
    const sectorNames = ['', 'وسط البلد', 'مناطق راقية', 'كثافة FMCG', 'لوجستي', 'ضواحي توسع'];
    ac.innerHTML = hits.map(d =>
      `<div data-ac="${d.id}" style="padding:8px 12px;cursor:pointer;font-size:12px;
        color:#e6edf3;border-bottom:1px solid #21262d;display:flex;
        justify-content:space-between;align-items:center;gap:8px;"
        onmouseover="this.style.background='#21262d'"
        onmouseout="this.style.background=''">
        <span>${d.neighborhood}</span>
        <span style="font-size:10px;color:#8b949e;white-space:nowrap;">${sectorNames[d.sector]||''}</span>
      </div>`
    ).join('');
    ac.style.display = 'block';
    ac.querySelectorAll('[data-ac]').forEach(el => {
      el.addEventListener('mousedown', ev => {
        ev.preventDefault();
        const d = DATA.find(x => x.id == el.dataset.ac);
        if (d) {
          document.getElementById('rh-search').value = d.neighborhood;
          searchVal = d.neighborhood;
          ac.style.display = 'none';
          renderTable();
          showNeighborhood(d, false);
        }
      });
    });
  });
  document.getElementById('rh-search').addEventListener('blur', () => {
    setTimeout(() => {
      const ac = document.getElementById('rh-ac');
      if (ac) ac.style.display = 'none';
    }, 150);
  });

  document.querySelectorAll('#rh-filters .fp').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('#rh-filters .fp').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      currentFilter = pill.dataset.filter;
      renderTable();
    });
  });
  document.querySelectorAll('#rh-sector-filters .sector-pill').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('#rh-sector-filters .sector-pill').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      currentSector = pill.dataset.sector;
      renderTable();
    });
  });

  // ── Edit Modal ─────────────────────────────────────────────────────────
  function openEditModal(id) {
    const d = DATA.find(x => x.id === id);
    if (!d) return;
    document.getElementById('edit-id').value = d.id;
    document.getElementById('edit-neighborhood').value = d.neighborhood;
    document.getElementById('edit-class').value = d.class;
    document.getElementById('edit-population').value = d.population;
    document.getElementById('edit-income').value = d.income;
    document.getElementById('edit-flow').value = d.flow;
    document.getElementById('edit-infra').value = d.infra;
    document.getElementById('edit-market-type').value = d.market_type;
    document.getElementById('edit-market-match').value = d.market_match;
    document.getElementById('edit-notes').value = d.notes || '';
    document.getElementById('edit-gap').value = d.gap;
    document.querySelectorAll('input[name="edit-segments"]').forEach(cb => {
      cb.checked = (d.segments_present || []).includes(cb.value);
    });
    document.getElementById('rh-modal-title').textContent = `✏️ تعديل: ${d.neighborhood}`;
    document.getElementById('rh-modal-overlay').classList.add('open');
  }

  document.getElementById('btn-modal-cancel').addEventListener('click', () => {
    document.getElementById('rh-modal-overlay').classList.remove('open');
  });
  document.getElementById('rh-modal-overlay').addEventListener('click', e => {
    if (e.target === document.getElementById('rh-modal-overlay'))
      document.getElementById('rh-modal-overlay').classList.remove('open');
  });
  document.getElementById('btn-modal-save').addEventListener('click', () => {
    const id  = parseInt(document.getElementById('edit-id').value);
    const idx = DATA.findIndex(d => d.id === id);
    if (idx === -1) return;
    const selectedSegs = Array.from(document.querySelectorAll('input[name="edit-segments"]:checked')).map(cb => cb.value);
    const updated = {
      ...DATA[idx],
      neighborhood:     document.getElementById('edit-neighborhood').value.trim(),
      class:            document.getElementById('edit-class').value,
      population:       parseInt(document.getElementById('edit-population').value) || 0,
      income:           document.getElementById('edit-income').value,
      flow:             document.getElementById('edit-flow').value,
      infra:            document.getElementById('edit-infra').value,
      market_type:      document.getElementById('edit-market-type').value,
      market_match:     document.getElementById('edit-market-match').value,
      notes:            document.getElementById('edit-notes').value,
      gap:              document.getElementById('edit-gap').value,
      segments_present: selectedSegs,
    };
    DATA[idx] = updated;
    saveToStorage(updated);
    updateStats(); renderTable(); rebuildMarkers();
    if (hexActive) renderHexLayer();
    document.getElementById('rh-modal-overlay').classList.remove('open');
    showToast(`✓ تم حفظ بيانات "${updated.neighborhood}"`, 'success');
  });

  // ── Init ──────────────────────────────────────────────────────────────
  updateStats();
  rebuildMarkers();
  renderTable();
  loadFromStorage();

})();
</script>

</DashboardLayout>
