---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="خريطة التجزئة — بنغازي 2026">

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
  /* ── Page Root ─────────────────────────────────────────────────────── */
  #rh-root {
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: calc(100vh - 60px);
    background: #0d1117;
    font-family: 'IBM Plex Sans Arabic', 'Cairo', sans-serif;
    direction: rtl;
  }

  /* ── Page title bar ──────────────────────────────────────────────── */
  #rh-page-title {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 4px 4px;
    border-bottom: 1px solid #30363d;
    margin-bottom: 4px;
  }
  #rh-page-title .pt-icon { font-size: 22px; }
  #rh-page-title .pt-text  { font-size: 16px; font-weight: 600; color: #e6edf3; }
  #rh-page-title .pt-sub   { font-size: 11px; color: #8b949e; margin-top: 2px; }

  /* ── CSS Variables ─────────────────────────────────────────────── */
  :root {
    --rh-bg-base:        #0d1117;
    --rh-bg-surface:     #161b22;
    --rh-bg-card:        #1c2128;
    --rh-bg-hover:       #21262d;
    --rh-border:         #30363d;
    --rh-border-subtle:  #21262d;
    --rh-text-primary:   #e6edf3;
    --rh-text-secondary: #8b949e;
    --rh-text-muted:     #484f58;
    --rh-accent-blue:    #2188ff;
    --rh-accent-blue-dim:#1a3d6e;
    --rh-accent-green:   #3fb950;
    --rh-accent-green-dim:#1a3a24;
    --rh-accent-orange:  #d29922;
    --rh-accent-orange-dim:#3d2e0a;
    --rh-accent-red:     #f85149;
    --rh-accent-red-dim: #3d1a1a;
    --rh-accent-purple:  #bc8cff;
    --rh-accent-purple-dim: #2d1e4a;
    --rh-radius: 8px;
    --rh-radius-sm: 5px;
  }

  /* ── Stat Cards ──────────────────────────────────────────────────── */
  #rh-stat-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
  }
  .rh-stat {
    background: var(--rh-bg-card);
    border: 1px solid var(--rh-border);
    border-radius: var(--rh-radius);
    padding: 14px 16px;
    position: relative;
    overflow: hidden;
  }
  .rh-stat::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    border-radius: 8px 0 0 8px;
  }
  .rh-stat.blue::before  { background: var(--rh-accent-blue); }
  .rh-stat.green::before { background: var(--rh-accent-green); }
  .rh-stat.orange::before{ background: var(--rh-accent-orange); }
  .rh-stat.red::before   { background: var(--rh-accent-red); }
  .rh-stat.purple::before{ background: var(--rh-accent-purple); }
  .s-label { font-size: 10px; color: var(--rh-text-muted); margin-bottom: 4px; text-transform: uppercase; letter-spacing: .5px; }
  .s-val   { font-size: 26px; font-weight: 700; color: var(--rh-text-primary); line-height: 1; }
  .rh-stat.blue   .s-val { color: var(--rh-accent-blue); }
  .rh-stat.green  .s-val { color: var(--rh-accent-green); }
  .rh-stat.orange .s-val { color: var(--rh-accent-orange); }
  .rh-stat.red    .s-val { color: var(--rh-accent-red); }
  .rh-stat.purple .s-val { color: var(--rh-accent-purple); }
  .s-sub   { font-size: 10px; color: var(--rh-text-muted); margin-top: 2px; }

  /* ── Split Layout ──────────────────────────────────────────────── */
  #rh-split {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 12px;
    flex: 1;
    min-height: 520px;
  }

  /* ── Panel Header ──────────────────────────────────────────────── */
  .ph {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    border-bottom: 1px solid var(--rh-border);
    gap: 8px;
    flex-wrap: wrap;
  }
  .ph-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--rh-text-secondary);
    letter-spacing: .4px;
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .pulse-dot {
    width: 7px; height: 7px;
    background: var(--rh-accent-green);
    border-radius: 50%;
    display: inline-block;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%,100% { opacity:1; transform:scale(1); }
    50%      { opacity:.5; transform:scale(1.3); }
  }
  .btn-hdr {
    font-size: 10px;
    padding: 4px 10px;
    border-radius: 5px;
    border: 1px solid var(--rh-border);
    background: var(--rh-bg-surface);
    color: var(--rh-text-secondary);
    cursor: pointer;
    transition: all .15s;
    font-family: inherit;
  }
  .btn-hdr:hover        { border-color: var(--rh-accent-blue); color: var(--rh-accent-blue); background: var(--rh-accent-blue-dim); }
  .btn-hdr.active-hex   { border-color: var(--rh-accent-green); color: var(--rh-accent-green); background: var(--rh-accent-green-dim); }
  .btn-hdr.danger:hover { border-color: var(--rh-accent-red); color: var(--rh-accent-red); background: var(--rh-accent-red-dim); }

  /* ── Map Panel ─────────────────────────────────────────────────── */
  #rh-map-panel {
    background: var(--rh-bg-card);
    border: 1px solid var(--rh-border);
    border-radius: var(--rh-radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  #rh-map { flex: 1; min-height: 460px; }
  .leaflet-tile { filter: brightness(0.65) saturate(0.35); }
  .leaflet-popup-content-wrapper {
    background: var(--rh-bg-card) !important; color: var(--rh-text-primary) !important;
    border: 1px solid var(--rh-border) !important; border-radius: 8px !important;
    box-shadow: 0 8px 32px rgba(0,0,0,.6) !important;
    font-family: 'IBM Plex Sans Arabic', 'Cairo', sans-serif !important; direction: rtl;
  }
  .leaflet-popup-tip { background: var(--rh-bg-card) !important; }
  .leaflet-popup-close-button { color: var(--rh-text-muted) !important; }

  /* ── Fullscreen (works inside layout) ──────────────────────────── */
  #rh-map-panel.rh-fullscreen {
    position: fixed !important; inset: 0 !important;
    z-index: 99999 !important; border-radius: 0 !important;
    width: 100vw !important; height: 100vh !important;
  }
  #rh-map-panel.rh-fullscreen #rh-map { height: calc(100vh - 44px) !important; }

  /* ── Legend ────────────────────────────────────────────────────── */
  .rh-legend {
    position: absolute;
    bottom: 24px; right: 10px;
    background: rgba(22,27,34,.9);
    border: 1px solid var(--rh-border);
    border-radius: var(--rh-radius-sm);
    padding: 8px 10px;
    font-size: 10px;
    color: var(--rh-text-secondary);
    z-index: 500;
    backdrop-filter: blur(4px);
  }
  .rh-legend.right { bottom: 24px; right: auto; left: 10px; }
  .leg-title { font-size: 9px; font-weight: 600; color: var(--rh-text-muted); margin-bottom: 5px; text-transform: uppercase; letter-spacing: .5px; }
  .leg-row   { display: flex; align-items: center; gap: 5px; margin-bottom: 3px; }
  .leg-dot   { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

  /* ── Table Panel ───────────────────────────────────────────────── */
  #rh-table-panel {
    background: var(--rh-bg-card);
    border: 1px solid var(--rh-border);
    border-radius: var(--rh-radius);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  #rh-search-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--rh-bg-surface);
    border-bottom: 1px solid var(--rh-border-subtle);
  }
  .srch-icon { font-size: 13px; color: var(--rh-text-muted); }
  #rh-search {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--rh-text-primary);
    font-size: 12px;
    font-family: inherit;
    direction: rtl;
  }
  #rh-search::placeholder { color: var(--rh-text-muted); }

  /* ── Filters ────────────────────────────────────────────────────── */
  #rh-filters, #rh-sector-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    padding: 8px 10px;
    border-bottom: 1px solid var(--rh-border-subtle);
  }
  .fp, .sector-pill {
    font-size: 10px;
    padding: 3px 9px;
    border-radius: 20px;
    border: 1px solid var(--rh-border);
    background: var(--rh-bg-surface);
    color: var(--rh-text-muted);
    cursor: pointer;
    transition: all .15s;
    font-family: inherit;
  }
  .fp.active, .sector-pill.active {
    background: var(--rh-accent-blue-dim);
    border-color: var(--rh-accent-blue);
    color: var(--rh-accent-blue);
  }

  /* ── Table ──────────────────────────────────────────────────────── */
  #rh-tscroll { flex: 1; overflow-y: auto; }
  .rh-table { width: 100%; border-collapse: collapse; font-size: 11px; }
  .rh-table th {
    background: var(--rh-bg-surface);
    color: var(--rh-text-muted);
    font-weight: 500;
    font-size: 10px;
    padding: 7px 10px;
    text-align: right;
    border-bottom: 1px solid var(--rh-border);
    position: sticky;
    top: 0;
    z-index: 1;
    letter-spacing: .3px;
  }
  .rh-table td {
    padding: 7px 10px;
    border-bottom: 1px solid var(--rh-border-subtle);
    color: var(--rh-text-primary);
    vertical-align: middle;
  }
  .rh-table tr:hover td { background: var(--rh-bg-hover); }
  .rh-table tr.rh-active td { background: var(--rh-accent-blue-dim); }

  /* ── Badges ─────────────────────────────────────────────────────── */
  .badge {
    display: inline-block;
    font-size: 9px;
    padding: 2px 6px;
    border-radius: 3px;
    font-weight: 600;
    letter-spacing: .3px;
    white-space: nowrap;
  }
  .badge-match-مطابق   { background: #1a3a24; color: #3fb950; }
  .badge-match-جزئي    { background: #3d2e0a; color: #d29922; }
  .badge-match-غير\ مطابق { background: #3d1a1a; color: #f85149; }
  .badge-infra-ممتاز   { color: #3fb950; }
  .badge-infra-جيد     { color: #2188ff; }
  .badge-infra-متوسط   { color: #d29922; }
  .badge-infra-default { color: #8b949e; }
  .badge-A { background: #3d2e0a; color: #d29922; }
  .badge-B { background: #1a3d6e; color: #2188ff; }
  .badge-C { background: #21262d; color: #8b949e; }
  .badge-D { background: #2d1e4a; color: #bc8cff; }
  .badge-AB { background: #2a2818; color: #c0a000; }
  .badge-BC { background: #1a2a3a; color: #5aa0cc; }

  /* ── Row actions ────────────────────────────────────────────────── */
  .row-actions { display: flex; gap: 4px; }
  .btn-ico {
    width: 22px; height: 22px;
    border-radius: 4px;
    border: 1px solid var(--rh-border);
    background: var(--rh-bg-surface);
    color: var(--rh-text-muted);
    cursor: pointer;
    font-size: 11px;
    display: flex; align-items: center; justify-content: center;
    transition: all .15s;
  }
  .btn-ico:hover { border-color: var(--rh-accent-blue); color: var(--rh-accent-blue); }

  /* ── Selected Info bar ──────────────────────────────────────────── */
  #rh-sel-info {
    padding: 8px 14px;
    border-top: 1px solid var(--rh-border);
    font-size: 11px;
    color: var(--rh-text-muted);
    display: flex;
    gap: 10px;
    align-items: center;
  }
  #rh-sel-name { font-weight: 600; color: var(--rh-text-secondary); }

  /* ── No results ─────────────────────────────────────────────────── */
  .rh-no-results {
    padding: 32px;
    text-align: center;
    color: var(--rh-text-muted);
    font-size: 12px;
  }

  /* ── Edit Modal ─────────────────────────────────────────────────── */
  #rh-modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,.7); z-index: 100000;
    align-items: center; justify-content: center;
    padding: 20px; overflow-y: auto;
  }
  #rh-modal-overlay.open { display: flex; }
  #rh-modal {
    background: #1c2128;
    border: 1px solid #30363d;
    border-radius: 10px;
    padding: 22px 24px;
    width: min(600px, 100%);
    max-height: 90vh;
    overflow-y: auto;
    direction: rtl;
  }
  #rh-modal h3 { font-size: 15px; font-weight: 600; color: #e6edf3; margin-bottom: 18px; }
  .modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .rh-field { display: flex; flex-direction: column; gap: 4px; }
  .rh-field label { font-size: 10px; color: #8b949e; font-weight: 500; letter-spacing: .3px; }
  .rh-field input, .rh-field select, .rh-field textarea {
    background: #161b22;
    border: 1px solid #30363d;
    border-radius: 5px;
    color: #e6edf3;
    font-size: 12px;
    padding: 7px 10px;
    font-family: inherit;
    direction: rtl;
    outline: none;
    transition: border-color .15s;
  }
  .rh-field input:focus, .rh-field select:focus, .rh-field textarea:focus { border-color: #2188ff; }
  .rh-field textarea { resize: vertical; min-height: 70px; }
  .rh-modal-actions { display: flex; gap: 10px; margin-top: 18px; justify-content: flex-end; }
  .btn-save {
    padding: 8px 20px; border-radius: 6px; font-size: 12px; font-weight: 600;
    background: #2188ff; color: #fff; border: none; cursor: pointer; font-family: inherit;
    transition: background .15s;
  }
  .btn-save:hover { background: #1a6fd4; }
  .btn-cancel {
    padding: 8px 16px; border-radius: 6px; font-size: 12px;
    background: #21262d; color: #8b949e; border: 1px solid #30363d;
    cursor: pointer; font-family: inherit;
  }

  /* ── Toast ──────────────────────────────────────────────────────── */
  #rh-toast {
    position: fixed;
    bottom: 24px; left: 50%; transform: translateX(-50%);
    z-index: 110000;
    display: flex; flex-direction: column; gap: 6px;
    align-items: center; pointer-events: none;
  }
  .toast-msg {
    padding: 9px 18px; border-radius: 7px; font-size: 12px; font-weight: 500;
    color: #e6edf3; backdrop-filter: blur(8px);
    opacity: 0; transform: translateY(8px);
    transition: all .25s; pointer-events: none;
    font-family: 'IBM Plex Sans Arabic', 'Cairo', sans-serif;
  }
  .toast-msg.show { opacity: 1; transform: translateY(0); }
  .toast-msg.success { background: rgba(14,40,20,.95); border: 1px solid #3fb950; }
  .toast-msg.error   { background: rgba(40,14,14,.95); border: 1px solid #f85149; }
  .toast-msg.info    { background: rgba(14,30,50,.95); border: 1px solid #2188ff; }

  /* ── Row count badge ────────────────────────────────────────────── */
  #rh-row-count {
    font-size: 10px;
    color: var(--rh-text-muted);
    background: var(--rh-bg-surface);
    border: 1px solid var(--rh-border);
    border-radius: 10px;
    padding: 2px 8px;
  }

  /* ── Popup styles ───────────────────────────────────────────────── */
  .rh-popup { font-size: 12px; min-width: 200px; }
  .rh-popup-title { font-size: 14px; font-weight: 700; color: #e6edf3; margin-bottom: 10px; }
  .rh-popup-row { display: flex; justify-content: space-between; gap: 12px; margin-bottom: 5px; }
  .rh-popup-key { color: #8b949e; font-size: 11px; }
  .rh-popup-val { color: #e6edf3; font-size: 11px; font-weight: 500; }
  .rh-popup-notes {
    margin-top: 8px; padding-top: 8px;
    border-top: 1px solid #30363d;
    color: #8b949e; font-size: 10px; line-height: 1.6;
  }

  /* ── Body fullscreen lock ──────────────────────────────────────────── */
  body.map-fullscreen-active { overflow: hidden; }

  /* ── Responsive ──────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    #rh-split { grid-template-columns: 1fr; }
    #rh-stat-row { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    #rh-stat-row { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<!-- ══ Root ══ -->
<div id="rh-root">

  <!-- Page Title -->
  <div id="rh-page-title">
    <span class="pt-icon">🗺️</span>
    <div>
      <div class="pt-text">لوحة التجزئة الجغرافية — بنغازي 2026</div>
      <div class="pt-sub">تحليل ديموغرافي وتجاري شامل · جميع أحياء المدينة</div>
    </div>
  </div>

  <!-- Stat Cards -->
  <div id="rh-stat-row">
    <div class="rh-stat blue">
      <div class="s-label">الأحياء المرصودة</div>
      <div class="s-val" id="stat-total">—</div>
      <div class="s-sub">حي وتجمع في بنغازي</div>
    </div>
    <div class="rh-stat green">
      <div class="s-label">تطابق كامل</div>
      <div class="s-val" id="stat-match-full">—</div>
      <div class="s-sub">أسواق تخدم السكان</div>
    </div>
    <div class="rh-stat orange">
      <div class="s-label">تطابق جزئي</div>
      <div class="s-val" id="stat-match-partial">—</div>
      <div class="s-sub">تغطية غير مكتملة</div>
    </div>
    <div class="rh-stat red">
      <div class="s-label">غير مطابق</div>
      <div class="s-val" id="stat-match-none">—</div>
      <div class="s-sub">فجوات استثمارية</div>
    </div>
    <div class="rh-stat purple">
      <div class="s-label">إجمالي السكان</div>
      <div class="s-val" id="stat-pop">—</div>
      <div class="s-sub">مليون نسمة تقريباً</div>
    </div>
  </div>

  <!-- Split -->
  <div id="rh-split">

    <!-- Map Panel -->
    <div id="rh-map-panel">
      <div class="ph">
        <div class="ph-title">
          <span class="pulse-dot"></span>
          الخريطة التفاعلية — بنغازي الكبرى
        </div>
        <div style="display:flex;gap:7px;align-items:center;">
          <button class="btn-hdr" id="btn-fullscreen">⛶ تكبير</button>
          <button class="btn-hdr" id="btn-hex-toggle">⬡ خرائط سداسية</button>
          <button class="btn-hdr danger" id="btn-reset-data">↺ إعادة ضبط</button>
        </div>
      </div>
      <div id="rh-map"></div>
      <div class="rh-legend">
        <div class="leg-title">تطابق السوق</div>
        <div class="leg-row"><div class="leg-dot" style="background:#3fb950"></div> مطابق</div>
        <div class="leg-row"><div class="leg-dot" style="background:#d29922"></div> جزئي</div>
        <div class="leg-row"><div class="leg-dot" style="background:#f85149"></div> غير مطابق</div>
      </div>
      <div class="rh-legend right">
        <div class="leg-title">الفئات</div>
        <div class="leg-row"><div class="leg-dot" style="background:#d29922"></div> A — دخل مرتفع</div>
        <div class="leg-row"><div class="leg-dot" style="background:#2188ff"></div> B — لوجستي/مختلط</div>
        <div class="leg-row"><div class="leg-dot" style="background:#8b949e"></div> C — كثافة استهلاكية</div>
        <div class="leg-row"><div class="leg-dot" style="background:#bc8cff"></div> D — ضواحي توسع</div>
      </div>
    </div>

    <!-- Table Panel -->
    <div id="rh-table-panel">
      <div class="ph">
        <div style="display:flex;justify-content:space-between;align-items:center;width:100%">
          <div class="ph-title">قائمة الأحياء</div>
          <span id="rh-row-count"></span>
        </div>
        <div id="rh-search-wrap">
          <span class="srch-icon">🔍</span>
          <input id="rh-search" type="text" placeholder="ابحث باسم الحي أو المنطقة..." />
        </div>
      </div>

      <!-- Class filters -->
      <div id="rh-filters">
        <button class="fp active" data-filter="all">الكل</button>
        <button class="fp" data-filter="A">فئة A</button>
        <button class="fp" data-filter="B">فئة B</button>
        <button class="fp" data-filter="C">فئة C</button>
        <button class="fp" data-filter="D">فئة D</button>
        <button class="fp" data-filter="none">غير مطابق</button>
        <button class="fp" data-filter="partial">جزئي</button>
      </div>

      <!-- Sector filters -->
      <div id="rh-sector-filters">
        <button class="sector-pill active" data-sector="all">كل القطاعات</button>
        <button class="sector-pill" data-sector="1">وسط البلد</button>
        <button class="sector-pill" data-sector="2">مناطق راقية</button>
        <button class="sector-pill" data-sector="3">كثافة FMCG</button>
        <button class="sector-pill" data-sector="4">لوجستي</button>
        <button class="sector-pill" data-sector="5">ضواحي</button>
      </div>

      <div id="rh-tscroll">
        <table class="rh-table">
          <thead>
            <tr>
              <th>الحي</th>
              <th>الفئة</th>
              <th>السكان</th>
              <th>الدخل</th>
              <th>البنية</th>
              <th>السوق</th>
              <th style="width:60px"></th>
            </tr>
          </thead>
          <tbody id="rh-tbody"></tbody>
        </table>
