---
// src/pages/dashboard/retail-hub.astro
// ─────────────────────────────────────────────────────────────────────────────
// صفحة خريطة التجزئة — بنغازي
// تُضاف إلى مشروع Brandzo Hub 2026 (Astro + Firebase)
// ─────────────────────────────────────────────────────────────────────────────
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="خريطة التجزئة — بنغازي">

  <!-- ══ Leaflet CSS + H3-js (CDN) ══ -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <style>
    /* ── CSS Variables (match Brandzo dark theme) ─────────────────────── */
    .rh-root {
      --bg-base:        #0d1117;
      --bg-surface:     #161b22;
      --bg-card:        #1c2128;
      --bg-hover:       #21262d;
      --border:         #30363d;
      --border-subtle:  #21262d;
      --text-primary:   #e6edf3;
      --text-secondary: #8b949e;
      --text-muted:     #484f58;
      --accent-blue:    #2188ff;
      --accent-blue-dim:#1a3d6e;
      --accent-green:   #3fb950;
      --accent-green-dim:#1a3a24;
      --accent-orange:  #d29922;
      --accent-orange-dim:#3d2e0a;
      --accent-red:     #f85149;
      --accent-red-dim: #3d1a1a;
      --radius:         8px;
      --radius-sm:      5px;
      font-family: 'IBM Plex Sans Arabic', 'Cairo', sans-serif;
    }

    /* ── Layout ───────────────────────────────────────────────────────── */
    .rh-root {
      display: flex;
      flex-direction: column;
      gap: 16px;
      height: calc(100vh - 80px); /* compensate for Brandzo's top nav */
      overflow: hidden;
      padding: 20px 24px 16px;
      background: var(--bg-base);
      color: var(--text-primary);
      direction: rtl;
    }

    /* ── Stat Cards ───────────────────────────────────────────────────── */
    #rh-stat-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      flex-shrink: 0;
    }
    .rh-stat {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 16px 18px;
      display: flex; flex-direction: column; gap: 6px;
      position: relative; overflow: hidden; transition: border-color .2s;
    }
    .rh-stat::before {
      content: ''; position: absolute; top: 0; right: 0;
      width: 3px; height: 100%;
      border-radius: 0 var(--radius) var(--radius) 0;
    }
    .rh-stat.blue::before  { background: var(--accent-blue); }
    .rh-stat.green::before { background: var(--accent-green); }
    .rh-stat.red::before   { background: var(--accent-red); }
    .rh-stat.orange::before{ background: var(--accent-orange); }
    .rh-stat:hover         { border-color: var(--accent-blue); }
    .rh-stat .s-label { font-size:11px; color:var(--text-secondary); text-transform:uppercase; letter-spacing:.5px; font-weight:500; }
    .rh-stat .s-val   { font-size:28px; font-weight:700; font-family:'JetBrains Mono',monospace; line-height:1; }
    .rh-stat.blue   .s-val { color:var(--accent-blue); }
    .rh-stat.green  .s-val { color:var(--accent-green); }
    .rh-stat.red    .s-val { color:var(--accent-red); }
    .rh-stat.orange .s-val { color:var(--accent-orange); }
    .rh-stat .s-sub { font-size:11px; color:var(--text-muted); }

    /* ── Content Split ────────────────────────────────────────────────── */
    #rh-split {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr 440px;
      gap: 14px;
      overflow: hidden;
      min-height: 0;
    }

    /* ── Map Panel ────────────────────────────────────────────────────── */
    #rh-map-panel {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); overflow: hidden; position: relative;
      display: flex; flex-direction: column;
    }
    #rh-map-panel .ph {
      padding: 10px 16px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      flex-shrink: 0; background: var(--bg-surface); gap: 10px;
    }
    .ph-title { font-size:13px; font-weight:600; color:var(--text-primary); display:flex; align-items:center; gap:8px; }
    .pulse-dot { width:7px; height:7px; border-radius:50%; background:var(--accent-green); animation:rhPulse 2s infinite; }
    @keyframes rhPulse { 0%,100%{opacity:1} 50%{opacity:.4} }
    #rh-map { flex: 1; min-height: 0; }
    .rh-legend {
      position: absolute; bottom: 12px; left: 12px;
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 10px 14px;
      z-index: 1000; font-size: 11px;
    }
    .rh-legend.segments {
      left: auto; right: 12px;
    }
    .leg-title { color:var(--text-muted); font-size:10px; text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px; }
    .leg-row   { display:flex; align-items:center; gap:7px; color:var(--text-secondary); padding:2px 0; }
    .leg-dot   { width:9px; height:9px; border-radius:50%; flex-shrink:0; }

    /* ── Table Panel ──────────────────────────────────────────────────── */
    #rh-table-panel {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); display: flex; flex-direction: column;
      overflow: hidden;
    }
    #rh-table-panel .ph {
      padding: 10px 14px; border-bottom: 1px solid var(--border);
      flex-shrink: 0; background: var(--bg-surface);
      display: flex; flex-direction: column; gap: 8px;
    }
    #rh-search-wrap { position: relative; }
    #rh-search {
      width: 100%; background: var(--bg-base); border: 1px solid var(--border);
      border-radius: var(--radius-sm); color: var(--text-primary);
      font-family: 'IBM Plex Sans Arabic','Cairo',sans-serif; font-size: 12px;
      padding: 7px 32px 7px 10px; outline: none; transition: border-color .15s; direction: rtl;
    }
    #rh-search::placeholder { color: var(--text-muted); }
    #rh-search:focus        { border-color: var(--accent-blue); }
    .rh-search-icon { position:absolute; left:9px; top:50%; transform:translateY(-50%); color:var(--text-muted); font-size:13px; pointer-events:none; }

    #rh-filters { display:flex; gap:6px; flex-wrap:wrap; padding:6px 14px; border-bottom:1px solid var(--border-subtle); flex-shrink:0; }
    .fp {
      font-size:11px; padding:4px 10px; border-radius:20px;
      border:1px solid var(--border); background:transparent;
      color:var(--text-secondary); cursor:pointer;
      font-family:'IBM Plex Sans Arabic','Cairo',sans-serif; transition:all .15s;
    }
    .fp.active    { border-color:var(--accent-blue); background:var(--accent-blue-dim); color:var(--accent-blue); }
    .fp:hover:not(.active) { border-color:var(--text-muted); color:var(--text-primary); }

    #rh-tscroll { flex:1; overflow-y:auto; overflow-x:hidden; scrollbar-width:thin; scrollbar-color:var(--border) transparent; }
    #rh-tscroll::-webkit-scrollbar       { width:5px; }
    #rh-tscroll::-webkit-scrollbar-thumb { background:var(--border); border-radius:10px; }

    table.rh-table { width:100%; border-collapse:collapse; font-size:12px; }
    .rh-table thead th {
      padding:9px 7px; text-align:right; color:var(--text-muted);
      font-weight:500; font-size:10px; text-transform:uppercase; letter-spacing:.4px;
      border-bottom:1px solid var(--border); position:sticky; top:0;
      background:var(--bg-card); z-index:2;
    }
    .rh-table tbody tr  { border-bottom:1px solid var(--border-subtle); cursor:pointer; transition:background .1s; }
    .rh-table tbody tr:hover    { background:var(--bg-hover); }
    .rh-table tbody tr.selected { background:var(--accent-blue-dim); }
    .rh-table tbody td { padding:7px 7px; color:var(--text-secondary); white-space:nowrap; }
    .rh-table tbody td:first-child { color:var(--text-primary); font-weight:500; }

    /* Badges */
    .badge { display:inline-flex; align-items:center; gap:3px; padding:2px 7px; border-radius:20px; font-size:10px; font-weight:600; white-space:nowrap; }
    .badge-A   { background:#3d2e0a; color:#d29922; border:1px solid #d2992244; } /* Gold/Amber */
    .badge-B   { background:var(--accent-blue-dim); color:var(--accent-blue); border:1px solid #2188ff44; } /* Blue */
    .badge-C   { background:#21262d; color:#8b949e; border:1px solid var(--border); } /* Gray */

    .badge-match-yes  { background:var(--accent-green-dim); color:var(--accent-green); border:1px solid #3fb95044; }
    .badge-match-part { background:var(--accent-orange-dim); color:var(--accent-orange); border:1px solid #d2992244; }
    .badge-match-no   { background:var(--accent-red-dim); color:var(--accent-red); border:1px solid #f8514944; }

    /* Action buttons in rows */
    .btn-act {
      background:transparent; border:1px solid var(--border);
      color:var(--text-secondary); font-size:10px; padding:3px 7px;
      border-radius:var(--radius-sm); cursor:pointer; transition:all .15s; white-space:nowrap;
    }
    .btn-act:hover              { border-color:var(--accent-blue); color:var(--accent-blue); background:var(--accent-blue-dim); }
    .btn-act.edit:hover         { border-color:var(--accent-orange); color:var(--accent-orange); background:var(--accent-orange-dim); }

    /* ── Fullscreen map mode ─────────────────────────────────────────────── */
    #rh-map-panel.rh-fullscreen {
      position: fixed !important;
      inset: 0 !important;
      z-index: 5000 !important;
      border-radius: 0 !important;
      width: 100vw !important;
      height: 100vh !important;
      margin: 0 !important;
    }
    #rh-map-panel.rh-fullscreen #rh-map {
      height: calc(100vh - 44px) !important;
    }
    body.map-fullscreen-active {
      overflow: hidden;
    }

    #rh-sel-info {
      padding:9px 14px; border-top:1px solid var(--border);
      background:var(--bg-surface); display:flex;
      justify-content:space-between; align-items:center;
      font-size:11px; color:var(--text-muted); flex-shrink:0;
    }
    .rh-no-results { text-align:center; padding:40px 20px; color:var(--text-muted); font-size:13px; }

    /* ── Map tile darkening ───────────────────────────────────────────── */
    .leaflet-tile { filter:brightness(0.7) saturate(0.4); }
    .leaflet-popup-content-wrapper {
      background:var(--bg-card) !important; color:var(--text-primary) !important;
      border:1px solid var(--border) !important; border-radius:8px !important;
      box-shadow:0 8px 32px rgba(0,0,0,.6) !important;
      font-family:'IBM Plex Sans Arabic','Cairo',sans-serif !important; direction:rtl;
    }
    .leaflet-popup-tip        { background:var(--bg-card) !important; }
    .leaflet-popup-close-button { color:var(--text-muted) !important; }
    .popup-title  { font-weight:700; font-size:14px; margin-bottom:10px; color:var(--accent-blue); border-bottom:1px solid var(--border); padding-bottom:8px; }
    .popup-row    { display:flex; justify-content:space-between; align-items:center; gap:16px; padding:4px 0; font-size:12px; }
    .pk { color:var(--text-muted); }
    .pv { color:var(--text-primary); font-weight:500; }

    /* ── Header action buttons ────────────────────────────────────────── */
    .btn-hdr {
      display:flex; align-items:center; gap:5px;
      padding:5px 12px; border-radius:var(--radius-sm);
      border:1px solid var(--border); background:var(--bg-card);
      color:var(--text-secondary);
      font-family:'IBM Plex Sans Arabic','Cairo',sans-serif;
      font-size:11px; cursor:pointer; transition:all .2s; white-space:nowrap;
    }
    .btn-hdr:hover           { border-color:var(--accent-blue); color:var(--accent-blue); background:var(--accent-blue-dim); }
    .btn-hdr.active-hex      { border-color:var(--accent-green); color:var(--accent-green); background:var(--accent-green-dim); }
    .btn-hdr.danger:hover    { border-color:var(--accent-red); color:var(--accent-red); background:var(--accent-red-dim); }

    /* ── Edit Modal ───────────────────────────────────────────────────── */
    #rh-modal-overlay {
      display: none;
      position: fixed; inset: 0;
      background: rgba(0,0,0,.65); z-index: 9000;
      align-items: center; justify-content: center;
      padding: 20px; overflow-y: auto;
    }
    #rh-modal-overlay.open { display: flex; }
    #rh-modal {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 24px 28px; width: 460px;
      max-width: 95vw; max-height: 90vh; overflow-y: auto;
      direction: rtl; box-shadow: 0 20px 60px rgba(0,0,0,.8);
    }
    #rh-modal h3 { font-size:15px; font-weight:700; color:var(--text-primary); margin-bottom:18px; border-bottom:1px solid var(--border); padding-bottom:12px; }
    .rh-field { display:flex; flex-direction:column; gap:5px; margin-bottom:14px; }
    .rh-field label { font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:.4px; }
    .rh-field input, .rh-field select {
      background:var(--bg-base); border:1px solid var(--border);
      border-radius:var(--radius-sm); color:var(--text-primary);
      font-family:'IBM Plex Sans Arabic','Cairo',sans-serif;
      font-size:13px; padding:8px 10px; outline:none; transition:border-color .15s;
    }
    .rh-field input:focus, .rh-field select:focus { border-color:var(--accent-blue); }
    .rh-field select option { background:var(--bg-card); }
    .rh-modal-actions { display:flex; gap:10px; justify-content:flex-start; margin-top:18px; }
    .btn-save   { padding:8px 22px; border-radius:var(--radius-sm); border:none; background:var(--accent-blue); color:#fff; font-size:13px; cursor:pointer; font-family:'IBM Plex Sans Arabic','Cairo',sans-serif; font-weight:600; transition:opacity .2s; }
    .btn-save:hover   { opacity:.85; }
    .btn-cancel { padding:8px 16px; border-radius:var(--radius-sm); border:1px solid var(--border); background:transparent; color:var(--text-secondary); font-size:13px; cursor:pointer; font-family:'IBM Plex Sans Arabic','Cairo',sans-serif; transition:all .15s; }
    .btn-cancel:hover { border-color:var(--text-muted); color:var(--text-primary); }

    /* ── Toast ────────────────────────────────────────────────────────── */
    #rh-toast {
      position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(20px);
      background: var(--bg-surface); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 10px 20px;
      font-size: 12px; color: var(--text-primary); z-index: 9999;
      opacity: 0; transition: opacity .3s, transform .3s; pointer-events: none;
      white-space: nowrap;
    }
    #rh-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    #rh-toast.error { border-color: var(--accent-red); color: var(--accent-red); }
    #rh-toast.success { border-color: var(--accent-green); color: var(--accent-green); }

    /* ── Responsive ───────────────────────────────────────────────────── */
    @media (max-width: 900px) {
      #rh-split { grid-template-columns: 1fr; grid-template-rows: 340px 1fr; }
      #rh-stat-row { grid-template-columns: repeat(2,1fr); }
      .rh-root { height: auto; overflow: visible; }
    }
  </style>

  <!-- ══ Page Root ══ -->
  <div class="rh-root" dir="rtl">

    <!-- Stat Cards -->
    <div id="rh-stat-row">
      <div class="rh-stat blue">
        <div class="s-label">المناطق المرصودة</div>
        <div class="s-val">20</div>
        <div class="s-sub">أحياء بنغازي الكبرى</div>
      </div>
      <div class="rh-stat green">
        <div class="s-label">تطابق كامل</div>
        <div class="s-val" id="rh-match-full">—</div>
        <div class="s-sub">الأسواق تخدم كافة السكان</div>
      </div>
      <div class="rh-stat orange">
        <div class="s-label">تطابق جزئي</div>
        <div class="s-val" id="rh-match-partial">—</div>
        <div class="s-sub">الأسواق تخدم بعض الفئات</div>
      </div>
      <div class="rh-stat red">
        <div class="s-label">غير مطابق</div>
        <div class="s-val" id="rh-match-none">—</div>
        <div class="s-sub">الأسواق لا تخدم السكان</div>
      </div>
    </div>

    <!-- Split: Map | Table -->
    <div id="rh-split">

      <!-- Map Panel -->
      <div id="rh-map-panel">
        <div class="ph">
          <div class="ph-title">
            <span class="pulse-dot"></span>
            الخريطة التفاعلية — بنغازي
          </div>
          <div style="display:flex;gap:8px;align-items:center;">
            <button class="btn-hdr" id="btn-fullscreen" title="تكبير الخريطة">
              ⛶ تكبير
            </button>
            <!-- Toggle hex view -->
            <button class="btn-hdr" id="btn-hex-toggle" title="تبديل عرض الخرائط السداسية">
              ⬡ خرائط سداسية
            </button>
            <!-- Reset data -->
            <button class="btn-hdr danger" id="btn-reset-data" title="إعادة تعيين البيانات للافتراضي">
              ↺ إعادة ضبط
            </button>
          </div>
        </div>
        <div id="rh-map"></div>
        <div class="rh-legend">
          <div class="leg-title">تطابق السوق</div>
          <div class="leg-row"><div class="leg-dot" style="background:#3fb950"></div> مطابق</div>
          <div class="leg-row"><div class="leg-dot" style="background:#d29922"></div> جزئي</div>
          <div class="leg-row"><div class="leg-dot" style="background:#f85149"></div> غير مطابق</div>
        </div>
        <div class="rh-legend segments">
          <div class="leg-title">الفئات السكانية</div>
          <div class="leg-row"><div class="leg-dot" style="background:#d29922"></div> فئة A (دخل عالٍ)</div>
          <div class="leg-row"><div class="leg-dot" style="background:#2188ff"></div> فئة B (متوسط)</div>
          <div class="leg-row"><div class="leg-dot" style="background:#8b949e"></div> فئة C (محدود)</div>
        </div>
      </div>

      <!-- Table Panel -->
      <div id="rh-table-panel">
        <div class="ph">
          <div class="ph-title">قائمة الأحياء</div>
          <div id="rh-search-wrap">
            <span class="rh-search-icon">🔍</span>
            <input id="rh-search" type="text" placeholder="ابحث باسم الحي..." />
          </div>
        </div>
        <div id="rh-filters">
          <button class="fp active" data-filter="all">الكل</button>
          <button class="fp" data-filter="A">فئة A</button>
          <button class="fp" data-filter="B">فئة B</button>
          <button class="fp" data-filter="C">فئة C</button>
          <button class="fp" data-filter="none">غير مطابق</button>
          <button class="fp" data-filter="partial">جزئي</button>
        </div>
        <div id="rh-tscroll">
          <table class="rh-table">
            <thead>
              <tr>
                <th>الحي</th>
                <th>الفئات السكانية</th>
                <th>السكان</th>
                <th>التدفق</th>
                <th>تطابق السوق</th>
                <th style="width:70px"></th>
              </tr>
            </thead>
            <tbody id="rh-tbody"></tbody>
          </table>
          <div id="rh-no-results" class="rh-no-results" style="display:none">لا توجد نتائج</div>
        </div>
        <div id="rh-sel-info">
          <span id="rh-sel-name">لم يتم تحديد أي حي</span>
          <span id="rh-row-count"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ Edit Modal ══ -->
  <div id="rh-modal-overlay">
    <div id="rh-modal">
      <h3 id="rh-modal-title">✏️ تعديل بيانات الحي</h3>
      <input type="hidden" id="edit-id" />
      <div class="rh-field">
        <label>اسم الحي</label>
        <input id="edit-neighborhood" type="text" />
      </div>
      <div class="rh-field">
        <label>الفئة التجارية</label>
        <select id="edit-class">
          <option value="A">A</option>
          <option value="A-B">A-B</option>
          <option value="B">B</option>
          <option value="B-C">B-C</option>
          <option value="C">C</option>
        </select>
      </div>
      <div class="rh-field">
        <label>عدد السكان</label>
        <input id="edit-population" type="number" min="0" />
      </div>
      <div class="rh-field">
        <label>السوق الأول</label>
        <input id="edit-market1" type="text" />
      </div>
      <div class="rh-field">
        <label>السوق الثاني</label>
        <input id="edit-market2" type="text" />
      </div>
      <div class="rh-field">
        <label>التدفق التجاري</label>
        <select id="edit-flow">
          <option value="عالٍ جداً">عالٍ جداً</option>
          <option value="عالٍ">عالٍ</option>
          <option value="متوسط">متوسط</option>
          <option value="منخفض">منخفض</option>
          <option value="منخفض جداً">منخفض جداً</option>
        </select>
      </div>
      <div class="rh-field">
        <label>سهولة الوصول</label>
        <select id="edit-accessibility">
          <option value="ممتاز">ممتاز</option>
          <option value="جيد">جيد</option>
          <option value="متوسط">متوسط</option>
          <option value="ضعيف">ضعيف</option>
        </select>
      </div>
      <div class="rh-field">
        <label>الفئات السكانية الموجودة</label>
        <div style="display:flex; gap:15px; padding:5px 0;">
          <label style="display:flex; align-items:center; gap:5px; color:var(--text-primary); cursor:pointer; font-size:12px;">
            <input type="checkbox" name="edit-segments" value="A" /> A (دخل عالٍ)
          </label>
          <label style="display:flex; align-items:center; gap:5px; color:var(--text-primary); cursor:pointer; font-size:12px;">
            <input type="checkbox" name="edit-segments" value="B" /> B (متوسط)
          </label>
          <label style="display:flex; align-items:center; gap:5px; color:var(--text-primary); cursor:pointer; font-size:12px;">
            <input type="checkbox" name="edit-segments" value="C" /> C (محدود)
          </label>
        </div>
      </div>
      <div class="rh-field">
        <label>نوع السوق</label>
        <select id="edit-market-type">
          <option value="جملة">جملة</option>
          <option value="تجزئة">تجزئة</option>
          <option value="مول">مول</option>
          <option value="شعبي">شعبي</option>
          <option value="مختلط">مختلط</option>
          <option value="لا يوجد">لا يوجد</option>
        </select>
      </div>
      <div class="rh-field">
        <label>تطابق السوق</label>
        <select id="edit-market-match">
          <option value="مطابق">مطابق</option>
          <option value="جزئي">جزئي</option>
          <option value="غير مطابق">غير مطابق</option>
        </select>
      </div>
      <div class="rh-field">
        <label>الفجوة الاستثمارية</label>
        <select id="edit-gap">
          <option value="لا">لا</option>
          <option value="جزئياً ⚠">جزئياً ⚠</option>
          <option value="نعم ⚠">نعم ⚠</option>
          <option value="نعم ⚠⚠">نعم ⚠⚠</option>
        </select>
      </div>
      <div class="rh-modal-actions">
        <button class="btn-save" id="btn-modal-save">💾 حفظ</button>
        <button class="btn-cancel" id="btn-modal-cancel">إلغاء</button>
      </div>
    </div>
  </div>

  <!-- ══ Toast notification ══ -->
  <div id="rh-toast"></div>

  <!-- ══ Scripts (CDN + inline logic) ══ -->
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline src="https://unpkg.com/h3-js@4/dist/h3-js.umd.js"></script>

  <script is:inline>
  (function () {
    'use strict';

    // ── 1. Default DATA (20 Benghazi neighborhoods) ──────────────────────────
    const DEFAULT_DATA = [
      {"id":1,"neighborhood":"الفويهات","lat":32.118,"lng":20.082,"class":"A","population":35000,"market1":"جيان فنيتشيا","market2":"سوبر ماركت الفويهات","flow":"عالٍ","accessibility":"ممتاز","gap":"لا","segments_present":["A","B"],"market_match":"مطابق","market_type":"مختلط"},
      {"id":2,"neighborhood":"السلماني","lat":32.115,"lng":20.088,"class":"A","population":42000,"market1":"مجمع السلماني","market2":"القاصد الكريم","flow":"عالٍ","accessibility":"ممتاز","gap":"لا","segments_present":["A","B"],"market_match":"مطابق","market_type":"مختلط"},
      {"id":3,"neighborhood":"الكويفية","lat":32.130,"lng":20.062,"class":"A-B","population":20000,"market1":"جيان فنيتشيا","market2":"داون تاون","flow":"متوسط","accessibility":"جيد","gap":"لا","segments_present":["A","B"],"market_match":"جزئي","market_type":"تجزئة"},
      {"id":4,"neighborhood":"الرجمة","lat":32.125,"lng":20.185,"class":"A-B","population":18000,"market1":"باراسي","market2":"-","flow":"منخفض","accessibility":"جيد","gap":"جزئياً ⚠","segments_present":["A","B"],"market_match":"جزئي","market_type":"تجزئة"},
      {"id":5,"neighborhood":"الكيش","lat":32.108,"lng":20.095,"class":"B","population":55000,"market1":"الحور","market2":"سالاتي","flow":"عالٍ جداً","accessibility":"جيد","gap":"جزئياً ⚠","segments_present":["B","C"],"market_match":"جزئي","market_type":"شعبي"},
      {"id":6,"neighborhood":"الهواري","lat":32.100,"lng":20.118,"class":"B","population":48000,"market1":"الحور","market2":"الزاد","flow":"عالٍ جداً","accessibility":"جيد","gap":"لا","segments_present":["B","C"],"market_match":"مطابق","market_type":"شعبي"},
      {"id":7,"neighborhood":"الليثي","lat":32.095,"lng":20.122,"class":"B","population":52000,"market1":"الزاد","market2":"الحور","flow":"عالٍ","accessibility":"جيد","gap":"لا","segments_present":["B","C"],"market_match":"مطابق","market_type":"شعبي"},
      {"id":8,"neighborhood":"قاريونس","lat":32.060,"lng":20.060,"class":"B","population":60000,"market1":"جيان المطار","market2":"جيان قاريونس","flow":"عالٍ جداً","accessibility":"ممتاز","gap":"لا","segments_present":["A","B","C"],"market_match":"مطابق","market_type":"مختلط"},
      {"id":9,"neighborhood":"الصابري","lat":32.112,"lng":20.100,"class":"B","population":40000,"market1":"مجمع السلماني","market2":"الماهري","flow":"عالٍ","accessibility":"ممتاز","gap":"لا","segments_present":["B","C"],"market_match":"مطابق","market_type":"شعبي"},
      {"id":10,"neighborhood":"بوهديمة","lat":32.098,"lng":20.138,"class":"B","population":32000,"market1":"الزاد","market2":"-","flow":"متوسط","accessibility":"جيد","gap":"لا","segments_present":["C"],"market_match":"جزئي","market_type":"تجزئة"},
      {"id":11,"neighborhood":"الرويسات","lat":32.105,"lng":20.148,"class":"B","population":36000,"market1":"مجمع بدزيرة","market2":"جيان المطار","flow":"متوسط","accessibility":"جيد","gap":"لا","segments_present":["B","C"],"market_match":"جزئي","market_type":"تجزئة"},
      {"id":12,"neighborhood":"بنينة","lat":32.096,"lng":20.269,"class":"B","population":25000,"market1":"جيان المطار","market2":"جيان إكسبريس","flow":"متوسط","accessibility":"جيد","gap":"لا","segments_present":["B","C"],"market_match":"مطابق","market_type":"تجزئة"},
      {"id":13,"neighborhood":"القوارشة","lat":32.038,"lng":20.078,"class":"B-C","population":28000,"market1":"مجمع الناجح","market2":"-","flow":"منخفض","accessibility":"متوسط","gap":"نعم ⚠","segments_present":["C"],"market_match":"غير مطابق","market_type":"شعبي"},
      {"id":14,"neighborhood":"سيدي فرج","lat":32.105,"lng":20.048,"class":"C","population":45000,"market1":"جيان فنيتشيا (بعيد)","market2":"-","flow":"منخفض جداً","accessibility":"ضعيف","gap":"نعم ⚠⚠","segments_present":["C"],"market_match":"غير مطابق","market_type":"لا يوجد"},
      {"id":15,"neighborhood":"المهيشي","lat":32.092,"lng":20.092,"class":"C","population":50000,"market1":"الحور 2","market2":"ليبيا مول","flow":"متوسط","accessibility":"جيد","gap":"جزئياً ⚠","segments_present":["B","C"],"market_match":"جزئي","market_type":"شعبي"},
      {"id":16,"neighborhood":"بوصنيب","lat":32.080,"lng":20.082,"class":"C","population":35000,"market1":"الحور 2","market2":"باراسي","flow":"منخفض","accessibility":"متوسط","gap":"نعم ⚠⚠","segments_present":["C"],"market_match":"غير مطابق","market_type":"شعبي"},
      {"id":17,"neighborhood":"بوعطني","lat":32.098,"lng":20.158,"class":"C","population":22000,"market1":"محلات محلية","market2":"-","flow":"منخفض جداً","accessibility":"ضعيف","gap":"نعم ⚠⚠","segments_present":["C"],"market_match":"غير مطابق","market_type":"لا يوجد"},
      {"id":18,"neighborhood":"قنفودة","lat":32.028,"lng":20.022,"class":"C","population":30000,"market1":"باراسي","market2":"-","flow":"منخفض","accessibility":"متوسط","gap":"نعم ⚠","segments_present":["C"],"market_match":"غير مطابق","market_type":"لا يوجد"},
      {"id":19,"neighborhood":"شبنة","lat":32.022,"lng":20.068,"class":"C","population":20000,"market1":"مجمع الناجح","market2":"-","flow":"منخفض","accessibility":"ضعيف","gap":"نعم ⚠⚠","segments_present":["C"],"market_match":"غير مطابق","market_type":"لا يوجد"},
      {"id":20,"neighborhood":"الطلحية","lat":32.082,"lng":20.188,"class":"B","population":14000,"market1":"جيان المطار","market2":"-","flow":"منخفض","accessibility":"متوسط","gap":"جزئياً ⚠","segments_present":["B","C"],"market_match":"جزئي","market_type":"تجزئة"}
    ];

    // Live working copy (may be overridden by localStorage on load)
    let DATA = DEFAULT_DATA.map(d => ({ ...d }));

    // ── Helper: toast notification ────────────────────────────────────────────
    function showToast(msg, type = '') {
      const t = document.getElementById('rh-toast');
      t.textContent = msg;
      t.className = 'show' + (type ? ' ' + type : '');
      setTimeout(() => { t.className = ''; }, 3000);
    }

    // ── 3. Load/Save data with localStorage ──────────────────────────────────

    // Load saved edits from localStorage (non-blocking, merges over defaults)
    function loadFromStorage() {
      try {
        const saved = localStorage.getItem('brandzo_retail_hub_v2');
        if (!saved) return;
        const overrides = JSON.parse(saved); // array of edited records
        overrides.forEach(override => {
          const idx = DATA.findIndex(d => d.id === override.id);
          if (idx !== -1) DATA[idx] = { ...DATA[idx], ...override };
        });
        updateStats();
        renderTable();
        addMarkersToMap();
      } catch (e) {
        console.warn('[RetailHub] localStorage load failed:', e);
      }
    }

    // Save all current DATA overrides to localStorage
    function saveToStorage(updatedRecord) {
      try {
        // Read existing overrides
        let overrides = [];
        const existing = localStorage.getItem('brandzo_retail_hub_v2');
        if (existing) overrides = JSON.parse(existing);

        // Upsert this record
        const idx = overrides.findIndex(o => o.id === updatedRecord.id);
        if (idx !== -1) overrides[idx] = updatedRecord;
        else overrides.push(updatedRecord);

        localStorage.setItem('brandzo_retail_hub_v2', JSON.stringify(overrides));
      } catch (e) {
        console.warn('[RetailHub] localStorage save failed:', e);
        showToast('❌ فشل الحفظ المحلي', 'error');
      }
    }

    async function resetToDefaults() {
      DATA = DEFAULT_DATA.map(d => ({ ...d }));
      try {
        localStorage.removeItem('brandzo_retail_hub_v2');
      } catch (e) { /* ignore */ }
      updateStats();
      renderTable();
      addMarkersToMap();
      if (hexActive) renderHexLayer();
      showToast('✓ تمت إعادة ضبط البيانات للافتراضي', 'success');
    }

    // ── 4. Stats ──────────────────────────────────────────────────────────────
    function updateStats() {
      const fullCnt    = DATA.filter(d => d.market_match === 'مطابق').length;
      const partialCnt = DATA.filter(d => d.market_match === 'جزئي').length;
      const noneCnt    = DATA.filter(d => d.market_match === 'غير مطابق').length;

      document.getElementById('rh-match-full').textContent    = fullCnt;
      document.getElementById('rh-match-partial').textContent = partialCnt;
      document.getElementById('rh-match-none').textContent    = noneCnt;
    }

    // ── 5. Map setup ──────────────────────────────────────────────────────────
    const rhMap = L.map('rh-map', { zoomControl: false }).setView([32.085, 20.12], 11);
    L.control.zoom({ position: 'topleft' }).addTo(rhMap);

    // ── Fullscreen map toggle ─────────────────────────────────────────────
    let mapFullscreen = false;
    document.getElementById('btn-fullscreen').addEventListener('click', () => {
      const panel = document.getElementById('rh-map-panel');
      mapFullscreen = !mapFullscreen;
      const btn = document.getElementById('btn-fullscreen');
      if (mapFullscreen) {
        panel.classList.add('rh-fullscreen');
        document.body.classList.add('map-fullscreen-active');
        btn.textContent = '✕ تصغير';
        btn.classList.add('active-hex'); // reuse existing highlight style
        // Leaflet needs invalidateSize after container resize
        setTimeout(() => rhMap.invalidateSize(), 50);
      } else {
        panel.classList.remove('rh-fullscreen');
        document.body.classList.remove('map-fullscreen-active');
        btn.textContent = '⛶ تكبير';
        btn.classList.remove('active-hex');
        setTimeout(() => rhMap.invalidateSize(), 50);
      }
    });

    // Close fullscreen on Escape key
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && mapFullscreen) {
        document.getElementById('btn-fullscreen').click();
      }
    });
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap', maxZoom: 18
    }).addTo(rhMap);

    function gapColor(match) {
      if (match === 'غير مطابق') return '#f85149';
      if (match === 'جزئي')      return '#d29922';
      return '#3fb950';
    }

    const markerLayer = L.layerGroup().addTo(rhMap);
    const markers = {};
    let selectedId = null;

    // FIX 1: Initial markers and stats call after map ready
    rhMap.whenReady(() => {
      addMarkersToMap();
      updateStats();
    });

    function buildPopup(d) {
      const m2 = d.market2 && d.market2 !== '-' ? d.market2 : '—';
      const segBadges = (d.segments_present || []).map(s => {
        const cls = s === 'A' ? 'badge-A' : (s === 'B' ? 'badge-B' : 'badge-C');
        return `<span class="badge ${cls}">${s}</span>`;
      }).join(' ');

      return `<div style="min-width:200px;padding:2px">
        <div class="popup-title">📍 ${d.neighborhood}</div>
        <div class="popup-row"><span class="pk">الفئات السكانية</span><span class="pv">${segBadges}</span></div>
        <div class="popup-row"><span class="pk">نوع السوق</span><span class="pv">${d.market_type || '—'}</span></div>
        <div class="popup-row"><span class="pk">تطابق السوق</span><span class="pv" style="color:${gapColor(d.market_match)}">${d.market_match || '—'}</span></div>
        <div class="popup-row" style="margin:6px 0;border-top:1px solid #30363d"></div>
        <div class="popup-row"><span class="pk">السوق 1</span><span class="pv">${d.market1}</span></div>
        <div class="popup-row"><span class="pk">السوق 2</span><span class="pv">${m2}</span></div>
        <div class="popup-row"><span class="pk">سهولة الوصول</span><span class="pv">${d.accessibility}</span></div>
      </div>`;
    }

    function addMarkersToMap() {
      markerLayer.clearLayers();
      DATA.forEach(d => {
        const color = gapColor(d.market_match);
        const icon = L.divIcon({
          className: '',
          html: `<div style="width:14px;height:14px;background:${color};border:2px solid rgba(255,255,255,0.25);border-radius:50%;box-shadow:0 0 6px ${color}88;cursor:pointer;"></div>`,
          iconSize: [14, 14], iconAnchor: [7, 7]
        });
        const marker = L.marker([d.lat, d.lng], { icon });
        marker.on('click', () => showNeighborhood(d, true));
        marker.bindPopup(buildPopup(d), { maxWidth: 260 });
        markers[d.id] = marker;
        if (!hexActive) markerLayer.addLayer(marker);
      });
    }

    function showNeighborhood(d, fromMap = false) {
      selectedId = d.id;
      document.querySelectorAll('#rh-tbody tr').forEach(r => r.classList.toggle('selected', r.dataset.id == d.id));
      const row = document.querySelector(`#rh-tbody tr[data-id="${d.id}"]`);
      if (row) row.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      document.getElementById('rh-sel-name').innerHTML =
        `<span style="color:var(--text-primary);font-weight:600">${d.neighborhood}</span> · ${d.class} · ${d.population.toLocaleString('ar-EG')} ساكن`;
      if (!fromMap) rhMap.setView([d.lat, d.lng], 14, { animate: true, duration: 0.8 });
      if (markers[d.id]) markers[d.id].openPopup();
    }

    // ── 6. Hexagonal Layer ────────────────────────────────────────────────────
    let hexActive = false;
    let hexLayer = null;
    const h3Res = 8; // resolution 8 ≈ ~0.7 km² hexagons

    function renderHexLayer() {
      if (hexLayer) { rhMap.removeLayer(hexLayer); hexLayer = null; }

      // Check H3 is available
      if (typeof h3 === 'undefined') {
        showToast('تعذّر تحميل مكتبة الخرائط السداسية', 'error');
        hexActive = false;
        document.getElementById('btn-hex-toggle').classList.remove('active-hex');
        document.getElementById('btn-hex-toggle').textContent = '⬡ خرائط سداسية';
        markerLayer.addTo(rhMap);
        return;
      }

      const features = DATA.map(d => {
        const hexIndex  = h3.latLngToCell(d.lat, d.lng, h3Res);
        const boundary  = h3.cellToBoundary(hexIndex); // [[lat,lng],...]
        // GeoJSON wants [lng, lat]
        const coords    = boundary.map(([lat, lng]) => [lng, lat]);
        coords.push(coords[0]); // close the ring
        return {
          type: 'Feature',
          properties: { id: d.id, match: d.market_match, neighborhood: d.neighborhood, data: d },
          geometry: { type: 'Polygon', coordinates: [coords] }
        };
      });

      hexLayer = L.geoJSON({ type: 'FeatureCollection', features }, {
        style: feat => ({
          fillColor:   gapColor(feat.properties.match),
          fillOpacity: 0.55,
          color:       '#ffffff22',
          weight:      1
        }),
        onEachFeature: (feat, layer) => {
          layer.bindPopup(buildPopup(feat.properties.data), { maxWidth: 260 });
          layer.on('mouseover', function () {
            this.setStyle({ fillOpacity: 0.8, weight: 2, color: '#ffffff55' });
          });
          layer.on('mouseout', function () {
            hexLayer.resetStyle(this);
          });
          layer.on('click', () => showNeighborhood(feat.properties.data, true));
        }
      }).addTo(rhMap);
    }

    document.getElementById('btn-hex-toggle').addEventListener('click', () => {
      hexActive = !hexActive;
      const btn = document.getElementById('btn-hex-toggle');
      if (hexActive) {
        btn.classList.add('active-hex');
        btn.textContent = '📍 خريطة عادية';
        // Hide pin markers
        markerLayer.remove();
        renderHexLayer();
      } else {
        btn.classList.remove('active-hex');
        btn.textContent = '⬡ خرائط سداسية';
        // Remove hex layer, restore pins
        if (hexLayer) { rhMap.removeLayer(hexLayer); hexLayer = null; }
        markerLayer.addTo(rhMap);
      }
    });

    // ── 7. Table rendering ────────────────────────────────────────────────────
    let currentFilter = 'all';
    let searchVal     = '';

    function segmentsBadge(segments) {
      return (segments || []).map(s => {
        const cls = s === 'A' ? 'badge-A' : (s === 'B' ? 'badge-B' : 'badge-C');
        return `<span class="badge ${cls}">${s}</span>`;
      }).join(' ');
    }
    function matchBadge(match) {
      if (match === 'مطابق')      return `<span class="badge badge-match-yes">${match}</span>`;
      if (match === 'جزئي')       return `<span class="badge badge-match-part">${match}</span>`;
      if (match === 'غير مطابق')  return `<span class="badge badge-match-no">${match}</span>`;
      return `<span class="badge">${match}</span>`;
    }

    function renderTable() {
      const q = searchVal.trim();
      const filtered = DATA.filter(d => {
        const matchSearch = !q || d.neighborhood.includes(q);
        let matchFilter = true;
        if      (currentFilter === 'A')   matchFilter = (d.segments_present || []).includes('A');
        else if (currentFilter === 'B')   matchFilter = (d.segments_present || []).includes('B');
        else if (currentFilter === 'C')   matchFilter = (d.segments_present || []).includes('C');
        else if (currentFilter === 'none') matchFilter = d.market_match === 'غير مطابق';
        else if (currentFilter === 'partial') matchFilter = d.market_match === 'جزئي';
        return matchSearch && matchFilter;
      });

      const tbody  = document.getElementById('rh-tbody');
      const noRes  = document.getElementById('rh-no-results');
      document.getElementById('rh-row-count').textContent = `${filtered.length} من ${DATA.length}`;

      if (!filtered.length) { tbody.innerHTML = ''; noRes.style.display = 'block'; return; }
      noRes.style.display = 'none';

      tbody.innerHTML = filtered.map(d => `
        <tr data-id="${d.id}" class="${selectedId === d.id ? 'selected' : ''}">
          <td>${d.neighborhood}</td>
          <td><div style="display:flex;gap:4px">${segmentsBadge(d.segments_present)}</div></td>
          <td style="font-family:'JetBrains Mono',monospace;font-size:10px">${(d.population/1000).toFixed(0)}k</td>
          <td style="font-size:10px">${d.flow}</td>
          <td>${matchBadge(d.market_match)}</td>
          <td style="display:flex;gap:4px">
            <button class="btn-act" data-id="${d.id}">📍</button>
            <button class="btn-act edit" data-edit="${d.id}">✏️</button>
          </td>
        </tr>
      `).join('');

      // Row click → show on map
      tbody.querySelectorAll('tr').forEach(row => {
        row.addEventListener('click', e => {
          if (e.target.closest('[data-id]') && !e.target.closest('[data-edit]')) {
            const d = DATA.find(x => x.id == row.dataset.id);
            if (d) showNeighborhood(d, false);
          }
        });
      });
      // 📍 pin button
      tbody.querySelectorAll('[data-id].btn-act:not([data-edit])').forEach(btn => {
        btn.addEventListener('click', e => {
          e.stopPropagation();
          const d = DATA.find(x => x.id == btn.dataset.id);
          if (d) showNeighborhood(d, false);
        });
      });
      // ✏️ edit button
      tbody.querySelectorAll('[data-edit]').forEach(btn => {
        btn.addEventListener('click', e => {
          e.stopPropagation();
          openEditModal(parseInt(btn.dataset.edit));
        });
      });
    }

    // ── 8. Edit Modal ─────────────────────────────────────────────────────────
    function openEditModal(id) {
      const d = DATA.find(x => x.id === id);
      if (!d) return;
      document.getElementById('edit-id').value            = d.id;
      document.getElementById('edit-neighborhood').value  = d.neighborhood;
      document.getElementById('edit-class').value         = d.class;
      document.getElementById('edit-population').value    = d.population;
      document.getElementById('edit-market1').value       = d.market1;
      document.getElementById('edit-market2').value       = d.market2 === '-' ? '' : d.market2;
      document.getElementById('edit-flow').value          = d.flow;
      document.getElementById('edit-accessibility').value = d.accessibility;
      document.getElementById('edit-gap').value           = d.gap;

      // New fields
      const segs = d.segments_present || [];
      document.querySelectorAll('input[name="edit-segments"]').forEach(cb => {
        cb.checked = segs.includes(cb.value);
      });
      document.getElementById('edit-market-type').value = d.market_type || 'تجزئة';
      document.getElementById('edit-market-match').value = d.market_match || 'مطابق';

      document.getElementById('rh-modal-title').textContent = `✏️ تعديل: ${d.neighborhood}`;
      document.getElementById('rh-modal-overlay').classList.add('open');
    }

    document.getElementById('btn-modal-cancel').addEventListener('click', () => {
      document.getElementById('rh-modal-overlay').classList.remove('open');
    });
    document.getElementById('rh-modal-overlay').addEventListener('click', e => {
      if (e.target === document.getElementById('rh-modal-overlay'))
        document.getElementById('rh-modal-overlay').classList.remove('open');
    });

    document.getElementById('btn-modal-save').addEventListener('click', () => {
      const id  = parseInt(document.getElementById('edit-id').value);
      const idx = DATA.findIndex(d => d.id === id);
      if (idx === -1) return;

      // Build updated record (preserve lat/lng)
      const selectedSegments = Array.from(document.querySelectorAll('input[name="edit-segments"]:checked')).map(cb => cb.value);

      const updated = {
        ...DATA[idx],
        neighborhood:     document.getElementById('edit-neighborhood').value.trim(),
        class:            document.getElementById('edit-class').value,
        population:       parseInt(document.getElementById('edit-population').value) || 0,
        market1:          document.getElementById('edit-market1').value.trim(),
        market2:          document.getElementById('edit-market2').value.trim() || '-',
        flow:             document.getElementById('edit-flow').value,
        accessibility:    document.getElementById('edit-accessibility').value,
        gap:              document.getElementById('edit-gap').value,
        segments_present: selectedSegments,
        market_type:      document.getElementById('edit-market-type').value,
        market_match:     document.getElementById('edit-market-match').value,
      };

      // Update in-memory array
      DATA[idx] = updated;

      // Persist to localStorage
      saveToStorage(updated);

      // Refresh all UI
      updateStats();
      renderTable();
      addMarkersToMap();
      if (hexActive) renderHexLayer();

      document.getElementById('rh-modal-overlay').classList.remove('open');
      showToast(`✓ تم حفظ بيانات "${updated.neighborhood}"`, 'success');
    });

    // ── 9. Reset button ───────────────────────────────────────────────────────
    document.getElementById('btn-reset-data').addEventListener('click', () => {
      if (confirm('هل تريد إعادة ضبط جميع البيانات للقيم الافتراضية؟ سيتم حذف جميع التعديلات المحفوظة.')) {
        resetToDefaults();
      }
    });

    // ── 10. Filter + Search ───────────────────────────────────────────────────
    document.getElementById('rh-search').addEventListener('input', e => {
      searchVal = e.target.value;
      renderTable();
    });
    document.querySelectorAll('#rh-filters .fp').forEach(pill => {
      pill.addEventListener('click', () => {
        document.querySelectorAll('#rh-filters .fp').forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
        currentFilter = pill.dataset.filter;
        renderTable();
      });
    });

    // ── 11. Initial render ────────────────────────────────────────────────────
    loadFromStorage();
    renderTable();

  })();
  </script>

</DashboardLayout>
