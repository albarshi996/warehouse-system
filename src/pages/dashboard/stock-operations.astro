/* ========================================================
   سجل المسح
   ======================================================== */
function addToScanLog(item, qty) {
  scanLog.push({ barcode: item.barcode, name: item.name, qty, time: getNow() });
  if (scanLog.length > 1000) scanLog = scanLog.slice(-1000);

  /* ☁️ المرحلة 2: كل مسح يُرفع كقيد دائم في السحابة (لا يُحذف أبداً).
     كل مسارات المسح (مفرد · جملة · كاميرا · لصق) تمرّ من هنا، فلا يفوت شيء.
     الرفع لا يُعطّل الواجهة، ويُخزَّن محلياً ويُرسل تلقائياً عند عودة الإنترنت. */
  if (window.__bzCloud) {
    window.__bzCloud.pushScan({
      barcode: item.barcode,
      name: item.name,
      qty,
      opType: operationType,
    });
  }
}

/* ========================================================
   ✅ الحزمة الثالثة: تحديث الإحصائيات مع config
   ======================================================== */
function updateStats() {
  const cfg = getOperationConfig(operationType);
  const total = inventoryDB.length;
  const scanned = inventoryDB.filter(i => i.scanned).length;
  const remaining = total - scanned;
  const diff = inventoryDB.filter(i => i.scanned && i.actualQty !== i.systemQty).length;
  const pct = total > 0 ? Math.round((scanned / total) * 100) : 0;

  document.getElementById('statTotal').textContent = formatNum(total);
  document.getElementById('statScanned').textContent = formatNum(scanned);
  document.getElementById('statRemaining').textContent = formatNum(remaining);
  document.getElementById('statDiff').textContent = formatNum(diff);
  document.getElementById('statPct').textContent = pct + '%';

  document.getElementById('tabFullCount').textContent = formatNum(total);
  document.getElementById('tabScannedCount').textContent = formatNum(scanned);
  document.getElementById('tabDiffCount').textContent = formatNum(diff);
  document.getElementById('tabUnscannedCount').textContent = formatNum(remaining);

  applyOperationConfigToUI();
}

/* ========================================================
   ✅ الحزمة الثالثة: عرض الجدول — يتكيف مع نوع العملية
   ======================================================== */
function getTabData() {
  let data = inventoryDB;
  if (currentTab === 'scanned') data = data.filter(i => i.scanned);
  else if (currentTab === 'diff') data = data.filter(i => i.scanned && i.actualQty !== i.systemQty);
  else if (currentTab === 'unscanned') data = data.filter(i => !i.scanned);
  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    data = data.filter(i =>
      (i.barcode && i.barcode.toLowerCase().includes(q)) ||
      (i.name && i.name.toLowerCase().includes(q)) ||
      (i.itemCode && i.itemCode.toLowerCase().includes(q)) ||
      (i.category && i.category.toLowerCase().includes(q))
    );
  }
  return data;
}

function renderCurrentTable() {
  const cfg = getOperationConfig(operationType);
  filteredData = getTabData();
  const totalPages = Math.max(1, Math.ceil(filteredData.length / ROWS_PER_PAGE));
  if (currentPage > totalPages) currentPage = totalPages;

  const start = (currentPage - 1) * ROWS_PER_PAGE;
  const pageData = filteredData.slice(start, start + ROWS_PER_PAGE);

  // رسم العناوين حسب نوع العملية
  const showSysQtyCol = cfg.showSysQty;
  const showDiffCol = cfg.showDiffStats;
  const qtyColLabel = cfg.qtyLabel;

  let headCols = `
    <th style="width:40px">#</th>
    <th>نوع العملية</th>
    <th>الباركود</th>
    <th>كود الصنف</th>
    <th class="wrap-cell">اسم الصنف</th>
    <th>الظل</th>
    <th>التصنيف</th>`;
  if (showSysQtyCol) headCols += `<th>الكمية الدفترية</th>`;
  headCols += `<th>${qtyColLabel}</th>`;
  if (showDiffCol) headCols += `<th>الفرق</th>`;
  headCols += `<th>ملاحظات</th><th>إجراء</th>`;

  document.getElementById('tableHead').innerHTML = headCols;

  const tbody = document.getElementById('tableBody');
  if (!pageData.length) {
    const colCount = 9 + (showSysQtyCol ? 1 : 0) + (showDiffCol ? 1 : 0);
    tbody.innerHTML = `<tr><td colspan="${colCount}" class="text-center py-12 text-dark-400">
      <i class="fa-solid fa-inbox text-4xl mb-3 block opacity-40"></i>
      لا توجد بيانات
    </td></tr>`;
    renderPagination(0, 0);
    return;
  }

  tbody.innerHTML = pageData.map((item, i) => {
    const globalIdx = start + i + 1;
    const diff = item.actualQty - item.systemQty;
    let diffClass = 'diff-zero', diffText = '0';
    if (diff > 0) { diffClass = 'diff-pos'; diffText = '+' + diff; }
    else if (diff < 0) { diffClass = 'diff-neg'; diffText = String(diff); }

    const itemOp = item.operationType || operationType;
    const itemCfg = getOperationConfig(itemOp);

    // تلوين الصف
    let rowClass = '';
    if (itemCfg.rowColorClass) rowClass = itemCfg.rowColorClass;
    else if (item.scanned) rowClass = (diff !== 0 && showDiffCol) ? 'row-diff' : 'row-scanned';

    const statusDot = item.scanned
      ? (diff !== 0 && showDiffCol
        ? '<span class="inline-block w-2 h-2 rounded-full bg-amber-400 mr-1"></span>'
        : '<span class="inline-block w-2 h-2 rounded-full bg-green-400 mr-1"></span>')
      : '<span class="inline-block w-2 h-2 rounded-full bg-dark-500 mr-1"></span>';

    const opTypeColors = {
      'جرد':'text-brand-400','استلام':'text-green-400','صرف':'text-red-400',
      'إضافة أصناف':'text-blue-400','تالف':'text-amber-400','مرتجع':'text-purple-400'
    };
    const opTypeColor = opTypeColors[itemOp] || 'text-brand-400';

    let row = `<tr class="${rowClass}">
      <td class="text-dark-400 text-xs">${globalIdx}</td>
      <td class="text-xs font-semibold ${opTypeColor}">${getOperationTypeIcon(itemOp)} ${itemOp}</td>
      <td>
        <button class="font-mono text-xs text-brand-400 hover:text-brand-300 transition" onclick="openScanDetailModal('${item.barcode.replace(/'/g,"\\'")}')">
          ${statusDot}${item.barcode}
        </button>
      </td>
      <td class="text-xs text-dark-400">${item.itemCode || '—'}</td>
      <td class="wrap-cell font-semibold item-name-cell" data-item-id="${item.id}" onmouseenter="showItemTooltipForId(event, '${item.id}')" onmouseleave="hideItemTooltip()">${item.name || '—'}</td>
      <td class="text-xs text-dark-400">${item.shade || '—'}</td>
      <td class="text-xs">${item.category || '—'}</td>`;

    if (showSysQtyCol) {
      row += `<td class="text-center font-bold text-gold-500">${formatNum(item.systemQty)}</td>`;
    }
    row += `<td class="text-center font-bold text-brand-400">${item.scanned ? formatNum(item.actualQty) : '—'}</td>`;
    if (showDiffCol) {
      row += `<td class="text-center ${diffClass}">${item.scanned ? diffText : '—'}</td>`;
    }
    row += `<td class="text-xs text-dark-400 wrap-cell" style="max-width:160px">${item.notes || '—'}</td>
      <td>
        <div class="flex gap-1">
          <button class="btn btn-ghost btn-sm !py-1 !px-2" onclick="openEditItem('${item.id}')" title="تعديل"><i class="fa-solid fa-pen text-xs"></i></button>
          <button class="btn btn-danger btn-sm !py-1 !px-2" onclick="deleteItem('${item.id}')" title="حذف"><i class="fa-solid fa-trash text-xs"></i></button>
        </div>
      </td>
    </tr>`;
    return row;
  }).join('');

  renderPagination(filteredData.length, totalPages);
}

function deleteItem(itemId) {
  if (!confirm('هل تريد حذف هذا الصنف نهائياً؟')) return;
  inventoryDB = inventoryDB.filter(i => i.id !== itemId);
  showToast('تم حذف الصنف', 'info');
  updateStats();
  updateProgressBar();
  renderCurrentTable();
  saveSessionDebounced();
}

function renderPagination(total, totalPages) {
  document.getElementById('paginationInfo').textContent =
    total === 0 ? 'لا توجد نتائج' : `عرض ${(currentPage-1)*ROWS_PER_PAGE+1}–${Math.min(currentPage*ROWS_PER_PAGE, total)} من ${total.toLocaleString()}`;
  const pc = document.getElementById('paginationControls');
  if (totalPages <= 1) { pc.innerHTML = ''; return; }
  let html = `<button class="btn btn-ghost btn-sm !py-1 !px-2" onclick="goPage(1)" ${currentPage===1?'disabled':''}><i class="fa-solid fa-angles-right text-xs"></i></button>`;
  html += `<button class="btn btn-ghost btn-sm !py-1 !px-2" onclick="goPage(${currentPage-1})" ${currentPage===1?'disabled':''}><i class="fa-solid fa-angle-right text-xs"></i></button>`;
  const range = [];
  const delta = 2;
  for (let i = Math.max(1, currentPage-delta); i <= Math.min(totalPages, currentPage+delta); i++) range.push(i);
  if (range[0] > 1) html += `<span class="text-xs text-dark-400 px-1">...</span>`;
  range.forEach(p => {
    html += `<button class="btn btn-sm !py-1 !px-3 ${p===currentPage?'btn-primary':'btn-ghost'}" onclick="goPage(${p})">${p}</button>`;
  });
  if (range[range.length-1] < totalPages) html += `<span class="text-xs text-dark-400 px-1">...</span>`;
  html += `<button class="btn btn-ghost btn-sm !py-1 !px-2" onclick="goPage(${currentPage+1})" ${currentPage===totalPages?'disabled':''}><i class="fa-solid fa-angle-left text-xs"></i></button>`;
  html += `<button class="btn btn-ghost btn-sm !py-1 !px-2" onclick="goPage(${totalPages})" ${currentPage===totalPages?'disabled':''}><i class="fa-solid fa-angles-left text-xs"></i></button>`;
  pc.innerHTML = html;
}

function goPage(p) { currentPage = p; renderCurrentTable(); }
function switchTab(tab) {
  currentTab = tab; currentPage = 1; searchQuery = '';
  document.getElementById('searchInput').value = '';
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
  renderCurrentTable();
}
function handleSearch() {
  searchQuery = document.getElementById('searchInput').value.trim();
  currentPage = 1;
  renderCurrentTable();
}

/* ========================================================
   التصدير إلى Excel — مع operationMeta
   ======================================================== */
function showExportModal() {
  buildValidationReport();
  openModal('exportModal');
}

function buildValidationReport() {
  const total = inventoryDB.length;
  const scanned = inventoryDB.filter(i => i.scanned).length;
  const diff = inventoryDB.filter(i => i.scanned && i.actualQty !== i.systemQty).length;
  const unscanned = total - scanned;
  const manualAdded = inventoryDB.filter(i => i.isManual).length;
  const negativeActual = inventoryDB.filter(i => i.actualQty < 0).length;
  const missingName = inventoryDB.filter(i => !i.name || i.name.trim() === '').length;
  const lines = [
    { ok: true,           text: `إجمالي الأصناف: <strong>${total.toLocaleString()}</strong>` },
    { ok: true,           text: `تم مسح: <strong>${scanned.toLocaleString()}</strong> (${total > 0 ? Math.round(scanned/total*100) : 0}%)` },
    { ok: diff === 0,     text: `فروقات: <strong>${diff.toLocaleString()}</strong>` },
    { ok: unscanned === 0,text: `لم يُمسح: <strong>${unscanned.toLocaleString()}</strong>` },
    { ok: manualAdded === 0, text: `مضافة يدوياً: <strong>${manualAdded.toLocaleString()}</strong>` },
    { ok: negativeActual === 0, text: `كميات سالبة: <strong>${negativeActual}</strong>`, warn: negativeActual > 0 },
    { ok: missingName === 0,    text: `بدون اسم: <strong>${missingName}</strong>`, warn: missingName > 0 },
  ];
  document.getElementById('validationLines').innerHTML = lines.map(l => {
    const icon = l.ok ? '✓' : (l.warn ? '⚠' : '✗');
    const color = l.ok ? 'text-green-400' : (l.warn ? 'text-amber-400' : 'text-red-400');
    return `<div class="${color}">${icon} ${l.text}</div>`;
  }).join('');
}

function exportToExcel(mode = 'full') {
  if (!inventoryDB.length) { showToast('لا توجد بيانات للتصدير', 'warning'); return; }
  let data, sheetName;
  if (mode === 'full') { data = inventoryDB; sheetName = 'كل الأصناف'; }
  else if (mode === 'scanned') { data = inventoryDB.filter(i => i.scanned); sheetName = 'الأصناف المسحوبة'; }
  else if (mode === 'diff') { data = inventoryDB.filter(i => i.scanned && i.actualQty !== i.systemQty); sheetName = 'الفروقات'; }
  else if (mode === 'unscanned') { data = inventoryDB.filter(i => !i.scanned); sheetName = 'غير المسحوبة'; }
  if (!data.length) { showToast('لا توجد بيانات في هذه الفئة', 'warning'); return; }

  const headers = ['#','نوع العملية','الباركود','كود الصنف','اسم الصنف','الظل/اللون','التصنيف','التصنيف الفرعي',
    'الكمية الدفترية','الكمية الفعلية','الفرق','الوحدة','سعر الوحدة','إجمالي القيمة','ملاحظات','تم المسح','آخر مسح','المصدر','تفاصيل إضافية'];

  const rows = data.map((item, i) => {
    const diff = item.actualQty - item.systemQty;
    const totalVal = (item.actualQty * item.unitPrice).toFixed(2);
    const metaStr = item.operationMeta ? Object.entries(item.operationMeta).filter(([,v])=>v).map(([k,v])=>`${k}: ${v}`).join(' | ') : '';
    return [
      i + 1, item.operationType || operationType, item.barcode || '', item.itemCode || '',
      item.name || '', item.shade || '', item.category || '', item.subcategory || '',
      item.systemQty, item.actualQty, diff, item.unit || '', item.unitPrice || 0,
      parseFloat(totalVal), item.notes || '', item.scanned ? 'نعم' : 'لا',
      item.timestamp ? new Date(item.timestamp).toLocaleString('ar-SA') : '',
      item.source || '', metaStr
    ];
  });

  const wsData = [headers, ...rows];
  const ws = XLSX.utils.aoa_to_sheet(wsData);
  ws['!cols'] = [
    {wch:5},{wch:18},{wch:13},{wch:38},{wch:18},{wch:20},{wch:20},
    {wch:14},{wch:14},{wch:10},{wch:11},{wch:13},{wch:15},{wch:28},{wch:10},{wch:20},{wch:16},{wch:30}
  ];
  ws['!autofilter'] = { ref: XLSX.utils.encode_range({s:{r:0,c:0},e:{r:0,c:headers.length-1}}) };
  ws['!freeze'] = { xSplit: 0, ySplit: 1 };

  const now = new Date();
  const total = inventoryDB.length;
  const scannedCount = inventoryDB.filter(i => i.scanned).length;
  const diffCount = inventoryDB.filter(i => i.scanned && i.actualQty !== i.systemQty).length;
  const netVar = inventoryDB.filter(i => i.scanned).reduce((s, i) => s + (i.actualQty - i.systemQty), 0);
  const summaryData = [
    ['تقرير جرد المخزون — مقترح الجرد الذكي Pro'],[],
    ['التاريخ', now.toLocaleDateString('ar-SA')],
    ['الوقت', now.toLocaleTimeString('ar-SA')],
    ['نوع العملية', operationType],[],
    ['إجمالي الأصناف', total], ['تم المسح', scannedCount],
    ['نسبة الإنجاز', total > 0 ? (scannedCount/total*100).toFixed(1)+'%' : '0%'],
    ['لم يُمسح', total - scannedCount], ['عدد الفروقات', diffCount],
    ['صافي التباين', netVar > 0 ? '+'+netVar : netVar],[],
    ['وضع التصدير', { full:'كل الأصناف', scanned:'المسحوبة فقط', diff:'الفروقات', unscanned:'غير المسحوبة' }[mode]],
    ['عدد الصفوف المصدّرة', data.length],
  ];
  const wsSummary = XLSX.utils.aoa_to_sheet(summaryData);
  wsSummary['!cols'] = [{wch:22},{wch:30}];
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, sheetName);
  XLSX.utils.book_append_sheet(wb, wsSummary, 'الملخص');
  const dateStr = now.toISOString().split('T')[0];
  const modeStr = { full:'Full', scanned:'Scanned', diff:'Diff', unscanned:'Unscanned' }[mode];
  XLSX.writeFile(wb, `Inventory_${modeStr}_${dateStr}.xlsx`);
  showToast(`تم تصدير ${data.length.toLocaleString()} صنف`, 'success');
  closeModal('exportModal');
}

/* ========================================================
   الطباعة / PDF
   ======================================================== */
function preparePrint() {
  if (!inventoryDB.length) { showToast('لا توجد بيانات للطباعة', 'warning'); return; }
  const company = document.getElementById('printCompanyName').value.trim() || 'Brandzo Hub 2026';
  const auditor = document.getElementById('printAuditorName').value.trim();
  const optScanned = document.getElementById('printOptScanned').checked;
  const optDiff = document.getElementById('printOptDiff').checked;
  const optUnscanned = document.getElementById('printOptUnscanned').checked;
  const optCategory = document.getElementById('printOptCategory').checked;
  const printAll = document.getElementById('printAllRows').checked;
  const MAX_ROWS = printAll ? Infinity : 300;

  document.getElementById('printFooterCompany').textContent = company;
  document.getElementById('printContent').innerHTML = '';
  document.getElementById('printLoadingMsg').style.display = 'block';
  document.getElementById('dashboardScreen').classList.add('hidden');
  document.getElementById('printContainer').style.display = 'block';

  setTimeout(() => {
    const now = new Date();
    const dateStr = now.toLocaleDateString('ar-SA');
    const timeStr = now.toLocaleTimeString('ar-SA');
    const total = inventoryDB.length;
    const scanned = inventoryDB.filter(i => i.scanned).length;
    const diffItems = inventoryDB.filter(i => i.scanned && i.actualQty !== i.systemQty);
    const unscannedItems = inventoryDB.filter(i => !i.scanned);
    const netVar = inventoryDB.filter(i => i.scanned).reduce((s, i) => s + (i.actualQty - i.systemQty), 0);
    const damagedItems = inventoryDB.filter(i => i.scanned && (i.operationType === 'تالف'));

    let html = `
      <div class="print-header">
        <div class="print-company">${company}</div>
        <h1>تقرير ${operationType} — Audit Report</h1>
        <div class="print-meta">
          التاريخ: ${dateStr} &nbsp;|&nbsp; الوقت: ${timeStr}
          ${auditor ? ` &nbsp;|&nbsp; المدقق: ${auditor}` : ''}
          &nbsp;|&nbsp; نوع العملية: ${operationType}
        </div>
      </div>
      <div class="print-summary avoid-break">
        ${[
          ['الإجمالي', total], ['تم المسح', scanned],
          ['المتبقي', total - scanned], ['فروقات', diffItems.length],
          ['الإنجاز', total > 0 ? Math.round(scanned/total*100)+'%' : '0%']
        ].map(([l,v]) => `<div class="print-summary-card"><div class="ps-label">${l}</div><div class="ps-value">${v}</div></div>`).join('')}
      </div>
      <div class="print-net avoid-break">
        صافي التباين: <strong>${netVar > 0 ? '+'+netVar : netVar} ${netVar > 0 ? '(فائض)' : netVar < 0 ? '(عجز)' : '(مطابق)'}</strong>
        &nbsp;|&nbsp; معدل الإنجاز: <strong>${total > 0 ? (scanned/total*100).toFixed(1) : 0}%</strong>
      </div>`;

    if (optScanned && scanned > 0) {
      const scannedItems = inventoryDB.filter(i => i.scanned);
      html += `<div class="page-break"></div><div class="print-section-title">الأصناف المسحوبة — Scanned Items (${scannedItems.length.toLocaleString()})</div>`;
      html += buildPrintTable(scannedItems, MAX_ROWS, true);
    }

    if (optDiff && diffItems.length > 0) {
      html += `<div class="page-break"></div><div class="print-section-title">الفروقات — Variance Analysis (${diffItems.length.toLocaleString()})</div>`;
      html += buildPrintTable(diffItems, MAX_ROWS, true);
    }

    if (optUnscanned && unscannedItems.length > 0) {
      html += `<div class="page-break"></div><div class="print-section-title">غير المسحوبة — Unscanned (${unscannedItems.length.toLocaleString()})</div>`;
      html += buildPrintTable(unscannedItems, MAX_ROWS, false);
    }

    // ✅ الحزمة الثالثة: قسم التالف في التقرير
    if (damagedItems.length > 0) {
      html += `<div class="page-break"></div><div class="print-section-title">أصناف التالف — Damaged Items (${damagedItems.length})</div>`;
      html += buildDamagedPrintTable(damagedItems);
    }

    if (optCategory) {
      html += `<div class="page-break"></div><div class="print-section-title">التصنيف حسب الفئة — Category Breakdown</div>`;
      html += buildCategoryBreakdown();
    }

    html += `
      <div class="avoid-break" style="margin-top:40px">
        <div class="print-section-title">التوقيعات — Signatures</div>
        <div class="signature-block">
          <div><div class="signature-line">${auditor || 'المدقق: Auditor'}</div></div>
          <div><div class="signature-line">المدير: Manager</div></div>
          <div><div class="signature-line">المراجع: Reviewer</div></div>
        </div>
      </div>`;

    document.getElementById('printLoadingMsg').style.display = 'none';
    document.getElementById('printContent').innerHTML = html;
    setTimeout(() => {
      window.print();
      setTimeout(() => {
        document.getElementById('printContainer').style.display = 'none';
        document.getElementById('dashboardScreen').classList.remove('hidden');
        closeModal('exportModal');
      }, 500);
    }, 300);
  }, 200);
}

function buildPrintTable(data, maxRows, showDiff) {
  if (!data.length) return '<p style="font-size:9pt;color:#888;text-align:center;padding:16px">لا توجد بيانات</p>';
  const truncated = data.length > maxRows;
  const display = truncated ? data.slice(0, maxRows) : data;
  const cols = showDiff
    ? ['#','نوع العملية','الباركود','كود الصنف','اسم الصنف','التصنيف','الكمية الدفترية','الكمية الفعلية','الفرق','ملاحظات']
    : ['#','نوع العملية','الباركود','كود الصنف','اسم الصنف','التصنيف','الكمية الدفترية'];
  let html = `<table class="print-table avoid-break"><thead><tr>${cols.map(c=>`<th>${c}</th>`).join('')}</tr></thead><tbody>`;
  display.forEach((item, idx) => {
    const diff = item.actualQty - item.systemQty;
    let dc = 'print-diff-zero', dt = '0';
    if (diff > 0) { dc = 'print-diff-pos'; dt = '+'+diff; }
    else if (diff < 0) { dc = 'print-diff-neg'; dt = String(diff); }
    if (showDiff) {
      html += `<tr><td>${idx+1}</td><td>${item.operationType || operationType}</td><td style="font-family:monospace;font-size:7.5pt">${item.barcode||'-'}</td><td>${item.itemCode||'-'}</td><td>${item.name||'-'}</td><td>${item.category||'-'}</td><td style="text-align:center">${item.systemQty}</td><td style="text-align:center">${item.actualQty}</td><td class="${dc}" style="text-align:center">${dt}</td><td>${item.notes||'-'}</td></tr>`;
    } else {
      html += `<tr><td>${idx+1}</td><td>${item.operationType || operationType}</td><td style="font-family:monospace;font-size:7.5pt">${item.barcode||'-'}</td><td>${item.itemCode||'-'}</td><td>${item.name||'-'}</td><td>${item.category||'-'}</td><td style="text-align:center">${item.systemQty}</td></tr>`;
    }
  });
  html += '</tbody></table>';
  if (truncated) html += `<p style="font-size:8pt;color:#666;font-style:italic;margin-top:6px">يُعرض أول ${maxRows.toLocaleString()} صف من أصل ${data.length.toLocaleString()}. فعّل "طباعة كل الصفوف" للقائمة الكاملة أو صدّر إلى Excel.</p>`;
  return html;
}

/* ✅ الحزمة الثالثة: جدول طباعة التالف مع أسباب التلف */
function buildDamagedPrintTable(data) {
  if (!data.length) return '<p style="font-size:9pt;color:#888;text-align:center;padding:16px">لا توجد بيانات</p>';
  let html = `<table class="print-table avoid-break">
    <thead><tr><th>#</th><th>الباركود</th><th>اسم الصنف</th><th>الكمية</th><th>سبب التلف</th><th>إمكانية الإرجاع</th><th>ملاحظات</th></tr></thead><tbody>`;
  data.forEach((item, idx) => {
    const meta = item.operationMeta || {};
    html += `<tr>
      <td>${idx+1}</td>
      <td style="font-family:monospace;font-size:7.5pt">${item.barcode||'-'}</td>
      <td>${item.name||'-'}</td>
      <td style="text-align:center">${item.actualQty}</td>
      <td>${meta.metaDamageReason || '-'}</td>
      <td style="text-align:center">${meta.metaCanReturn || '-'}</td>
      <td>${item.notes||'-'}</td>
    </tr>`;
  });
  html += '</tbody></table>';
  return html;
}

function buildCategoryBreakdown() {
  const catMap = {};
  inventoryDB.forEach(item => {
    const cat = item.category || 'غير مصنف';
    if (!catMap[cat]) catMap[cat] = { total:0, scanned:0, sysQty:0, actQty:0 };
    catMap[cat].total++;
    if (item.scanned) { catMap[cat].scanned++; catMap[cat].sysQty += item.systemQty; catMap[cat].actQty += item.actualQty; }
  });
  const sorted = Object.entries(catMap).sort((a, b) => b[1].total - a[1].total);
  let html = `<table class="print-table avoid-break">
    <thead><tr><th>التصنيف</th><th>الأصناف</th><th>تم المسح</th><th>الكمية الدفترية</th><th>الكمية الفعلية</th><th>الفرق</th></tr></thead><tbody>`;
  sorted.forEach(([cat, d]) => {
    const diff = d.actQty - d.sysQty;
    let dc = 'print-diff-zero', dt = '0';
    if (diff > 0) { dc = 'print-diff-pos'; dt = '+'+diff; }
    else if (diff < 0) { dc = 'print-diff-neg'; dt = String(diff); }
    html += `<tr><td>${cat}</td><td style="text-align:center">${d.total}</td><td style="text-align:center">${d.scanned}</td><td style="text-align:center">${d.sysQty}</td><td style="text-align:center">${d.actQty}</td><td class="${dc}" style="text-align:center">${dt}</td></tr>`;
  });
  html += '</tbody></table>';
  return html;
}
(function(){
  function sync(){
    var s=document.getElementById('statScanned'), r=document.getElementById('statRemaining');
    var fs=document.getElementById('bzFloatScanned'), fr=document.getElementById('bzFloatRemaining');
    if(s&&fs) fs.textContent=s.textContent;
    if(r&&fr) fr.textContent=r.textContent;
  }
  function init(){
    var bar=document.getElementById('statsBar');
    if(bar && window.MutationObserver){
      new MutationObserver(sync).observe(bar,{subtree:true,childList:true,characterData:true});
    }
    sync();
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',init);
  else init();
})();
</script>
