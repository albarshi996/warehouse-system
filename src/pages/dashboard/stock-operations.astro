  checkAdminSession();
  checkExistingSession();
});

/* ========================================================
   لصق عادي — Batch (بتبويبين الآن)
   ======================================================== */
let batchCurrentTab = 'text';

function switchBatchTab(tab) {
  batchCurrentTab = tab;
  document.getElementById('batchTabText').classList.toggle('active', tab === 'text');
  document.getElementById('batchTabCam').classList.toggle('active', tab === 'cam');
  document.getElementById('batchPanelText').classList.toggle('hidden', tab !== 'text');
  document.getElementById('batchPanelCam').classList.toggle('hidden', tab !== 'cam');
  if (tab === 'cam') {
    populateBulkCameraDevices();
  } else {
    stopBulkCamera();
  }
}

function openBatchModal() {
  openModal('batchModal');
  // إعادة تبويب النص
  batchCurrentTab = 'text';
  document.getElementById('batchTabText').classList.add('active');
  document.getElementById('batchTabCam').classList.remove('active');
  document.getElementById('batchPanelText').classList.remove('hidden');
  document.getElementById('batchPanelCam').classList.add('hidden');
  document.getElementById('batchText').value = '';
  setTimeout(() => document.getElementById('batchText').focus(), 100);
}

function closeBatchModal() {
  stopBulkCamera();
  closeModal('batchModal');
}

function processBatch() {
  const text = document.getElementById('batchText').value.trim();
  if (!text) { showToast('الصق الباركودات أولاً', 'warning'); return; }
  const lines = text.split(/\r?\n/).map(l => l.trim()).filter(l => l.length >= 2);
  if (!lines.length) { showToast('لا توجد بيانات صالحة', 'error'); return; }
  const counts = {};
  lines.forEach(bc => { counts[bc] = (counts[bc] || 0) + 1; });
  let found = 0, notFound = 0;
  for (const [bc, cnt] of Object.entries(counts)) {
    const lower = bc.toLowerCase();
    let idx = inventoryDB.findIndex(i => i.barcodeLower === lower);
    if (idx < 0) idx = inventoryDB.findIndex(i => i.itemCode && i.itemCode.toLowerCase() === lower);
    if (idx >= 0) {
      inventoryDB[idx].actualQty += cnt;
      inventoryDB[idx].scanned = true;
      inventoryDB[idx].timestamp = getNow();
      addToScanLog(inventoryDB[idx], cnt);
      found++;
    } else { notFound++; }
  }
  closeBatchModal();
  showToast(`تم: ${found} صنف — ${notFound} غير موجود`, found > 0 ? 'success' : 'warning');
  updateStats(); renderCurrentTable();
}

/* ========================================================
   ✅ الحزمة الأولى: مسح بالكاميرا (مودال منفصل)
   ======================================================== */
let singleCameraStream = null;
let singleCameraScanning = false;
let singleCameraScanCount = 0;
let singleCameraLastBarcode = '';
let singleCameraLastTime = 0;
let singleCameraAnimFrame = null;
let singleBarcodeDetector = null;

async function openCameraModal() {
  singleCameraScanCount = 0;
  singleCameraLastBarcode = '';
  singleCameraLastTime = 0;
  document.getElementById('singleCameraScanInfo').textContent = 'لم يُمسح بعد';
  openModal('cameraScanModal');
  await populateSingleCameraDevices();
  await startSingleCamera();
}

async function populateSingleCameraDevices() {
  try {
    const devices = await navigator.mediaDevices.enumerateDevices();
    const cams = devices.filter(d => d.kind === 'videoinput');
    const sel = document.getElementById('cameraSelect');
    sel.innerHTML = '';
    cams.forEach((cam, i) => {
      const opt = document.createElement('option');
      opt.value = cam.deviceId;
      opt.textContent = cam.label || `كاميرا ${i + 1}`;
      sel.appendChild(opt);
    });
    // تفضيل الكاميرا الخلفية
    const backCam = cams.find(c => c.label.toLowerCase().includes('back') || c.label.toLowerCase().includes('rear') || c.label.includes('environment'));
    if (backCam) sel.value = backCam.deviceId;
  } catch (e) {}
}

async function startSingleCamera() {
  stopSingleCameraStream();
  const sel = document.getElementById('cameraSelect');
  const deviceId = sel.value;
  const constraints = { video: deviceId ? { deviceId: { exact: deviceId } } : { facingMode: 'environment' } };
  try {
    singleCameraStream = await navigator.mediaDevices.getUserMedia(constraints);
    const video = document.getElementById('cameraVideo');
    video.srcObject = singleCameraStream;
    await video.play();
    singleCameraScanning = true;
    document.getElementById('cameraStatusBadge').textContent = 'جارٍ المسح...';
    beginSingleScanLoop();
  } catch (err) {
    showToast('تعذّر الوصول إلى الكاميرا: ' + err.message, 'error');
  }
}

async function switchSingleCamera() {
  await startSingleCamera();
}

async function flipSingleCamera() {
  const sel = document.getElementById('cameraSelect');
  const opts = sel.options;
  if (opts.length < 2) return;
  const current = sel.selectedIndex;
  sel.selectedIndex = (current + 1) % opts.length;
  await startSingleCamera();
}

function stopSingleCameraStream() {
  singleCameraScanning = false;
  if (singleCameraAnimFrame) { cancelAnimationFrame(singleCameraAnimFrame); singleCameraAnimFrame = null; }
  if (singleCameraStream) {
    singleCameraStream.getTracks().forEach(t => t.stop());
    singleCameraStream = null;
  }
}

function closeCameraModal() {
  stopSingleCameraStream();
  closeModal('cameraScanModal');
  document.getElementById('cameraVideo').srcObject = null;
}

async function beginSingleScanLoop() {
  const video = document.getElementById('cameraVideo');
  const flash = document.getElementById('cameraFlash');

  // BarcodeDetector أو fallback
  if (!singleBarcodeDetector) {
    if ('BarcodeDetector' in window) {
      singleBarcodeDetector = new BarcodeDetector({ formats: ['ean_13','ean_8','code_128','code_39','qr_code','upc_a','upc_e','codabar','itf','data_matrix','pdf417'] });
    } else {
      document.getElementById('cameraStatusBadge').textContent = 'BarcodeDetector غير متاح — جرب Chrome أو Edge';
      showToast('هذا المتصفح لا يدعم BarcodeDetector. استخدم Chrome أو Edge.', 'warning');
      return;
    }
  }

  async function loop() {
    if (!singleCameraScanning) return;
    if (video.readyState === video.HAVE_ENOUGH_DATA) {
      try {
        const barcodes = await singleBarcodeDetector.detect(video);
        if (barcodes.length > 0) {
          const code = barcodes[0].rawValue;
          const now = Date.now();
          if (code !== singleCameraLastBarcode || now - singleCameraLastTime > 3000) {
            singleCameraLastBarcode = code;
            singleCameraLastTime = now;
            singleCameraScanCount++;
            document.getElementById('singleCameraScanInfo').textContent = `آخر مسح: ${code} (${singleCameraScanCount})`;
            // flash
            flash.classList.add('flash');
            setTimeout(() => flash.classList.remove('flash'), 250);
            // beep
            playBeep();
            // إيقاف مؤقت وفتح مودال الصنف
            singleCameraScanning = false;
            document.getElementById('cameraStatusBadge').textContent = '✓ تم اكتشاف الباركود';
            // نفتح مودال التفاصيل بعد لحظة
            setTimeout(() => {
              openScanDetailModal(code);
              // نعيد المسح عند إغلاق مودال التفاصيل
              const origClose = window._origCloseScanDetail;
              const origConfirm = window._origConfirmScanEntry;
              // نلاحظ إغلاق المودال لنعيد التشغيل
              restartSingleCameraAfterModal();
            }, 300);
            return;
          }
        }
      } catch (e) {}
    }
    singleCameraAnimFrame = requestAnimationFrame(loop);
  }
  singleCameraAnimFrame = requestAnimationFrame(loop);
}

function restartSingleCameraAfterModal() {
  // نضع مراقباً على كلا الزرّين في مودال التفاصيل
  const scanDetailModal = document.getElementById('scanDetailModal');
  function onModalClose() {
    if (!document.getElementById('cameraScanModal').classList.contains('active')) return;
    if (!singleCameraScanning) {
      singleCameraScanning = true;
      document.getElementById('cameraStatusBadge').textContent = 'جارٍ المسح...';
      beginSingleScanLoop();
    }
    scanDetailModal.removeEventListener('click', checkClose);
  }
  function checkClose(e) {
    // إذا أُغلق المودال
    setTimeout(() => {
      if (!scanDetailModal.classList.contains('active')) {
        onModalClose();
        scanDetailModal.removeEventListener('click', checkClose);
      }
    }, 100);
  }
  scanDetailModal.addEventListener('click', checkClose);
  // ضمان الإعادة بعد 5 ثانية على أي حال
  setTimeout(() => {
    if (!singleCameraScanning && document.getElementById('cameraScanModal').classList.contains('active') && !document.getElementById('scanDetailModal').classList.contains('active')) {
      singleCameraScanning = true;
      document.getElementById('cameraStatusBadge').textContent = 'جارٍ المسح...';
      beginSingleScanLoop();
    }
  }, 5000);
}

/* ========================================================
   ✅ الحزمة الثانية: المسح الجماعي بالكاميرا
   ======================================================== */
let bulkCameraStream = null;
let bulkCameraScanning = false;
let bulkCameraAnimFrame = null;
let bulkBarcodeDetector = null;
let bulkScanItems = []; // [{barcode, name, qty}]
let bulkLastScanTime = {}; // debounce per barcode

async function populateBulkCameraDevices() {
  try {
    const devices = await navigator.mediaDevices.enumerateDevices();
    const cams = devices.filter(d => d.kind === 'videoinput');
    const sel = document.getElementById('bulkCameraSelect');
    sel.innerHTML = '<option value="">-- اختر الكاميرا --</option>';
    cams.forEach((cam, i) => {
      const opt = document.createElement('option');
      opt.value = cam.deviceId;
      opt.textContent = cam.label || `كاميرا ${i + 1}`;
      sel.appendChild(opt);
    });
    const backCam = cams.find(c => c.label.toLowerCase().includes('back') || c.label.toLowerCase().includes('rear') || c.label.toLowerCase().includes('environment'));
    if (backCam) sel.value = backCam.deviceId;
  } catch (e) {}
}

async function startBulkCamera() {
  stopBulkCamera();
  const sel = document.getElementById('bulkCameraSelect');
  const deviceId = sel.value;
  const constraints = { video: deviceId ? { deviceId: { exact: deviceId } } : { facingMode: 'environment' } };
  try {
    bulkCameraStream = await navigator.mediaDevices.getUserMedia(constraints);
    const video = document.getElementById('bulkCameraVideo');
    video.srcObject = bulkCameraStream;
    await video.play();
    bulkCameraScanning = true;
    document.getElementById('bulkCameraStatus').textContent = 'جارٍ المسح المستمر...';
    document.getElementById('bulkStartBtn').disabled = true;
    document.getElementById('bulkStopBtn').disabled = false;
    beginBulkScanLoop();
  } catch (err) {
    showToast('تعذّر الوصول إلى الكاميرا: ' + err.message, 'error');
  }
}

async function switchBulkCamera() {
  if (bulkCameraScanning) await startBulkCamera();
}

function stopBulkCamera() {
  bulkCameraScanning = false;
  if (bulkCameraAnimFrame) { cancelAnimationFrame(bulkCameraAnimFrame); bulkCameraAnimFrame = null; }
  if (bulkCameraStream) {
    bulkCameraStream.getTracks().forEach(t => t.stop());
    bulkCameraStream = null;
  }
  const video = document.getElementById('bulkCameraVideo');
  if (video) video.srcObject = null;
  document.getElementById('bulkStartBtn').disabled = false;
  document.getElementById('bulkStopBtn').disabled = true;
  document.getElementById('bulkCameraStatus').textContent = 'الكاميرا متوقفة';
}

async function beginBulkScanLoop() {
  const video = document.getElementById('bulkCameraVideo');
  const flash = document.getElementById('bulkCameraFlash');

  if (!bulkBarcodeDetector) {
    if ('BarcodeDetector' in window) {
      bulkBarcodeDetector = new BarcodeDetector({ formats: ['ean_13','ean_8','code_128','code_39','qr_code','upc_a','upc_e','codabar','itf','data_matrix','pdf417'] });
    } else {
      document.getElementById('bulkCameraStatus').textContent = 'BarcodeDetector غير متاح — جرب Chrome أو Edge';
      showToast('هذا المتصفح لا يدعم BarcodeDetector. استخدم Chrome أو Edge.', 'warning');
      return;
    }
  }

  async function loop() {
    if (!bulkCameraScanning) return;
    if (video.readyState === video.HAVE_ENOUGH_DATA) {
      try {
        const barcodes = await bulkBarcodeDetector.detect(video);
        if (barcodes.length > 0) {
          const code = barcodes[0].rawValue;
          const now = Date.now();
          // debounce: لا تكرار نفس الباركود في أقل من 2 ثانية
          if (!bulkLastScanTime[code] || now - bulkLastScanTime[code] > 2000) {
            bulkLastScanTime[code] = now;
            // flash
            flash.classList.add('flash');
            setTimeout(() => flash.classList.remove('flash'), 200);
            // beep
            playBeep(880, 0.08);
            // إضافة للقائمة أو زيادة الكمية إذا موجود
            addToBulkList(code);
          }
        }
      } catch (e) {}
    }
    bulkCameraAnimFrame = requestAnimationFrame(loop);
  }
  bulkCameraAnimFrame = requestAnimationFrame(loop);
}

function addToBulkList(barcode) {
  const lower = barcode.toLowerCase();
  const dbItem = inventoryDB.find(i => i.barcodeLower === lower) ||
                 inventoryDB.find(i => i.itemCode && i.itemCode.toLowerCase() === lower);
  const name = dbItem ? (dbItem.name || '—') : 'غير موجود';

  const existing = bulkScanItems.find(i => i.barcode.toLowerCase() === lower);
  if (existing) {
    existing.qty++;
    refreshBulkList();
  } else {
    bulkScanItems.push({ barcode, name, qty: 1 });
    refreshBulkList();
  }

  const countEl = document.getElementById('bulkScanCount');
  countEl.textContent = bulkScanItems.reduce((s, i) => s + i.qty, 0);
  document.getElementById('bulkScanStatus').textContent = `آخر قراءة: ${barcode}`;
  document.getElementById('bulkApplyBtn').disabled = bulkScanItems.length === 0;
}

function refreshBulkList() {
  const list = document.getElementById('bulkScanList');
  const empty = document.getElementById('bulkScanEmpty');
  if (!bulkScanItems.length) {
    list.innerHTML = '';
    empty.style.display = '';
    document.getElementById('bulkApplyBtn').disabled = true;
    document.getElementById('bulkScanCount').textContent = '0';
    return;
  }
  empty.style.display = 'none';
  document.getElementById('bulkApplyBtn').disabled = false;

  list.innerHTML = bulkScanItems.map((item, idx) => `
    <div class="bulk-item-row">
      <span class="text-dark-400">${idx + 1}</span>
      <span class="font-mono text-xs text-brand-400 truncate">${escapeHtml(item.barcode)}</span>
      <span class="text-xs truncate ${item.name === 'غير موجود' ? 'text-red-400' : ''}">${escapeHtml(item.name)}</span>
      <input type="number" class="bulk-qty-input" value="${item.qty}" min="1"
        onchange="updateBulkQty(${idx}, this.value)">
      <button onclick="removeBulkItem(${idx})" class="text-dark-400 hover:text-red-400 transition text-xs">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
  `).join('');
}

function updateBulkQty(idx, val) {
  const qty = parseInt(val) || 1;
  bulkScanItems[idx].qty = Math.max(1, qty);
  document.getElementById('bulkScanCount').textContent = bulkScanItems.reduce((s, i) => s + i.qty, 0);
}

function removeBulkItem(idx) {
  bulkScanItems.splice(idx, 1);
  refreshBulkList();
  document.getElementById('bulkScanCount').textContent = bulkScanItems.reduce((s, i) => s + i.qty, 0);
}

function clearBulkList() {
  bulkScanItems = [];
  bulkLastScanTime = {};
  refreshBulkList();
}

function applyBulkScans() {
  if (!bulkScanItems.length) return;
  let found = 0, notFound = 0;
  bulkScanItems.forEach(scan => {
    const lower = scan.barcode.toLowerCase();
    let idx = inventoryDB.findIndex(i => i.barcodeLower === lower);
    if (idx < 0) idx = inventoryDB.findIndex(i => i.itemCode && i.itemCode.toLowerCase() === lower);
    if (idx >= 0) {
      inventoryDB[idx].actualQty += scan.qty;
      inventoryDB[idx].scanned = true;
      inventoryDB[idx].timestamp = getNow();
      addToScanLog(inventoryDB[idx], scan.qty);
      found++;
    } else {
      notFound++;
    }
  });
  stopBulkCamera();
  closeModal('batchModal');
  showToast(`تم تطبيق ${found} صنف${notFound ? ` — ${notFound} غير موجود` : ''}`, found > 0 ? 'success' : 'warning');
  clearBulkList();
  updateStats();
  renderCurrentTable();
}

function escapeHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* ========================================================
   صوت Beep (AudioContext)
   ======================================================== */
function playBeep(freq = 1100, duration = 0.07) {
  if (!soundEnabled) return;
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain);
    gain.connect(ctx.destination);
    osc.frequency.value = freq;
    osc.type = 'square';
    gain.gain.setValueAtTime(0.15, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + duration);
    osc.start(ctx.currentTime);
    osc.stop(ctx.currentTime + duration);
    setTimeout(() => ctx.close(), 300);
  } catch (e) {}
}

/* ========================================================
   لصق متقدم
   ======================================================== */
function openAdvancedPasteModal() {
  openModal('advancedPasteModal');
  document.getElementById('advancedPasteText').value = '';
  document.getElementById('pasteAdvPreviewArea').classList.add('hidden');
  document.getElementById('pasteAdvHasHeader').checked = false;
  setTimeout(() => document.getElementById('advancedPasteText').focus(), 100);
}

function getAdvDelimiter() {
  const v = document.querySelector('input[name="pasteAdvDelim"]:checked').value;
  if (v === 'tab') return '\t';
  if (v === 'comma') return ',';
  if (v === 'semi') return ';';
  return 'auto';
}

function autoDetectDelimiter(text) {
  const sample = text.split(/\r?\n/).slice(0, 5).join('\n');
  const t = (sample.match(/\t/g)||[]).length;
  const c = (sample.match(/,/g)||[]).length;
  const s = (sample.match(/;/g)||[]).length;
  if (t >= c && t >= s) return '\t';
  return c >= s ? ',' : ';';
}

function parseAdvRows(text, delim, hasHeader) {
  const HEADER_KW = ['barcode','باركود','qty','quantity','كمية','name','اسم','notes','ملاحظات'];
  const lines = text.split(/\r?\n/).map(l=>l.trim()).filter(l=>l.length > 0);
  if (!lines.length) return [];
  let startIdx = 0;
  if (hasHeader) { startIdx = 1; }
  else {
    const first = lines[0].toLowerCase();
    if (HEADER_KW.some(kw => first.includes(kw))) startIdx = 1;
  }
  return lines.slice(startIdx).map(line => {
    const parts = line.split(delim).map(p => p.trim());
    if (!parts[0] || parts[0].length < 2) return null;
    const barcode = parts[0];
    let qty = 1, notes = '', name = '';
    if (parts.length === 1) { qty = 1; }
    else if (parts.length === 2) { qty = parseFloat(parts[1]) || 1; }
    else if (parts.length === 3) {
      const q3 = parseFloat(parts[2]);
      if (!isNaN(q3)) { name = parts[1]; qty = q3; }
      else { qty = parseFloat(parts[1]) || 1; notes = parts[2]; }
    } else {
      name = parts[1]; qty = parseFloat(parts[2]) || 1; notes = parts.slice(3).join(' ');
    }
    return { barcode, qty, notes: notes.substring(0, 500), name };
  }).filter(Boolean);
}

function showPastePreview() {
  const text = document.getElementById('advancedPasteText').value.trim();
  if (!text) { showToast('الصق البيانات أولاً', 'warning'); return; }
  let delim = getAdvDelimiter();
  if (delim === 'auto') delim = autoDetectDelimiter(text);
  const rows = parseAdvRows(text, delim, document.getElementById('pasteAdvHasHeader').checked);
  if (!rows.length) { showToast('لا توجد بيانات صالحة', 'error'); return; }
  const tbody = document.getElementById('pasteAdvPreviewBody');
  tbody.innerHTML = rows.slice(0, 5).map((row, i) => {
    const found = inventoryDB.some(item => item.barcodeLower === row.barcode.toLowerCase());
    return `<tr>
      <td class="text-xs text-dark-400">${i+1}</td>
      <td class="font-mono text-xs">${row.barcode}</td>
      <td class="text-center">${row.qty}</td>
      <td class="text-xs text-dark-400">${row.notes||'-'}</td>
      <td>${found ? '<span class="text-green-400 font-semibold">✓ موجود</span>' : '<span class="text-red-400 font-semibold">✗ غير موجود</span>'}</td>
    </tr>`;
  }).join('') + (rows.length > 5 ? `<tr><td colspan="5" class="text-center text-xs text-dark-400 py-2">...و ${rows.length-5} صف آخر</td></tr>` : '');
  document.getElementById('pasteAdvPreviewArea').classList.remove('hidden');
}

function processAdvancedPaste() {
  const text = document.getElementById('advancedPasteText').value.trim();
  if (!text) { showToast('الصق البيانات أولاً', 'warning'); return; }
  let delim = getAdvDelimiter();
  if (delim === 'auto') delim = autoDetectDelimiter(text);
  const rows = parseAdvRows(text, delim, document.getElementById('pasteAdvHasHeader').checked);
  if (!rows.length) { showToast('لا توجد بيانات صالحة', 'error'); return; }
  const grouped = {};
  rows.forEach(row => {
    const key = row.barcode.toLowerCase();
    if (grouped[key]) { grouped[key].qty += row.qty; }
    else { grouped[key] = { ...row }; }
  });
  let updated = 0;
  const notFound = [];
  for (const [key, item] of Object.entries(grouped)) {
    let idx = inventoryDB.findIndex(i => i.barcodeLower === key);
    if (idx < 0) idx = inventoryDB.findIndex(i => i.itemCode && i.itemCode.toLowerCase() === key);
    if (idx >= 0) {
      inventoryDB[idx].actualQty += item.qty;
      inventoryDB[idx].scanned = true;
      inventoryDB[idx].timestamp = getNow();
      if (item.notes) inventoryDB[idx].notes = item.notes;
      addToScanLog(inventoryDB[idx], item.qty);
      updated++;
    } else { notFound.push(item); }
  }
  closeModal('advancedPasteModal');
  showToast(`تم تحديث ${updated} صنف${notFound.length ? ` — ${notFound.length} غير موجود` : ''}`, updated > 0 ? 'success' : 'warning');
  updateStats(); renderCurrentTable();
}

