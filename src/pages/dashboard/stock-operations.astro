   ======================================================== */
function handleSingleScan() {
  const input = document.getElementById('scanInput');
  const raw = input.value.trim();
  if (!raw) { showToast('أدخل الباركود أولاً', 'warning'); return; }
  input.value = '';
  input.focus();
  openScanDetailModal(raw);
}

/* ✅ الحزمة الثالثة: openScanDetailModal محدّثة */
function openScanDetailModal(barcode) {
  activeScanBarcode = barcode;
  const lower = barcode.toLowerCase();
  let item = inventoryDB.find(i => i.barcodeLower === lower);
  if (!item) item = inventoryDB.find(i => i.itemCode && i.itemCode.toLowerCase() === lower);
  activeScanIsNew = !item;

  const cfg = getOperationConfig(operationType);

  document.getElementById('scanItemName').textContent     = item ? (item.name || '—') : 'صنف غير موجود';
  document.getElementById('scanItemBarcode').textContent  = barcode;
  document.getElementById('scanItemCode').textContent     = item ? (item.itemCode || '—') : '—';
  document.getElementById('scanItemCat').textContent      = item ? (item.category || '—') : '—';
  document.getElementById('scanItemShade').textContent    = item ? (item.shade || '—') : '—';
  document.getElementById('scanItemUnit').textContent     = item ? (item.unit || '—') : '—';
  document.getElementById('scanItemSysQty').textContent   = item ? formatNum(item.systemQty) : '—';
  document.getElementById('scanItemPrevQty').textContent  = item ? formatNum(item.actualQty) : '—';

  // إخفاء/إظهار الكمية الدفترية
  const sysRow = document.getElementById('scanSysQtyRow');
  if (sysRow) sysRow.style.display = cfg.showSysQty ? '' : 'none';

  // تسمية الكمية
  document.getElementById('scanQtyLabel').textContent = cfg.qtyLabel;

  const card = document.getElementById('scanItemCard');
  card.classList.toggle('found', !!item);
  card.classList.toggle('not-found', !item);
  document.getElementById('scanNewItemWarning').classList.toggle('hidden', !!item);
  document.getElementById('scanDeleteBtn').classList.toggle('hidden', !item || !item.scanned);
  document.getElementById('scanQtyInput').value = '1';
  document.getElementById('scanNotesInput').value = item ? (item.notes || '') : '';
  document.getElementById('scanPriceInput').value = item ? (item.unitPrice || '') : '';
  document.getElementById('scanOverstockWarning').classList.add('hidden');

  // رسم الحقول الإضافية ديناميكياً
  const extraContainer = document.getElementById('operationExtraFields');
  extraContainer.innerHTML = '';
  if (cfg.extraFields && cfg.extraFields.length > 0) {
    cfg.extraFields.forEach(field => {
      const div = document.createElement('div');
      const reqMark = field.required ? '<span class="text-red-400">*</span>' : '';
      if (field.type === 'select') {
        div.innerHTML = `
          <label class="input-label">${field.label} ${reqMark}</label>
          <select id="${field.id}" class="input-field">
            <option value="">-- اختر --</option>
            ${(field.options || []).map(o => `<option value="${o}">${o}</option>`).join('')}
          </select>`;
      } else {
        div.innerHTML = `
          <label class="input-label">${field.label} ${reqMark}</label>
          <input type="text" id="${field.id}" class="input-field" placeholder="${field.placeholder || ''}">`;
      }
      extraContainer.appendChild(div);
    });
  }

  // تحذير تجاوز الرصيد للصرف
  if (cfg.overstockCheck && item) {
    document.getElementById('scanQtyInput').addEventListener('input', function() {
      const qty = parseFloat(this.value) || 0;
      document.getElementById('scanOverstockWarning').classList.toggle('hidden', qty <= item.systemQty);
    }, { once: false });
  }

  document.getElementById('scanDetailTitle').innerHTML =
    `<i class="fa-solid fa-barcode ml-2 text-brand-400"></i>${item ? 'تفاصيل الصنف' : 'باركود جديد'}`;

  openModal('scanDetailModal');
  setTimeout(() => document.getElementById('scanQtyInput').select(), 100);
}

function closeScanDetail() {
  closeModal('scanDetailModal');
  activeScanBarcode = '';
  activeScanIsNew = false;
  document.getElementById('scanInput').focus();
}

/* ✅ الحزمة الثالثة: confirmScanEntry — يحفظ operationMeta */
function confirmScanEntry() {
  const qty = parseFloat(document.getElementById('scanQtyInput').value);
  if (isNaN(qty) || qty < 0) { showToast('الكمية يجب أن تكون عدداً صحيحاً موجباً', 'warning'); return; }
  const notes = document.getElementById('scanNotesInput').value.trim();
  const price = parseFloat(document.getElementById('scanPriceInput').value) || 0;
  const lower = activeScanBarcode.toLowerCase();

  const cfg = getOperationConfig(operationType);

  // التحقق من الحقول الإجبارية
  for (const field of (cfg.extraFields || [])) {
    if (field.required) {
      const el = document.getElementById(field.id);
      if (el && !el.value.trim()) {
        showToast(`حقل "${field.label}" مطلوب`, 'warning');
        el.focus();
        return;
      }
    }
  }

  // جمع بيانات الحقول الإضافية
  const operationMeta = {};
  for (const field of (cfg.extraFields || [])) {
    const el = document.getElementById(field.id);
    if (el) operationMeta[field.id] = el.value.trim();
  }

  let idx = inventoryDB.findIndex(i => i.barcodeLower === lower);
  if (idx < 0) idx = inventoryDB.findIndex(i => i.itemCode && i.itemCode.toLowerCase() === lower);

  if (idx >= 0) {
    const item = inventoryDB[idx];
    item.actualQty += qty;
    item.scanned = true;
    item.timestamp = getNow();
    if (notes) item.notes = notes;
    if (price > 0) item.unitPrice = price;
    item.operationMeta = { ...(item.operationMeta || {}), ...operationMeta };
    addToScanLog(item, qty);
    showToast(`✓ ${item.name || activeScanBarcode} — كمية: ${qty}`, 'success');
  } else {
    const newItem = {
      id: `manual-${Date.now()}`,
      barcode: activeScanBarcode, barcodeLower: lower,
      itemCode: '', name: activeScanBarcode,
      shade: '', category: 'غير مصنف', subcategory: '',
      systemQty: 0, unit: '', unitPrice: price, notes,
      actualQty: qty, scanned: true, timestamp: getNow(),
      source: 'مسح يدوي', isManual: true,
      operationType: operationType, operationMeta
    };
    inventoryDB.push(newItem);
    addToScanLog(newItem, qty);
    showToast(`أُضيف صنف جديد: ${activeScanBarcode}`, 'info');
  }

  closeModal('scanDetailModal');
  updateStats();
  updateProgressBar();
  renderCurrentTable();
  saveSessionDebounced();
  
  // مؤشر صوتي عند المسح
  if (soundEnabled) {
    if (idx >= 0) {
      // صنف موجود - نغمة نجاح
      playBeep(880, 100);
    } else {
      // صنف جديد - نغمة تحذير
      playBeep(440, 200);
    }
  }
  
  document.getElementById('scanInput').focus();
}

function deleteScanEntry() {
  if (!confirm('هل تريد إلغاء مسح هذا الصنف وإعادة الكمية الفعلية إلى 0؟')) return;
  const lower = activeScanBarcode.toLowerCase();
  const idx = inventoryDB.findIndex(i => i.barcodeLower === lower);
  if (idx >= 0) {
    inventoryDB[idx].actualQty = 0;
    inventoryDB[idx].scanned = false;
    inventoryDB[idx].timestamp = null;
    showToast('تم إلغاء المسح للصنف', 'info');
  }
  closeModal('scanDetailModal');
  updateStats();
  updateProgressBar();      // ✅ تصحيح: تحديث شريط التقدم فوراً
  renderCurrentTable();
  saveSessionDebounced();   // ✅ تصحيح: حفظ الإلغاء حتى لا يعود بعد إعادة الفتح
}

