  txt.style.color = colors[state] || '#8899a6';
  txt.textContent = text || '';
};

function switchToDashboard() {
  document.getElementById('importScreen').classList.add('hidden');
  document.getElementById('dashboardScreen').classList.remove('hidden');

  /* ☁️ بدء عملية سحابية لهذه الجلسة (مرّة واحدة) */
  if (window.__bzCloud && !window.__bzCloud.opId) {
    window.__bzCloud.startOperation(operationType);
  }

  document.getElementById('currentOperationType').textContent = getOperationTypeIcon(operationType) + ' ' + operationType;
  applyOperationConfigToUI();
  
  // إظهار زر الإعدادات للمسؤولين فقط
  if (isAdminLoggedIn) {
    document.getElementById('adminSettingsBtn').classList.remove('hidden');
  }
  
  updateStats();
  renderCurrentTable();
  setTimeout(() => document.getElementById('scanInput').focus(), 100);
}

