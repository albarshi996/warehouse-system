function updateProgressBar() {
  const total = inventoryDB.length;
  const scanned = inventoryDB.filter(i => i.scanned).length;
  const pct = total > 0 ? (scanned / total) * 100 : 0;
  
  const fill = document.getElementById('progressBarFill');
  const text = document.getElementById('progressPctText');
  
  fill.style.width = `${pct}%`;
  text.textContent = `${pct.toFixed(1)}%`;
  
  // تحديث اللون حسب النسبة
  fill.classList.remove('low', 'medium', 'high', 'excellent');
  if (pct < 25) fill.classList.add('low');
  else if (pct < 50) fill.classList.add('medium');
  else if (pct < 75) fill.classList.add('high');
  else fill.classList.add('excellent');
}

