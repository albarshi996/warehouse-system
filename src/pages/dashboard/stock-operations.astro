---
/**
 * العمليات المخزنية — الجرد الذكي Pro (مُرحَّل إلى داخل البوابة).
 *
 * الأصل: public/عمليات-مخزنية.html (ملف مستقل بمكتبات CDN ودخول أدمن وهمي).
 * ما تغيّر هنا فقط:
 *   1. محمي بحارس الدخول الحقيقي (AuthGate) — لا يفتح إلا لمستخدم مسجّل.
 *   2. صلاحية الأدمن تُشتق من دور Firebase الحقيقي (لا كلمة سر في الكود).
 *   3. Tailwind و XLSX من بناء المشروع محليًّا (لا CDN) — يعمل مع ضعف الإنترنت.
 * منطق التطبيق نفسه لم يُمسّ (نقل أمين).
 */
import '../../styles/global.css';
import AuthGate from '../../components/brandzo-erp/access/AuthGate.jsx';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
---

<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>العمليات المخزنية — Brandzo Hub</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
<style is:global>
:root{
  --bg:#0f1419; --surface:#1a2332; --surface-2:#243044;
  --primary:#c41e3a; --primary-light:#e85d68;
  --accent:#DAAA3C; --text:#e7e9ea; --text-muted:#8899a6;
  --border:#2f3b4a; --danger:#ef4444; --success:#22c55e;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Cairo',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden}
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:var(--surface)}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:var(--primary)}

.import-bg{
  background:linear-gradient(135deg,#090d12 0%,#0f1f2e 30%,#0d2626 60%,#0f1419 100%);
  background-size:400% 400%;
  animation:gradShift 12s ease infinite;
  min-height:100vh
}
@keyframes gradShift{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}

.glass-card{
  background:rgba(26,35,50,.88);
  backdrop-filter:blur(20px);
  border:1px solid rgba(196, 30, 58,.18);
  box-shadow:0 25px 60px rgba(0,0,0,.5),inset 0 1px 0 rgba(255,255,255,.04)
}
.drop-zone{border:2px dashed var(--border);transition:all .3s;position:relative;overflow:hidden}
.drop-zone:hover,.drop-zone.drag-over{border-color:var(--primary);background:rgba(196, 30, 58,.06)}

.btn{
  display:inline-flex;align-items:center;gap:8px;
  padding:10px 20px;border-radius:8px;font-weight:600;
  font-family:'Cairo',sans-serif;font-size:14px;
  cursor:pointer;border:none;transition:all .2s;position:relative;overflow:hidden
}
.btn::after{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,rgba(255,255,255,.08),transparent);pointer-events:none}
.btn:active{transform:scale(.97)}
.btn-primary{background:var(--primary);color:#fff}
.btn-primary:hover{background:var(--primary-light);box-shadow:0 4px 20px rgba(196, 30, 58,.3)}
.btn-accent{background:var(--accent);color:#1a1a1a}
.btn-accent:hover{background:#e6c04f;box-shadow:0 4px 20px rgba(249,168,37,.3)}
.btn-info{background:#0288d1;color:#fff}
.btn-info:hover{background:#039be5}
.btn-success{background:#16a34a;color:#fff}
.btn-success:hover{background:#22c55e}
.btn-danger{background:var(--danger);color:#fff}
.btn-danger:hover{background:#f87171}
.btn-ghost{background:transparent;color:var(--text-muted);border:1px solid var(--border)}
.btn-ghost:hover{background:var(--surface-2);color:var(--text);border-color:var(--primary)}
.btn-sm{padding:6px 14px;font-size:13px}
.btn:disabled{opacity:.5;cursor:not-allowed;transform:none!important}

.toast-container{position:fixed;top:20px;left:20px;z-index:9999;display:flex;flex-direction:column;gap:8px}
.toast{
  padding:12px 20px;border-radius:10px;font-size:14px;font-weight:500;
  display:flex;align-items:center;gap:10px;min-width:300px;max-width:460px;
  animation:toastIn .35s ease;box-shadow:0 10px 30px rgba(0,0,0,.4);
  border:1px solid rgba(255,255,255,.06)
}
.toast.out{animation:toastOut .3s ease forwards}
.toast-success{background:#064e3b;color:#a7f3d0;border-color:#065f46}
.toast-error{background:#450a0a;color:#fca5a5;border-color:#7f1d1d}
.toast-warning{background:#451a03;color:#fde68a;border-color:#78350f}
.toast-info{background:#0c2d48;color:#7dd3fc;border-color:#0c4a6e}
@keyframes toastIn{from{opacity:0;transform:translateX(-40px) scale(.95)}to{opacity:1;transform:translateX(0) scale(1)}}
@keyframes toastOut{to{opacity:0;transform:translateX(-40px) scale(.95)}}

.modal-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(4px);
  z-index:1000;display:none;align-items:center;justify-content:center;padding:20px
}
.modal-overlay.active{display:flex;animation:fadeIn .2s ease}
.modal-box{
  background:var(--surface);border:1px solid var(--border);border-radius:16px;
  width:100%;max-width:640px;max-height:92vh;overflow-y:auto;
  box-shadow:0 30px 80px rgba(0,0,0,.5);animation:modalIn .3s ease
}
.modal-box.wide{max-width:860px}
.modal-box.narrow{max-width:480px}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes modalIn{from{opacity:0;transform:scale(.95) translateY(10px)}to{opacity:1;transform:scale(1) translateY(0)}}

.data-table{width:100%;border-collapse:separate;border-spacing:0;font-size:13px}
.data-table thead th{
  background:var(--surface-2);color:var(--text-muted);font-weight:700;
  padding:10px 12px;text-align:right;position:sticky;top:0;z-index:10;
  border-bottom:2px solid var(--primary);font-size:12px;white-space:nowrap
}
.data-table tbody tr{transition:background .15s}
.data-table tbody tr:hover{background:rgba(196, 30, 58,.06)}
.data-table tbody tr.row-scanned{background:rgba(196, 30, 58,.04)}
.data-table tbody tr.row-diff{background:rgba(249,168,37,.04)}
.data-table tbody tr.row-damaged{background:rgba(249,115,22,.07)}
.data-table tbody td{padding:8px 12px;border-bottom:1px solid rgba(47,59,74,.5);vertical-align:middle;white-space:nowrap}
.data-table tbody td.wrap-cell{white-space:normal;min-width:150px}
.diff-pos{color:#f59e0b;font-weight:700}
.diff-neg{color:#ef4444;font-weight:700}
.diff-zero{color:#22c55e;font-weight:700}

/* Tooltip للصنف */
.item-tooltip{
  position:absolute;
  z-index:50;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:8px;
  padding:8px 12px;
  min-width:180px;
  box-shadow:0 10px 30px rgba(0,0,0,.4);
  pointer-events:none;
  opacity:0;
  transition:opacity .2s;
  font-size:12px
}
.item-tooltip.visible{opacity:1}
.item-tooltip-row{display:flex;justify-content:space-between;margin-bottom:4px}
.item-tooltip-row:last-child{margin-bottom:0}
.item-tooltip-label{color:var(--text-muted)}
.item-tooltip-value{font-weight:600;color:var(--text)}

.stat-pill{display:flex;flex-direction:column;align-items:center;padding:8px 16px;background:var(--surface-2);border:1px solid var(--border);border-radius:10px;min-width:90px;transition:all .2s}
.stat-pill:hover{border-color:var(--primary);transform:translateY(-1px)}
.stat-pill .stat-val{font-size:20px;font-weight:900;line-height:1.1}
.stat-pill .stat-lbl{font-size:11px;color:var(--text-muted);font-weight:500}

.tab-btn{padding:8px 18px;border-radius:8px 8px 0 0;font-weight:600;font-size:13px;cursor:pointer;border:1px solid transparent;border-bottom:none;background:transparent;color:var(--text-muted);transition:all .2s;font-family:'Cairo',sans-serif}
.tab-btn.active{background:var(--surface-2);color:var(--primary-light);border-color:var(--border)}
.tab-btn:hover:not(.active){color:var(--text);background:rgba(36,48,68,.5)}

.modal-tab-btn{padding:6px 16px;border-radius:6px;font-weight:600;font-size:12px;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--text-muted);transition:all .2s;font-family:'Cairo',sans-serif}
.modal-tab-btn.active{background:var(--primary);color:#fff;border-color:var(--primary)}
.modal-tab-btn:hover:not(.active){background:var(--surface-2);color:var(--text)}

.input-field{background:var(--surface-2);border:1px solid var(--border);border-radius:8px;padding:10px 14px;color:var(--text);font-family:'Cairo',sans-serif;font-size:14px;transition:all .2s;outline:none;width:100%}
.input-field:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(196, 30, 58,.15)}
.input-field::placeholder{color:var(--text-muted);opacity:.6}
textarea.input-field{resize:vertical;min-height:100px;line-height:1.6}
.input-label{display:block;font-size:12px;font-weight:600;color:var(--text-muted);margin-bottom:6px}

.progress-bar{height:4px;background:var(--surface-2);border-radius:2px;overflow:hidden}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--primary),var(--accent));border-radius:2px;transition:width .3s}
.progress-fill.low{background:linear-gradient(90deg,#ef4444,#f97316)}
.progress-fill.medium{background:linear-gradient(90deg,#f97316,#eab308)}
.progress-fill.high{background:linear-gradient(90deg,#eab308,#22c55e)}
.progress-fill.excellent{background:linear-gradient(90deg,#22c55e,#c41e3a)}
.spinner{width:20px;height:20px;border:2.5px solid rgba(255,255,255,.2);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite;display:inline-block}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes pulseGlow{0%,100%{box-shadow:0 0 0 0 rgba(196, 30, 58,.3)}50%{box-shadow:0 0 0 8px rgba(196, 30, 58,0)}}
.pulse-glow{animation:pulseGlow 2s ease infinite}

.scan-card{background:var(--surface-2);border:1px solid var(--border);border-radius:12px;padding:16px}
.scan-card.found{border-color:rgba(196, 30, 58,.4)}
.scan-card.not-found{border-color:rgba(239,68,68,.4)}

#printContainer{display:none}

/* كاميرا */
.camera-viewfinder{position:relative;border-radius:12px;overflow:hidden;background:#000;aspect-ratio:4/3}
.camera-viewfinder video{width:100%;height:100%;object-fit:cover;display:block}
.camera-flash-overlay{position:absolute;inset:0;background:rgba(0,255,150,0);pointer-events:none;transition:background .15s}
.camera-flash-overlay.flash{background:rgba(0,255,150,.45)}
.camera-target-box{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none}
.camera-target-box::after{content:'';display:block;width:220px;height:130px;border:2.5px solid rgba(0,255,150,.7);border-radius:10px;box-shadow:0 0 0 9999px rgba(0,0,0,.28)}
.camera-status-badge{position:absolute;bottom:10px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,.65);color:#fff;font-size:11px;padding:4px 14px;border-radius:20px;font-family:'Cairo',sans-serif;white-space:nowrap}

/* bulk scan list */
.bulk-item-row{display:grid;grid-template-columns:30px 1fr 1fr 70px 32px;align-items:center;gap:6px;padding:5px 8px;border-bottom:1px solid rgba(47,59,74,.4);font-size:12px}
.bulk-item-row:hover{background:rgba(196, 30, 58,.05)}
.bulk-qty-input{background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:2px 6px;color:var(--text);font-family:'Cairo',sans-serif;font-size:12px;width:100%;text-align:center}

@media print{
  @page{size:A4 portrait;margin:15mm 12mm}
  body{font-family:'Cairo',sans-serif!important;font-size:10pt;color:#000;background:#fff!important}
  #importScreen,#dashboardScreen,.toast-container,.modal-overlay,.print-no-print{display:none!important}
  #printContainer{display:block!important}
  .print-header{text-align:center;border-bottom:2.5px solid #000;padding-bottom:12px;margin-bottom:18px}
  .print-header h1{font-size:17pt;font-weight:900;color:#000}
  .print-header .print-company{font-size:11pt;font-weight:700;margin-bottom:2px}
  .print-header .print-meta{font-size:8pt;color:#555;margin-top:5px}
  .print-summary{display:flex;gap:6px;margin-bottom:18px}
  .print-summary-card{flex:1;border:1.5px solid #bbb;border-radius:5px;padding:8px 4px;text-align:center}
  .ps-label{font-size:7pt;color:#666;text-transform:uppercase;font-weight:600}
  .ps-value{font-size:15pt;font-weight:900;color:#000}
  .print-section-title{font-size:11pt;font-weight:800;border-right:4px solid #000;padding-right:8px;margin:18px 0 8px;color:#000}
  .print-table{width:100%;border-collapse:collapse;font-size:8pt;margin-bottom:12px}
  .print-table th{background:#1a1a1a;color:#fff;padding:5px 6px;text-align:right;font-weight:700;font-size:7pt}
  .print-table td{padding:4px 6px;border-bottom:.5px solid #ccc;vertical-align:middle}
  .print-table tr:nth-child(even){background:#f5f5f5}
  .print-diff-pos{color:#b45309;font-weight:700}
  .print-diff-neg{color:#b91c1c;font-weight:700}
  .print-diff-zero{color:#15803d;font-weight:700}
  .print-net{font-size:9.5pt;font-weight:700;margin-bottom:14px;padding:6px 10px;background:#f9f9f9;border:1px solid #ddd;border-radius:4px}
  .print-footer{position:fixed;bottom:0;width:100%;border-top:1px solid #ccc;padding-top:5px;font-size:7pt;color:#999;display:flex;justify-content:space-between}
  .signature-block{margin-top:40px;display:flex;gap:60px}
  .signature-line{border-top:1px solid #000;width:200px;margin-top:32px;text-align:center;font-size:8pt;padding-top:4px;color:#333}
  .page-break{page-break-after:always}
  .avoid-break{page-break-inside:avoid}
}

@media(max-width:768px){
  .stat-pill{min-width:70px;padding:6px 10px}
  .stat-pill .stat-val{font-size:16px}
  .data-table{font-size:11px}
  .data-table thead th,.data-table tbody td{padding:6px 8px}
}
@media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important}}

/* ============================================================
   إضافات UI/UX غير تدميرية (Brandzo) — CSS فقط، لا يمس أي منطق
   ============================================================ */
/* أسماء دلالية بديلة تشير للمتغيرات القائمة (لا تُعيد تسمية أي متغير) */
:root{
  --brand-primary: var(--primary);
  --surface-card:  var(--surface);
}

/* شريط الملخص العائم — يظهر على الجوال فقط */
.bz-float-bar{
  position:fixed; bottom:20px; left:50%; transform:translateX(-50%);
  z-index:900; display:none; align-items:center; gap:10px;
  padding:10px 14px; border-radius:16px; max-width:calc(100vw - 24px);
  background:rgba(26,35,50,.85);
  -webkit-backdrop-filter:blur(20px) saturate(180%);
  backdrop-filter:blur(20px) saturate(180%);
  border:1px solid var(--border); box-shadow:0 10px 30px rgba(0,0,0,.45);
  font-family:'Cairo',sans-serif;
}
.bz-float-stat{display:flex;flex-direction:column;align-items:center;line-height:1.15;min-width:52px}
.bz-float-stat .v{font-size:16px;font-weight:900;color:var(--text)}
.bz-float-stat .l{font-size:10px;color:var(--text-muted);font-weight:600}
.bz-float-sep{width:1px;height:26px;background:var(--border)}
.bz-float-save{
  display:flex;align-items:center;gap:6px;border:none;cursor:pointer;
  background:var(--brand-primary);color:#fff;font-family:'Cairo',sans-serif;
  font-weight:700;font-size:13px;padding:9px 14px;border-radius:12px;transition:filter .2s
}
.bz-float-save:active{filter:brightness(1.12)}

@media (max-width:767px){
  /* إصلاح تكبير iOS التلقائي أثناء المسح — يستثني الحقول المدمجة */
  input:not(.bulk-qty-input), select, textarea, [type="search"]{ font-size:16px !important; }
  /* إظهار الشريط العائم على الجوال */
  .bz-float-bar{display:flex}
  /* هامش سفلي آمن حتى لا يحجب الشريط أزرار الترقيم */
  #dashboardScreen main{padding-bottom:96px}
}
</style>
</head>
<body>
<!-- حارس الدخول: طبقة تغطية قبل الترطيب + تحويل غير المسجّل إلى /login -->
<div id="bz-auth-overlay" style="position:fixed;inset:0;z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;background:#0f1419;color:#e7e9ea;font-family:'Cairo',sans-serif">
  <div style="width:48px;height:48px;border:4px solid rgba(255,255,255,.15);border-top-color:#DAAA3C;border-radius:50%;animation:bzspin .8s linear infinite"></div>
  <span style="font-size:.9rem;opacity:.8">جارٍ التحقّق من الدخول...</span>
</div>
<style is:global>@keyframes bzspin{to{transform:rotate(360deg)}}

/* 🐛 إصلاح ترحيل: global.css يفرض `*,*::before{font-family:'Cairo' !important}`،
   وهو يسحق خطّ أيقونات FontAwesome (تُرسم عبر ::before) فتظهر مربّعات فارغة.
   نستثني أصناف الأيقونات صراحةً ونُعيد لها خطّها. */
.fa, .fas, .fa-solid, .far, .fa-regular, .fal, .fa-light, .fad, .fa-duotone,
.fa::before, .fas::before, .fa-solid::before, .far::before, .fa-regular::before,
.fal::before, .fa-light::before, .fad::before, .fa-duotone::before {
  font-family: "Font Awesome 6 Free" !important;
}
.fab, .fa-brands, .fab::before, .fa-brands::before {
  font-family: "Font Awesome 6 Brands" !important;
}
</style>
<AuthGate client:load />

<!-- طريق العودة إلى البوابة (الصفحة ملء الشاشة بلا سايدبار) -->
<a
  href={`${base}/dashboard`}
  style="position:fixed;top:10px;left:10px;z-index:60;display:inline-flex;align-items:center;gap:.4rem;background:rgba(26,35,50,.9);color:#e7e9ea;border:1px solid #2f3b4a;border-radius:8px;padding:.35rem .7rem;font-size:.75rem;font-weight:700;text-decoration:none;backdrop-filter:blur(6px)"
  title="العودة إلى لوحة التحكم"
>← البوابة</a>

<!-- ☁️ مؤشّر حالة السحابة: يُطمئن الموظّف أن عمله محفوظ (أو يُنذره فوراً) -->
<div
  id="bzCloudStatus"
  style="position:fixed;top:10px;left:96px;z-index:60;display:none;align-items:center;gap:.4rem;background:rgba(26,35,50,.9);border:1px solid #2f3b4a;border-radius:8px;padding:.35rem .7rem;font-size:.72rem;font-weight:700;backdrop-filter:blur(6px)"
>
  <span id="bzCloudDot" style="width:8px;height:8px;border-radius:50%;background:#8899a6"></span>
  <span id="bzCloudText" style="color:#8899a6">…</span>
</div>
<div class="toast-container" id="toastContainer"></div>
<div class="item-tooltip" id="itemTooltip"></div>

<!-- ===================== شاشة الاستيراد ===================== -->
<div id="importScreen" class="import-bg flex items-center justify-center p-4">
  <div class="glass-card rounded-2xl p-8 w-full max-w-lg">
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-brand-500/10 border border-brand-500/20 mb-4">
        <i class="fa-solid fa-boxes-stacked text-2xl text-brand-400"></i>
      </div>
      <h1 class="text-2xl font-black text-white">مقترح الجرد الذكي Pro</h1>
      <p class="text-sm text-dark-400 mt-1">Smart Inventory Interactive Proposal — Professional Edition</p>
      <div class="mt-4 pt-4 border-t border-dark-600">
        <p class="text-lg font-bold text-brand-400">Brandzo Hub</p>
        <p class="text-sm font-semibold text-gold-500 mt-1">إدارة المستودعات</p>
        <p class="text-xs text-dark-400 mt-1">(محمد البرشي - رمزي باش)</p>
      </div>
    </div>

    <div class="mb-5">
      <label class="input-label text-center">نوع العملية</label>
      <select id="operationTypeSelect" class="input-field text-center font-semibold" onchange="changeOperationType()">
        <option value="جرد">📋 جرد المخزون</option>
        <option value="استلام">📥 استلام بضاعة</option>
        <option value="صرف">📤 صرف بضاعة</option>
        <option value="إضافة أصناف">➕ إضافة أصناف جديدة</option>
        <option value="تالف">⚠️ تالف</option>
        <option value="مرتجع">↩️ مرتجع</option>
      </select>
    </div>

    <div id="dropZone" class="drop-zone rounded-xl p-8 text-center cursor-pointer mb-5">
      <input type="file" id="fileInput" accept=".xlsx,.xls" class="hidden" multiple>
      <div class="mb-3"><i class="fa-solid fa-cloud-arrow-up text-4xl text-dark-400"></i></div>
      <p class="text-sm font-semibold text-dark-400 mb-1">اسحب ملفات Excel هنا</p>
