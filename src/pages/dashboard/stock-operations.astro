/* ========================================================
   اكتشاف الأعمدة — ذكي وشامل (بدون تعديل)
   ======================================================== */
const COLUMN_KEYWORDS = {
  barcode:['باركود','barcode','بارك','code_bar','bar code','ean','upc','رمز الباركود','كود الباركود','product id','item id'],
  itemCode:['كود الصنف','item code','sku','رمز الصنف','product code','item.number','item no','item_code','part no','part number','article','رقم الصنف'],
  name:['اسم الصنف','product name','اسم','name','product_name','المنتج','وصف','description','item name','الاسم','item description','عنوان'],
  shade:['الظل','اللون','shade','colour','color','لون','الظل/اللون','درجة اللون'],
  category:['التصنيف','category','فئة','قسم','division','القسم','group','مجموعة','brand','براند','ماركة'],
  subcategory:['التصنيف الفرعي','subcategory','sub_category','sub category','الفئة الفرعية','subgroup'],
  systemQty:['الكمية الدفترية','system qty','system quantity','الكمية','qty','quantity','كمية','الرصيد','balance','stock','الكميه','system_qty','qty_system','on hand','onhand','المخزون','رصيد'],
  unit:['الوحدة','unit','وحدة','uom','unit of measure'],
  unitPrice:['سعر الوحدة','unit price','السعر','price','سعر','unit_price','cost','التكلفة','تكلفة'],
  notes:['ملاحظات','notes','note','ملاحظة','remark','remarks','comment','تعليق']
};

function detectColumns(sheet) {
  const range = XLSX.utils.decode_range(sheet['!ref'] || 'A1');
  const maxHeaderSearch = Math.min(range.s.r + 9, range.e.r);
  const headerTexts = [];
  for (let r = range.s.r; r <= maxHeaderSearch; r++) {
    const rowTexts = [];
    for (let c = range.s.c; c <= range.e.c; c++) {
      const addr = XLSX.utils.encode_cell({ r, c });
      const cell = sheet[addr];
      rowTexts.push(cell ? String(cell.v).trim().toLowerCase() : '');
    }
    headerTexts.push({ texts: rowTexts, rowIndex: r });
  }
  let bestRow = { texts: [], rowIndex: range.s.r };
  let bestScore = -1;
  headerTexts.forEach(row => {
    let score = 0;
    row.texts.forEach(text => {
      for (const field of Object.keys(COLUMN_KEYWORDS)) {
        if (COLUMN_KEYWORDS[field].some(kw => text === kw.toLowerCase() || text.includes(kw.toLowerCase()))) score++;
      }
    });
    if (score > bestScore) { bestScore = score; bestRow = row; }
  });
  const mapping = {};
  bestRow.texts.forEach((text, c) => {
    if (!text) return;
    for (const [field, keywords] of Object.entries(COLUMN_KEYWORDS)) {
      if (mapping[field] != null) continue;
      if (keywords.some(kw => text === kw.toLowerCase() || text.includes(kw.toLowerCase()))) {
        mapping[field] = range.s.c + c;
        break;
      }
    }
  });
  return { mapping, headerRowIndex: bestRow.rowIndex, startRow: bestRow.rowIndex + 1, endRow: range.e.r, startCol: range.s.c };
}

/* ========================================================
   معالجة الملفات
   ======================================================== */
function handleFileSelect(files) {
  if (!files || files.length === 0) return;
  let processed = 0;
  const total = files.length;
  document.getElementById('importProgress').classList.remove('hidden');

  Array.from(files).forEach(file => {
    const reader = new FileReader();
    reader.onload = function(e) {
      try {
        const data = new Uint8Array(e.target.result);
        const workbook = XLSX.read(data, { type:'array', cellDates:true, cellText:false, dense:false });
        let addedCount = 0, updatedCount = 0;

        workbook.SheetNames.forEach(sheetName => {
          const sheet = workbook.Sheets[sheetName];
          if (!sheet || !sheet['!ref']) return;
          const { mapping, startRow, endRow } = detectColumns(sheet);
          const getVal = (r, field) => {
            if (mapping[field] == null) return '';
            const addr = XLSX.utils.encode_cell({ r, c: mapping[field] });
            const cell = sheet[addr];
            if (!cell) return '';
            if (cell.t === 'n') return cell.v;
            if (cell.t === 'd') return cell.v;
            return String(cell.v).trim();
          };
          const CHUNK = 5000;
          let r = startRow;
          function processChunk() {
            const chunkEnd = Math.min(r + CHUNK - 1, endRow);
            for (; r <= chunkEnd; r++) {
              const rawBarcode = String(getVal(r, 'barcode') || '').trim();
              if (!rawBarcode || rawBarcode.length < 2) continue;
              if (rawBarcode.toLowerCase() === 'nan' || rawBarcode === '0') continue;
              const barcodeLower = rawBarcode.toLowerCase();
              const rawName = String(getVal(r, 'name') || '').trim();
              let systemQty = 0;
              const rawQty = getVal(r, 'systemQty');
              if (rawQty !== '') systemQty = parseFloat(rawQty) || 0;
              const existingIdx = inventoryDB.findIndex(item => item.barcodeLower === barcodeLower);
              if (existingIdx >= 0) {
                const ex = inventoryDB[existingIdx];
                if (!ex.name && rawName) ex.name = rawName;
                const shade = String(getVal(r, 'shade') || '').trim();
                const cat = String(getVal(r, 'category') || '').trim();
                const sub = String(getVal(r, 'subcategory') || '').trim();
                if (!ex.shade && shade) ex.shade = shade;
                if (!ex.category && cat) ex.category = cat;
                if (!ex.subcategory && sub) ex.subcategory = sub;
                if (systemQty > 0 && !ex.scanned) ex.systemQty = systemQty;
                ex.source = (ex.source ? ex.source + ', ' : '') + sheetName;
                updatedCount++;
              } else {
                const unitPrice = parseFloat(getVal(r, 'unitPrice')) || 0;
                inventoryDB.push({
                  id: `${Date.now()}-${Math.random().toString(36).slice(2)}`,
                  barcode: rawBarcode, barcodeLower,
                  itemCode: String(getVal(r, 'itemCode') || '').trim(),
                  name: rawName,
                  shade: String(getVal(r, 'shade') || '').trim(),
                  category: String(getVal(r, 'category') || '').trim(),
                  subcategory: String(getVal(r, 'subcategory') || '').trim(),
                  systemQty, unit: String(getVal(r, 'unit') || '').trim(),
                  unitPrice, notes: String(getVal(r, 'notes') || '').trim(),
                  actualQty: 0, scanned: false, timestamp: null,
                  source: sheetName, isManual: false,
                  operationType: operationType, operationMeta: {}
                });
                addedCount++;
              }
            }
            const rowsDone = r - startRow;
            const totalRows = endRow - startRow + 1;
            const filePct = totalRows > 0 ? rowsDone / totalRows : 1;
            const overallPct = Math.round(((processed + filePct) / total) * 100);
            document.getElementById('importProgressFill').style.width = overallPct + '%';
            document.getElementById('importProgressPct').textContent = overallPct + '%';
            document.getElementById('importProgressText').textContent =
              `${sheetName}: ${Math.min(r, endRow+1) - startRow} / ${totalRows} صف`;
            if (r <= endRow) { setTimeout(processChunk, 0); } else { fileFinished(); }
          }
          processChunk();
        });

        function fileFinished() {
          processed++;
          if (processed === total) {
            setTimeout(() => {
              document.getElementById('importProgress').classList.add('hidden');
              document.getElementById('importProgressFill').style.width = '0%';
              showToast(`تم استيراد ${inventoryDB.length.toLocaleString()} صنف بنجاح`, 'success');
              switchToDashboard();
            }, 400);
          }
        }
      } catch (err) {
        processed++;
        showToast(`خطأ في معالجة الملف: ${err.message}`, 'error');
        if (processed === total && inventoryDB.length > 0) switchToDashboard();
      }
    };
    reader.readAsArrayBuffer(file);
  });
}

/* ========================================================
   تحميل قالب الاستيراد
   ======================================================== */
function downloadTemplate() {
  try {
    const headers = ['الباركود','كود الصنف','اسم الصنف','الظل/اللون','التصنيف','التصنيف الفرعي','الكمية الدفترية','الوحدة','سعر الوحدة','ملاحظات'];
    const example = ['8059692040599','WNW-001','مثال — احذف هذا الصف','شفاف','ماكياج','أساس',10,'قطعة',15.5,'توضيحي'];
    const ws = XLSX.utils.aoa_to_sheet([headers, example]);
    ws['!cols'] = [{wch:18},{wch:13},{wch:38},{wch:20},{wch:22},{wch:22},{wch:15},{wch:11},{wch:13},{wch:28}];
    ws['!autofilter'] = { ref: XLSX.utils.encode_range({s:{r:0,c:0},e:{r:0,c:9}}) };
    headers.forEach((_, i) => {
      const addr = XLSX.utils.encode_cell({r:0, c:i});
      if (!ws[addr]) return;
      ws[addr].s = { font: { bold: true }, fill: { fgColor: { rgb: '004D40' } }, font: { color: { rgb: 'FFFFFF' }, bold: true } };
    });
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'قالب الجرد');
    const guide = XLSX.utils.aoa_to_sheet([
      ['تعليمات استخدام قالب مقترح الجرد الذكي Pro'],[''],
      ['1. الباركود (مطلوب)','أدخل الباركود أو أي معرّف فريد للصنف'],
      ['2. كود الصنف (اختياري)','كود داخلي أو SKU'],
      ['3. اسم الصنف (مطلوب)','الاسم الكامل للمنتج'],
      ['4. الظل/اللون (اختياري)','مثال: أحمر، بيج، شفاف'],
      ['5. التصنيف (اختياري)','مثال: ماكياج، عناية بالبشرة'],
      ['6. التصنيف الفرعي (اختياري)','مثال: أساس، كريم، حمرة'],
      ['7. الكمية الدفترية (اختياري)','الكمية الموجودة في السجلات'],
      ['8. الوحدة (اختياري)','مثال: قطعة، علبة، درزن'],
      ['9. سعر الوحدة (اختياري)','السعر لكل وحدة واحدة'],
      ['10. ملاحظات (اختياري)','أي ملاحظات إضافية'],[''],
      ['ملاحظات مهمة:'],
      ['• آلية التعرف تلقائياً على الأعمدة — لا يشترط الترتيب المحدد'],
      ['• يمكن استيراد ملايين الصفوف من شيت واحد'],
      ['• يمكن استيراد عدة ملفات في نفس الوقت'],
    ]);
    guide['!cols'] = [{wch:25},{wch:50}];
    XLSX.utils.book_append_sheet(wb, guide, 'تعليمات');
    XLSX.writeFile(wb, `Inventory_Template_${new Date().toISOString().split('T')[0]}.xlsx`);
    showToast('تم تحميل قالب الاستيراد', 'success');
  } catch (err) {
    showToast('خطأ في إنشاء القالب: ' + err.message, 'error');
  }
