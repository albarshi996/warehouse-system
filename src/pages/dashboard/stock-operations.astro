<script>
  // XLSX من حزمة المشروع بدل CDN — يُعرَّف عالميًّا قبل أي استخدام.
  import * as XLSXmod from 'xlsx';
  window.XLSX = XLSXmod;

  // جسر الدور: يمرّر دور Firebase الحقيقي إلى منطق الصفحة.
  import { subscribeAuth, fetchUserProfile } from '../../services/auth/authService.js';
  subscribeAuth(async (user) => {
    if (!user) return;
    const profile = await fetchUserProfile(user);
    window.__bzProfile = profile;
    if (typeof window.applyBzRole === 'function') window.applyBzRole(profile);
  });

  /* ─────────────────────────────────────────────────────────────
     جسر السحابة (المرحلة 2): كل مسح يُحفظ كقيد دائم في Firestore.
     يعمل بلا إنترنت (Firestore يُخزّن محلياً ويرفع تلقائياً عند العودة).
     ───────────────────────────────────────────────────────────── */
  import {
    createOperation,
    appendScan,
    closeOperation,
    updateOperationSummary,
  } from '../../services/stock/operationsService.js';

  window.__bzCloud = {
    opId: null,
    pending: 0,
    failed: 0,

    /** يبدأ عملية سحابية جديدة (يُستدعى عند بدء العمل). */
    async startOperation(type) {
      if (this.opId) return this.opId;
      try {
        this.opId = await createOperation({ type, profile: window.__bzProfile });
        localStorage.setItem('bzCloudOpId', this.opId);
        window.__bzSetCloudStatus?.('synced', `عملية سحابية: ${this.opId.slice(0, 6)}…`);
        return this.opId;
      } catch (e) {
        window.__bzSetCloudStatus?.('error', 'تعذّر إنشاء العملية السحابية');
        console.error('[cloud] createOperation failed', e);
        return null;
      }
    },

    /** يُرسل قيد مسح دائم. لا يُسقط المسح أبداً إن فشل — يُبلّغ فقط. */
    async pushScan(entry) {
      if (!this.opId) await this.startOperation(entry.opType || 'جرد');
      if (!this.opId) return;
      this.pending++;
      window.__bzSetCloudStatus?.('syncing', `جارٍ الرفع (${this.pending})…`);
      try {
        await appendScan(this.opId, { ...entry, profile: window.__bzProfile });
        this.pending--;
        window.__bzSetCloudStatus?.(
          this.pending > 0 ? 'syncing' : 'synced',
          this.pending > 0 ? `جارٍ الرفع (${this.pending})…` : 'محفوظ في السحابة ✓'
        );
      } catch (e) {
        this.pending--;
        this.failed++;
        window.__bzSetCloudStatus?.('error', `تعذّر رفع ${this.failed} قيد`);
        console.error('[cloud] appendScan failed', e);
      }
    },

    async saveSummary(itemCount, scannedCount) {
      if (!this.opId) return;
      try {
        await updateOperationSummary(this.opId, { itemCount, scannedCount });
      } catch (e) {
        console.error('[cloud] summary failed', e);
      }
    },

    async close() {
      if (!this.opId) return;
      try {
        await closeOperation(this.opId);
        localStorage.removeItem('bzCloudOpId');
        window.__bzSetCloudStatus?.('synced', 'أُقفلت العملية');
        this.opId = null;
      } catch (e) {
        console.error('[cloud] close failed', e);
      }
    },
  };
</script>
<script is:inline>
/* ========================================================
   الحالة العامة
   ======================================================== */
let inventoryDB = [];
let scanLog = [];
let currentTab = 'full';
let currentPage = 1;
const ROWS_PER_PAGE = 50;
let searchQuery = '';
let filteredData = [];
let activeScanBarcode = '';
let activeScanIsNew = false;
let operationType = 'جرد';
let isAdminLoggedIn = false;
let soundEnabled = true;

/* ========================================================
   أدوات مساعدة
   ======================================================== */
function showToast(message, type = 'info') {
  const container = document.getElementById('toastContainer');
  const icons = { success:'fa-circle-check', error:'fa-circle-xmark', warning:'fa-triangle-exclamation', info:'fa-circle-info' };
  const el = document.createElement('div');
  el.className = `toast toast-${type}`;
  el.innerHTML = `<i class="fa-solid ${icons[type]||icons.info}"></i><span>${message}</span>`;
  container.appendChild(el);
  setTimeout(() => { el.classList.add('out'); setTimeout(() => el.remove(), 300); }, 4000);
}

/* ========================================================
   دوال تسجيل دخول المسؤول
   ======================================================== */
function openAdminLoginModal() {
  document.getElementById('adminUsername').value = '';
  document.getElementById('adminPassword').value = '';
  openModal('adminLoginModal');
  setTimeout(() => document.getElementById('adminUsername').focus(), 100);
}

/* 🔒 صلاحية المسؤول تُشتق الآن من دور Firebase الحقيقي — لا كلمة سر في الكود.
   يستدعيها جسر الدور (module script أعلى الصفحة) فور معرفة المستخدم. */
window.applyBzRole = function (profile) {
  const adminRoles = ['admin', 'warehouse_manager'];
  isAdminLoggedIn = !!profile && adminRoles.includes(profile.role);
  const badge = document.getElementById('adminBadge');
  if (badge) badge.classList.toggle('hidden', !isAdminLoggedIn);
};

function handleAdminLogin() {
  // لم يعد هناك دخول بكلمة سر: الصلاحية من دور المستخدم المسجّل في البوابة.
  const profile = window.__bzProfile;
  if (profile && ['admin', 'warehouse_manager'].includes(profile.role)) {
    window.applyBzRole(profile);
    closeModal('adminLoginModal');
    showToast('صلاحية المسؤول مفعّلة عبر دورك في البوابة', 'success');
  } else {
    showToast('هذه الصلاحية للمدير العام ومدير المستودع فقط', 'error');
  }
}

function checkAdminSession() {
  /* 🔒 لم نعد نثق بـ localStorage للصلاحية (كان يمكن انتحالها من أدوات المطوّر).
     الصلاحية تصل حصراً من جسر الدور عبر applyBzRole بعد مصادقة Firebase.
     نُنظّف أي أثر قديم للجلسة الوهمية. */
  localStorage.removeItem('adminSession');
  if (window.__bzProfile) window.applyBzRole(window.__bzProfile);

  const savedSound = localStorage.getItem('soundEnabled');
  if (savedSound !== null) {
    soundEnabled = savedSound === 'true';
  }
}

function openAdminSettingsModal() {
  document.getElementById('soundToggle').checked = soundEnabled;
  openModal('adminSettingsModal');
}

function toggleSound() {
  soundEnabled = document.getElementById('soundToggle').checked;
  localStorage.setItem('soundEnabled', soundEnabled.toString());
  showToast(soundEnabled ? 'تم تفعيل الصوت' : 'تم إيقاف الصوت', 'info');
}

function clearAllData() {
  if (!confirm('هل تريد مسح كل البيانات؟ هذا الإجراء لا يمكن التراجع عنه.')) return;
  inventoryDB = [];
  scanLog = [];
  // ✅ تصحيح: الجلسة تُحفظ فعلياً تحت مفتاح واحد 'inventorySession'
  localStorage.removeItem('inventorySession');
  showToast('تم مسح كل البيانات', 'success');
  closeModal('adminSettingsModal');
  goBackToImport();
}

function changeOperationTypeAdmin() {
  closeModal('adminSettingsModal');
  goBackToImport();
  setTimeout(() => {
    document.getElementById('operationTypeSelect').focus();
  }, 100);
}

/* ========================================================
   حفظ واستعادة الجلسة
   ======================================================== */
let saveSessionTimeout = null;

function saveSessionDebounced() {
  if (saveSessionTimeout) clearTimeout(saveSessionTimeout);
  saveSessionTimeout = setTimeout(() => {
    const sessionData = {
      inventoryDB: inventoryDB,
      operationType: operationType,
      scanLog: scanLog,
      timestamp: Date.now()
    };
    localStorage.setItem('inventorySession', JSON.stringify(sessionData));
  }, 2000);
}

/* ✅ حفظ فوري للجلسة (بدون تأخير الثانيتين) — لزر «حفظ سريع» */
function forceSaveSession() {
  if (!inventoryDB.length) { showToast('لا توجد بيانات للحفظ', 'warning'); return; }
  if (saveSessionTimeout) { clearTimeout(saveSessionTimeout); saveSessionTimeout = null; }
  try {
    localStorage.setItem('inventorySession', JSON.stringify({
      inventoryDB: inventoryDB,
      operationType: operationType,
      scanLog: scanLog,
      timestamp: Date.now()
    }));
    showToast('تم حفظ الجلسة فوراً ✓', 'success');
  } catch (e) {
    showToast('تعذّر الحفظ: ' + e.message, 'error');
  }
}

function checkExistingSession() {
  const saved = localStorage.getItem('inventorySession');
  if (saved) {
    try {
      const sessionData = JSON.parse(saved);
      if (sessionData.inventoryDB && sessionData.inventoryDB.length > 0) {
        document.getElementById('savedOperationType').textContent = sessionData.operationType || 'جرد';
        document.getElementById('savedItemCount').textContent = sessionData.inventoryDB.length.toLocaleString();
        document.getElementById('savedScannedCount').textContent = sessionData.inventoryDB.filter(i => i.scanned).length.toLocaleString();
        openModal('restoreSessionModal');
      }
    } catch (e) {
      console.error('Error parsing session data:', e);
    }
  }
}

function restoreSession() {
  const saved = localStorage.getItem('inventorySession');
  if (saved) {
    try {
      const sessionData = JSON.parse(saved);
      inventoryDB = sessionData.inventoryDB || [];
      operationType = sessionData.operationType || 'جرد';
      scanLog = sessionData.scanLog || [];
      
      document.getElementById('operationTypeSelect').value = operationType;
      closeModal('restoreSessionModal');
      switchToDashboard();
      showToast('تم استعادة الجلسة السابقة', 'success');
    } catch (e) {
      showToast('حدث خطأ أثناء استعادة الجلسة', 'error');
    }
  }
}

function startNewSession() {
  localStorage.removeItem('inventorySession');
  closeModal('restoreSessionModal');
  showToast('تم البدء بجلسة جديدة', 'info');
}

