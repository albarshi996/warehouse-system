  <style>
    .animate-fadeIn {
      animation: fadeIn 0.3s ease-in-out;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <script>
    import mermaid from 'mermaid';

    mermaid.initialize({
      startOnLoad: false,
      theme: 'dark',
      securityLevel: 'loose',
      fontFamily: 'Cairo, sans-serif',
      flowchart: {
        useMaxWidth: true,
        htmlLabels: true,
        curve: 'basis'
      }
    });

    async function renderMermaidIn(tabId) {
      const container = document.getElementById(`${tabId}-content`);
      if (!container) return;
      const diagrams = container.querySelectorAll('.mermaid');
      diagrams.forEach((el) => {
        // Store original content if not already stored
        if (!el.getAttribute('data-original-text')) {
           el.setAttribute('data-original-text', el.textContent.trim());
        }
        if (el.getAttribute('data-processed')) {
          el.removeAttribute('data-processed');
        }
      });
      try {
        await mermaid.run({ nodes: diagrams });
      } catch (e) {
        console.warn('Mermaid render error:', e);
      }
    }

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const tab = (btn instanceof HTMLElement) ? btn.dataset.tab : null;
        if (!tab) return;

        document.querySelectorAll('.tab-btn').forEach(b => {
          b.classList.remove('bg-brand-red', 'text-white');
          b.classList.add('bg-gray-800', 'text-gray-200');
        });
        btn.classList.add('bg-brand-red', 'text-white');
        btn.classList.remove('bg-gray-800', 'text-gray-200');

        document.querySelectorAll('.tab-pane').forEach(p => p.classList.add('hidden'));
        const activePane = document.getElementById(`${tab}-content`);
        if (activePane) activePane.classList.remove('hidden');

        const tabsWithCharts = ['finance', 'hr', 'procurement', 'warehouse', 'supplychain'];
        if (tabsWithCharts.includes(tab)) {
          await renderMermaidIn(tab);
        }
      });
    });

    document.addEventListener('DOMContentLoaded', async () => {
      await renderMermaidIn('finance');

      // Print Flowchart Logic
      document.addEventListener('click', (e) => {
        if (!(e.target instanceof HTMLElement)) return;
        const btn = e.target.closest('.print-flowchart-btn');
        if (!btn || !(btn instanceof HTMLElement)) return;

        const section = btn.closest('section');
        if (!section) return;
        const mermaidDiv = section.querySelector('.mermaid');
        if (!mermaidDiv || !(mermaidDiv instanceof HTMLElement)) return;

        // Get original Mermaid text
        let graphDefinition = mermaidDiv.getAttribute('data-original-text') || mermaidDiv.textContent.trim();

        const title = btn.getAttribute('data-title') || 'مخطط التدفق';

        const printWindow = window.open('', '_blank');
        printWindow.document.write(`
          <!DOCTYPE html>
          <html lang="ar" dir="rtl">
          <head>
            <meta charset="UTF-8">
            <title>طباعة - ${title}</title>
            <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
            <script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"><\/script>
            <style>
              body { font-family: 'Cairo', sans-serif; background: white; color: black; padding: 20px; margin: 0; text-align: center; }
              h1 { color: #c41e3a; margin-bottom: 30px; border-bottom: 2px solid #DAAA3C; padding-bottom: 10px; }
              .mermaid { display: flex; justify-content: center; }
              @media print {
                body { margin: 0; }
                .no-print { display: none; }
                @page { size: A4; margin: 15mm; }
              }
              .no-print {
                background: #DAAA3C;
                color: #1a1a2e;
                border: none;
                padding: 10px 20px;
                border-radius: 8px;
                font-weight: bold;
                cursor: pointer;
                margin-bottom: 20px;
              }
            </style>
          </head>
          <body>
            <div class="no-print">
              <button onclick="window.print(); window.close();" class="no-print">Close & Print (إغلاق وطباعة)</button>
            </div>
            <h1>${title}</h1>
            <div class="mermaid">
              ${graphDefinition}
            </div>
            <script>
              mermaid.initialize({ startOnLoad: true, theme: 'default' });
            <\/script>
          </body>
          </html>
        `);
        printWindow.document.close();
      });
    });
  </script>
