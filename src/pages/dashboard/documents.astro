---
/**
 * صندوق المستندات — مستنداتي · بانتظار اعتمادي · الكل (للمدير).
 * المرحلة F1 من خطة تحويل النماذج (ROADMAP §11).
 * قاعدة صفر حذف: مكتبة النماذج الورقية `/dashboard/forms` تبقى كما هي.
 */
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import DocumentsInbox from '../../components/brandzo-erp/documents/DocumentsInbox.jsx';
---

<DashboardLayout title="المستندات" showGuide={false}>
  <div class="text-right" dir="rtl">
    <div class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">📑 المستندات</h1>
      <p class="text-gray-300 text-sm leading-relaxed max-w-3xl">
        المستندات الرسمية <span class="text-brand-gold font-bold">تُحفظ ولا تضيع</span>: لكل مستند
        رقم تسلسلي حقيقي، واسم من أنشأه ومن اعتمده، وسجلّ تدقيق دائم — بدل الورقة التي تُملأ ثم
        تُغلق الصفحة فيضيع كل شيء.
      </p>
      <div class="w-20 h-1 bg-brand-red rounded-full mt-3"></div>
    </div>

    <DocumentsInbox client:load />
  </div>
</DashboardLayout>
