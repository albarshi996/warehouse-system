---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Icon from '../../components/ui/Icon.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
---

<DashboardLayout title="مقترحات التطوير">
  <div class="text-right" dir="rtl">
    {/* Header & Actions */}
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4 no-print">
      <div>
        <h1 class="text-3xl font-bold text-white mb-2">مقترحات التطوير التشغيلي</h1>
        <p class="text-gray-400">تحسين كفاءة المستودعات، الدورة المستندية، والمعايير الهندسية</p>
      </div>
      <button
        onclick="window.print()"
        class="flex items-center gap-2 px-6 py-3 bg-brand-red hover:bg-brand-red-dark text-white rounded-xl font-bold transition-all shadow-lg active:scale-95"
      >
        <Icon name="printer" size={20} />
        <span>طباعة المقترح / تصدير PDF</span>
      </button>
    </div>

    <div class="grid grid-cols-1 gap-8">
      {/* القسم الأول: نموذج الجرد الدائري */}
      <section class="bg-white/5 backdrop-blur border border-white/10 rounded-2xl p-6 md:p-8 shadow-xl overflow-hidden print:bg-white print:text-black print:border-black print:shadow-none">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400 print:text-blue-700">
            <Icon name="clipboardList" size={28} />
          </div>
          <h2 class="text-2xl font-bold text-white print:text-black">القسم الأول: نموذج الجرد الدائري (Cycle Count Form BH-CC)</h2>
        </div>

        <div class="overflow-x-auto mb-6">
          <table class="w-full text-sm text-right border-collapse">
            <thead>
              <tr class="bg-white/10 print:bg-gray-100 border-b border-white/20 print:border-black">
                <th class="p-3 border border-white/10 print:border-black">رمز الصنف (SKU)</th>
                <th class="p-3 border border-white/10 print:border-black">وصف الصنف</th>
                <th class="p-3 border border-white/10 print:border-black">رقم الرف/الموقع</th>
                <th class="p-3 border border-white/10 print:border-black">الكمية الفعلية</th>
                <th class="p-3 border border-white/10 print:border-black">الكمية الدفترية</th>
                <th class="p-3 border border-white/10 print:border-black">الفارق</th>
                <th class="p-3 border border-white/10 print:border-black">ملاحظات</th>
              </tr>
            </thead>
            <tbody>
              {[1, 2, 3, 4, 5].map((_) => (
                <tr class="border-b border-white/5 print:border-black">
                  <td class="p-3 border border-white/10 print:border-black h-10"></td>
                  <td class="p-3 border border-white/10 print:border-black"></td>
                  <td class="p-3 border border-white/10 print:border-black"></td>
                  <td class="p-3 border border-white/10 print:border-black"></td>
                  <td class="p-3 border border-white/10 print:border-black"></td>
                  <td class="p-3 border border-white/10 print:border-black"></td>
                  <td class="p-3 border border-white/10 print:border-black"></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="bg-blue-500/10 border-r-4 border-blue-500 p-4 mb-8 print:bg-gray-100 print:border-black">
          <h3 class="font-bold text-blue-400 print:text-black mb-1">💡 ملاحظة تشغيلية: Blind Count (الجرد الأعمى)</h3>
          <p class="text-sm text-gray-300 print:text-black">
            يُمنع تزويد الجارد بالكمية الدفترية مسبقاً لضمان دقة العد الميداني وعدم الاعتماد على الأرقام الموجودة في النظام.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-8 mt-8 border-t border-white/10 pt-6 print:border-black">
          <div class="text-center">
            <p class="text-gray-400 print:text-black mb-12">توقيع الجارد (Counter Signature)</p>
            <div class="w-48 h-px bg-white/30 mx-auto print:bg-black"></div>
          </div>
          <div class="text-center">
            <p class="text-gray-400 print:text-black mb-12">اعتماد مشرف المستودع (Supervisor)</p>
            <div class="w-48 h-px bg-white/30 mx-auto print:bg-black"></div>
          </div>
        </div>
      </section>

      {/* القسم الثاني: تكامل Odoo Enterprise */}
      <section class="bg-white/5 backdrop-blur border border-white/10 rounded-2xl p-6 md:p-8 shadow-xl print:bg-white print:text-black print:border-black print:shadow-none">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 bg-green-500/20 rounded-xl flex items-center justify-center text-green-400 print:text-green-700">
            <Icon name="package" size={28} />
          </div>
          <h2 class="text-2xl font-bold text-white print:text-black">القسم الثاني: تكامل Odoo Enterprise (أتمتة الجرد)</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-white/5 p-5 rounded-xl border border-white/10 print:border-black">
            <div class="text-2xl font-bold text-green-400 mb-2">1</div>
            <h3 class="font-bold text-white print:text-black mb-2">إنشاء مهمة الجرد</h3>
            <p class="text-sm text-gray-400 print:text-black">الدخول إلى تطبيق Inventory ← Adjustments لإنشاء دورة جرد جديدة.</p>
          </div>
          <div class="bg-white/5 p-5 rounded-xl border border-white/10 print:border-black">
            <div class="text-2xl font-bold text-green-400 mb-2">2</div>
            <h3 class="font-bold text-white print:text-black mb-2">تفريغ البيانات</h3>
            <p class="text-sm text-gray-400 print:text-black">إدخال نتائج الجرد الميداني يدوياً أو عبر Barcode Scanner مباشرة في النظام.</p>
          </div>
          <div class="bg-white/5 p-5 rounded-xl border border-white/10 print:border-black">
            <div class="text-2xl font-bold text-green-400 mb-2">3</div>
            <h3 class="font-bold text-white print:text-black mb-2">معالجة الفروقات</h3>
            <p class="text-sm text-gray-400 print:text-black">تحليل أسباب العجز أو الزيادة وتوثيق التبريرات قبل الاعتماد.</p>
          </div>
          <div class="bg-white/5 p-5 rounded-xl border border-white/10 print:border-black">
            <div class="text-2xl font-bold text-green-400 mb-2">4</div>
            <h3 class="font-bold text-white print:text-black mb-2">الاعتماد والقيود</h3>
            <p class="text-sm text-gray-400 print:text-black">النقر على Validate لتحديث المخزن وإنشاء القيود المحاسبية للفوارق آلياً.</p>
          </div>
        </div>
      </section>

      {/* القسم الثالث: المخططات الهندسية وتوزيع المساحات */}
      <section class="bg-white/5 backdrop-blur border border-white/10 rounded-2xl p-6 md:p-8 shadow-xl print:bg-white print:text-black print:border-black print:shadow-none">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 bg-orange-500/20 rounded-xl flex items-center justify-center text-orange-400 print:text-orange-700">
            <Icon name="warehouse" size={28} />
          </div>
          <h2 class="text-2xl font-bold text-white print:text-black">القسم الثالث: المخططات الهندسية وتوزيع المساحات</h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <div>
            <h3 class="text-xl font-bold text-brand-yellow mb-4">توزيع التدفق (U-Shape Flow)</h3>
            <div class="bg-white/5 border border-white/10 rounded-xl p-6 print:border-black">
              <ul class="space-y-4">
                <li class="flex items-center gap-3">
                  <span class="w-8 h-8 bg-blue-500/20 rounded-full flex items-center justify-center text-blue-400 font-bold">1</span>
                  <span>منطقة الاستلام (Receiving)</span>
                </li>
                <li class="flex items-center gap-3">
                  <span class="w-8 h-8 bg-blue-500/20 rounded-full flex items-center justify-center text-blue-400 font-bold">2</span>
                  <span>منطقة التخزين (Storage)</span>
                </li>
                <li class="flex items-center gap-3">
                  <span class="w-8 h-8 bg-blue-500/20 rounded-full flex items-center justify-center text-blue-400 font-bold">3</span>
                  <span>منطقة الانتقاء (Picking)</span>
                </li>
                <li class="flex items-center gap-3">
                  <span class="w-8 h-8 bg-blue-500/20 rounded-full flex items-center justify-center text-blue-400 font-bold">4</span>
                  <span>منطقة التعبئة والتغليف (Packing)</span>
                </li>
                <li class="flex items-center gap-3">
                  <span class="w-8 h-8 bg-blue-500/20 rounded-full flex items-center justify-center text-blue-400 font-bold">5</span>
                  <span>منطقة الشحن (Shipping)</span>
                </li>
              </ul>
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-brand-yellow mb-4">معادلات الكفاءة التخزينية</h3>
            <div class="space-y-6">
              <div class="bg-white/5 border border-white/10 rounded-xl p-5 print:border-black">
                <p class="text-sm text-gray-400 mb-2">حساب السعة التخزينية القصوى:</p>
                <div class="text-2xl font-mono text-white print:text-black">(A − B) × C = السعة (m³)</div>
                <p class="text-xs text-gray-500 mt-2">A: المساحة الكلية | B: الممرات والمكاتب | C: ارتفاع التخزين المتاح</p>
              </div>
              <div class="bg-white/5 border border-white/10 rounded-xl p-5 print:border-black">
                <p class="text-sm text-gray-400 mb-2">نسبة الاستخدام (Utilization Ratio):</p>
                <div class="text-2xl font-mono text-white print:text-black">(حجم المخزون ÷ السعة الكلية) × 100</div>
                <div class="mt-4 p-3 bg-brand-red/10 border-r-4 border-brand-red text-sm">
                  المعدل المثالي: <span class="font-bold text-brand-red">70% إلى 85%</span>
                  <span class="block text-xs mt-1 text-gray-400 italic">تجاوز 85% يقلل الكفاءة التشغيلية (الازدحام)</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* القسم الرابع: معايير الأداء التشغيلي */}
      <section class="bg-white/5 backdrop-blur border border-white/10 rounded-2xl p-6 md:p-8 shadow-xl print:bg-white print:text-black print:border-black print:shadow-none">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 bg-purple-500/20 rounded-xl flex items-center justify-center text-purple-400 print:text-purple-700">
            <Icon name="grid" size={28} />
          </div>
          <h2 class="text-2xl font-bold text-white print:text-black">القسم الرابع: معايير الأداء التشغيلي (KPIs)</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-gradient-to-br from-white/5 to-white/0 p-6 rounded-2xl border border-white/10 print:border-black">
            <h3 class="font-bold text-white print:text-black mb-4 flex items-center gap-2">
              <span>📉</span> جودة الانتقاء (Picking Accuracy)
            </h3>
            <div class="space-y-4">
              <div class="flex justify-between items-center p-3 bg-red-500/10 rounded-lg">
                <span class="text-sm">بدون إجراءات عمل (No SOPs)</span>
                <span class="font-bold text-red-400">1% - 3% أخطاء</span>
              </div>
              <div class="flex justify-between items-center p-3 bg-green-500/10 rounded-lg">
                <span class="text-sm">مع تطبيق SOPs & Barcode</span>
                <span class="font-bold text-green-400">أقل من 0.1%</span>
              </div>
            </div>
          </div>

          <div class="bg-gradient-to-br from-white/5 to-white/0 p-6 rounded-2xl border border-white/10 print:border-black">
            <h3 class="font-bold text-white print:text-black mb-4 flex items-center gap-2">
              <span>🚀</span> استراتيجيات الانتقاء (Picking Methods)
            </h3>
            <div class="grid grid-cols-1 gap-3 text-sm">
              <div class="p-3 border border-white/10 rounded-lg hover:bg-white/5 transition-colors print:border-black">
                <span class="font-bold text-brand-yellow">Discrete Picking:</span> طلب واحد لكل جولة
              </div>
              <div class="p-3 border border-white/10 rounded-lg hover:bg-white/5 transition-colors print:border-black">
                <span class="font-bold text-brand-yellow">Batch Picking:</span> عدة طلبات لنفس الصنف في جولة واحدة
              </div>
              <div class="p-3 border border-white/10 rounded-lg hover:bg-white/5 transition-colors print:border-black">
                <span class="font-bold text-brand-yellow">Wave Picking:</span> جدولة الانتقاء بناءً على مسارات الشحن
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    {/* Footer */}
    <div class="mt-12 text-center text-gray-500 text-sm print:text-black">
      <p>مقترح تطوير لوحة تحكم برانزو 2026 — محمد البرشي</p>
      <p class="mt-1">جميع الحقوق محفوظة للمحتوى التشغيلي</p>
    </div>
  </div>
</DashboardLayout>

<style>
  @media print {
    .no-print {
      display: none !important;
    }
    body {
      background: white !important;
      color: black !important;
    }
    @page {
      size: A4;
      margin: 1cm;
    }
  }
</style>
