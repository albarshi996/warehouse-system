---
/**
 * إدارة المستخدمين — للمدير العام فقط. إسناد الأدوار عبر Firestore.
 * القاعدة الذهبية: لا حذف — صفحة ومكوّن جديدان (access/).
 */
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import UsersAdmin from '../../components/brandzo-erp/access/UsersAdmin.jsx';
---

<DashboardLayout title="إدارة المستخدمين" showGuide={false}>
  <div class="text-right" dir="rtl">
    <div class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">👥 إدارة المستخدمين</h1>
      <p class="text-gray-300 text-sm leading-relaxed max-w-3xl">
        أسنِد الأدوار وفعّل/عطّل الحسابات. أنشئ الحساب أولًا في Firebase Console،
        ثم انسخ الـ <span class="font-mono text-brand-gold">User UID</span> وأسند له دورًا هنا.
      </p>
      <div class="w-20 h-1 bg-brand-red rounded-full mt-3"></div>
    </div>

    <UsersAdmin client:load />

    <!-- تنبيه أمني: قواعد Firestore يجب أن تحصر الكتابة بالأدمن -->
    <details class="mt-8 bg-emerald-500/10 border border-emerald-500/30 rounded-2xl p-5">
      <summary class="text-emerald-300 font-bold cursor-pointer">
        ✅ قاعدة البيانات مقفولة — قواعد الأمان منشورة وفعّالة (اضغط للتفاصيل)
      </summary>
      <div class="mt-3 text-sm text-gray-200 space-y-3">
        <p>
          <b class="text-emerald-300">آخر تحقّق (2026-07-17):</b> تم اختبار القراءة بلا تسجيل دخول على
          كل المجموعات الحسّاسة (<span class="font-mono">users</span>،
          <span class="font-mono">candidates</span>، <span class="font-mono">operations</span>،
          <span class="font-mono">Items_Master</span>، <span class="font-mono">balances</span>،
          <span class="font-mono">documents</span>) — كلها ترفض الوصول (403) كما هو متوقّع.
        </p>
        <p>
          القواعد الكاملة والمحدَّثة (لكل المجموعات، لا الأدوار فقط) موجودة في ملف
          <span class="font-mono text-emerald-300">firestore.rules</span> بجذر المستودع وهي المصدر
          الوحيد المعتمد. عند أي تعديل عليها لازم تُنشَر يدويًا من
          <span class="font-mono text-emerald-300">Firebase Console → Firestore Database → Rules → Publish</span>
          — هذه الخطوة تلامس إعدادات أمان الحساب فلا تتم تلقائيًا من الكود.
        </p>
        <p class="text-gray-400 text-xs">
          ملاحظة: بريد المدير العام يبقى أدمن عبر التمهيد المدمج حتى قبل إنشاء مستنده،
          فلا تنقطع صلاحيتك مهما تغيّرت القواعد.
        </p>
      </div>
    </details>
  </div>
</DashboardLayout>
