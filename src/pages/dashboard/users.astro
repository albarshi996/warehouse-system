---
/**
 * إدارة المستخدمين — للمدير العام فقط. إسناد الأدوار عبر Firestore.
 * القاعدة الذهبية: لا حذف — صفحة ومكوّن جديدان (access/).
 */
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import UsersAdmin from '../../components/brandzo-erp/access/UsersAdmin.jsx';
---

<DashboardLayout title="إدارة المستخدمين" showGuide={false}>
  <div class="text-right" dir="rtl">
    <div class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">👥 إدارة المستخدمين</h1>
      <p class="text-gray-300 text-sm leading-relaxed max-w-3xl">
        أسنِد الأدوار وفعّل/عطّل الحسابات. أنشئ الحساب أولًا في Firebase Console،
        ثم انسخ الـ <span class="font-mono text-brand-gold">User UID</span> وأسند له دورًا هنا.
      </p>
      <div class="w-20 h-1 bg-brand-red rounded-full mt-3"></div>
    </div>

    <UsersAdmin client:load />

    <!-- تنبيه أمني: قواعد Firestore يجب أن تحصر الكتابة بالأدمن -->
    <details class="mt-8 bg-amber-500/10 border border-amber-500/30 rounded-2xl p-5">
      <summary class="text-amber-300 font-bold cursor-pointer">
        ⚠️ خطوة أمان مطلوبة — قواعد أمان Firestore (اضغط للتفاصيل)
      </summary>
      <div class="mt-3 text-sm text-gray-200 space-y-3">
        <p>
          بدون قواعد، يستطيع أي مستخدم مصادق تعديل دوره. الصق القواعد التالية في
          <span class="font-mono text-amber-300">Firebase Console → Firestore Database → Rules</span>
          ثم <span class="font-bold">Publish</span> (تسمح بالكتابة على الأدوار للأدمن فقط):
        </p>
        <pre class="bg-black/40 border border-white/10 rounded-lg p-4 overflow-x-auto text-xs leading-relaxed" dir="ltr"><code>rules_version = '2';
service cloud.firestore {'{'}
  match /databases/{'{'}database{'}'}/documents {'{'}

    function isAdmin() {'{'}
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    {'}'}

    // أدوار المستخدمين: القراءة لكل مصادق، الكتابة للأدمن فقط
    match /users/{'{'}uid{'}'} {'{'}
      allow read: if request.auth != null;
      allow write: if isAdmin();
    {'}'}

    // بقيّة المجموعات: للمصادقين فقط (عدّل حسب حاجتك)
    match /{'{'}document=**{'}'} {'{'}
      allow read, write: if request.auth != null;
    {'}'}
  {'}'}
{'}'}</code></pre>
        <p class="text-gray-400 text-xs">
          ملاحظة: بريد المدير العام يبقى أدمن عبر التمهيد المدمج حتى قبل إنشاء مستنده،
          لذا تستطيع نشر هذه القواعد ثم إدارة الباقي من هنا.
        </p>
      </div>
    </details>
  </div>
</DashboardLayout>
