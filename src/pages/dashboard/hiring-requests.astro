---
/**
 * طلبات التوظيف من الإدارات — منفصلة عن صفحة «التوظيف» الحسّاسة (بلا أي
 * بيانات مرشحين: أسماء/هواتف/رواتب). الصفحة الوحيدة المتاحة لدور
 * department_user (الإلزام في AuthGate عبر services/auth/pageAccess.js).
 */
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import HiringRequestsBoard from '../../components/brandzo-erp/hiring/HiringRequestsBoard.jsx';
---

<DashboardLayout title="طلبات التوظيف" showGuide={false}>
  <div class="text-right" dir="rtl">
    <div class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">🏬 طلبات التوظيف من الإدارات</h1>
      <p class="text-gray-300 text-sm leading-relaxed max-w-3xl">
        كل إدارة ترسل مسمّاها الوظيفي المطلوب وبطاقة تعريفية عن الحاجة، وترى طلباتها هي فقط.
        المدير العام ومدير المستودع يراجعان كل الطلبات من هنا.
      </p>
      <div class="w-20 h-1 bg-brand-red rounded-full mt-3"></div>
    </div>

    <HiringRequestsBoard client:load />
  </div>
</DashboardLayout>
