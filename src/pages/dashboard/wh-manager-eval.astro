---
/**
 * تقييم مرشّح «مدير المستودعات» — أداة سرّية محميّة بالدور داخل اللوحة.
 * الوصول: المدير العام + مستخدم الإدارة (الإلزام في المكوّن + pageAccess).
 * المحتوى لا يُحقن إلا بعد التحقّق من الدور (بحزمة JS لا في HTML الثابت).
 */
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import WarehouseManagerEval from '../../components/brandzo-erp/assessments/WarehouseManagerEval.jsx';
---

<DashboardLayout title="تقييم مدير المستودعات" showGuide={false}>
  <div class="text-right" dir="rtl">
    <div class="mb-4">
      <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">📝 تقييم مرشّح — مدير المستودعات</h1>
      <p class="text-gray-300 text-sm leading-relaxed max-w-3xl">
        أداة تقييم داخلية سرّية (٦ محاور · تنقيط ٠-١٠٠ · حفظ تلقائي في متصفّحك).
        متاحة للمدير العام ومستخدم الإدارة فقط.
      </p>
      <div class="w-20 h-1 bg-brand-red rounded-full mt-3"></div>
    </div>

    <WarehouseManagerEval client:load />
  </div>
</DashboardLayout>
