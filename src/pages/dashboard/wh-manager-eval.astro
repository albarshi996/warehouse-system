<DashboardLayout title="تقييم مدير المستودعات" showGuide={false}>
  <div class="text-right" dir="rtl">
    <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-1">
      <h1 class="text-xl sm:text-2xl font-bold text-white">📝 تقييم مرشّح — مدير المستودعات</h1>
      <span class="text-gray-300 text-xs sm:text-[13px] leading-relaxed">
        🎙️ إملاء صوتي للإجابات · 🔴 تسجيل المكالمة · ⛶ ملء الشاشة — من شريط الأدوات داخل النموذج
      </span>
    </div>

    <WarehouseManagerEval client:load />
  </div>
</DashboardLayout>
