---
/**
 * تقييم مرشّح «مدير المستودعات» — أداة سرّية محميّة بالدور داخل اللوحة.
 * الوصول: المدير العام + مستخدم الإدارة (الإلزام في المكوّن + pageAccess).
 * المحتوى لا يُحقن إلا بعد التحقّق من الدور (بحزمة JS لا في HTML الثابت).
 */
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import WarehouseManagerEval from '../../components/brandzo-erp/assessments/WarehouseManagerEval.jsx';
