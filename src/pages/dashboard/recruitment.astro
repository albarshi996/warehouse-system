---
/**
 * التوظيف الذكي — المرشحون في السحابة: إضافة · فرز · مقابلة · قبول/رفض.
 * المسمّى والوصف من الهيكل الرسمي (كتالوج مولَّد من ملف المالك). العملة: د.ل.
 * الوصول: المدير العام ومدير المستودع (بيانات حسّاسة).
 * الصفحة الثابتة القديمة (تقرير التوظيف والجدول الزمني) تبقى — صفر حذف.
 */
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import RecruitmentBoard from '../../components/brandzo-erp/recruitment/RecruitmentBoard.jsx';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
---

<DashboardLayout title="التوظيف" showGuide={false}>
  <div class="text-right" dir="rtl">
    <div class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">🧑‍💼 التوظيف الذكي</h1>
      <p class="text-gray-300 text-sm leading-relaxed max-w-3xl">
        المرشحون <span class="text-brand-gold font-bold">يُحفظون في السحابة</span> برحلة واضحة
        (جديد ← فرز ← مقابلة ← قرار) وسجلّ تدقيق دائم. المسمّى والوصف من
        <a
          href={`${base}/تقرير-التوظيف-والجدول-الزمني.html`}
          target="_blank"
          rel="noopener"
          class="text-brand-gold hover:underline">الهيكل التنظيمي الرسمي</a
        > — والرواتب بالدينار الليبي.
      </p>
      <div class="w-20 h-1 bg-brand-red rounded-full mt-3"></div>
    </div>

    <RecruitmentBoard client:load />
  </div>
</DashboardLayout>
