---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
---

<DashboardLayout title="المقارنة العالمية للمستودعات">
  <div class="text-right" dir="rtl">
    <div class="mb-6 sm:mb-8 w-full rounded-2xl overflow-hidden border border-brand-red/20 shadow-2xl" style="height: 90vh; min-height: 700px;">
      <iframe
        src={`${base}/تقرير-المقارنة-العالمية.html`}
        title="تقرير المقارنة العالمية للمستودعات"
        class="w-full h-full border-0"
        loading="lazy"
      ></iframe>
    </div>
  </div>
</DashboardLayout>
