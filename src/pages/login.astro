---
/**
 * صفحة تسجيل الدخول — مستقلّة عن DashboardLayout (بلا سايدبار).
 * تحمي بقيّة البوابة عبر حارس AuthGate الموجود في DashboardLayout.
 */
import '../styles/global.css';
import LoginForm from '../components/brandzo-erp/access/LoginForm.jsx';
---

<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>تسجيل الدخول - Brandzo Hub 2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: 'Cairo', sans-serif;
      }
    </style>
  </head>

  <body class="bz-page-bg min-h-screen flex items-center justify-center px-4 py-10">
    <LoginForm client:load />
