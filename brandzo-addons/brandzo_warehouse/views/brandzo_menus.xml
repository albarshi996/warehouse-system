<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- تطبيق Brandzo الجذر -->
    <menuitem id="menu_bz_root" name="Brandzo"
              sequence="5"
              groups="brandzo_warehouse.group_bz_warehouse_user"/>

    <!-- المجموعة الأولى من الدورة: الشراء والتعاقد (المرحلتان 01–02) -->
    <menuitem id="menu_bz_purchase" name="دورة الشراء والتعاقد"
              parent="menu_bz_root" sequence="10"/>

    <menuitem id="menu_bz_pr" name="طلبات الشراء (PR)"
              parent="menu_bz_purchase" sequence="10"
              action="purchase_requisition.action_purchase_requisition"/>

    <menuitem id="menu_bz_po" name="أوامر الشراء (PO)"
              parent="menu_bz_purchase" sequence="20"
              action="purchase.purchase_form_action"/>

    <!-- المجموعة الثانية: الشحن والبوابة (المرحلة 07) -->
    <menuitem id="menu_bz_dispatch" name="الشحن والبوابة"
              parent="menu_bz_root" sequence="30"/>

    <menuitem id="menu_bz_gate_pass" name="تصاريح البوابة"
              parent="menu_bz_dispatch" sequence="10"
              action="action_bz_gate_pass"/>

    <!-- المرحلة 08: المرتجعات والتالف -->
    <menuitem id="menu_bz_returns" name="المرتجعات والتالف"
              parent="menu_bz_root" sequence="35"/>

    <menuitem id="menu_bz_return_pickings" name="إذون الإرجاع"
              parent="menu_bz_returns" sequence="10"
              action="action_bz_returns"/>

    <menuitem id="menu_bz_scrap" name="الإتلاف"
              parent="menu_bz_returns" sequence="20"
              action="stock.action_stock_scrap"/>

    <!-- المجموعة الثالثة: المالية والمطابقة الثلاثية (المرحلة 11) -->
    <menuitem id="menu_bz_finance" name="المالية والمطابقة"
              parent="menu_bz_root" sequence="40"/>

    <menuitem id="menu_bz_bill_match" name="المطابقة الثلاثية"
              parent="menu_bz_finance" sequence="10"
              action="action_bz_bill_match"/>
</odoo>
