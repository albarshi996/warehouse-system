<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- نوع العملية: تفعيل اشتراط فحص الجودة على أنواع الاستلام فقط -->
    <record id="view_bz_picking_type_form" model="ir.ui.view">
        <field name="name">bz.stock.picking.type.form</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.view_picking_type_form"/>
        <field name="arch" type="xml">
            <field name="code" position="after">
                <field name="bz_qc_required" invisible="code != 'incoming'"/>
                <field name="bz_is_dispatch" invisible="code != 'outgoing'"/>
            </field>
        </field>
    </record>

    <!-- إذن الاستلام: أزرار الفحص + شارة الحالة + تبويب الجودة -->
    <record id="view_bz_picking_form" model="ir.ui.view">
        <field name="name">bz.stock.picking.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <!-- أزرار الفحص في الرأس قبل زر Validate (مقصورة على مفتش الجودة) -->
            <button name="button_validate" position="before">
                <button name="action_bz_qc_pass" type="object"
                        string="اعتماد الفحص (اجتاز)" class="btn-success"
                        groups="brandzo_warehouse.group_bz_qc_inspector"
                        invisible="picking_type_code != 'incoming' or not bz_qc_required or bz_qc_state == 'passed' or state in ('done', 'cancel')"/>
                <button name="action_bz_qc_fail" type="object"
                        string="رفض الفحص (فشل)" class="btn-danger"
                        groups="brandzo_warehouse.group_bz_qc_inspector"
                        invisible="picking_type_code != 'incoming' or not bz_qc_required or bz_qc_state == 'failed' or state in ('done', 'cancel')"/>
                <button name="action_bz_qc_reset" type="object"
                        string="إعادة الفحص"
                        groups="brandzo_warehouse.group_bz_qc_inspector"
                        invisible="picking_type_code != 'incoming' or not bz_qc_required or bz_qc_state == 'pending' or state == 'done'"/>
            </button>

            <!-- شارة نتيجة الجودة (الوارد) + شارة أقرب صلاحية (الصادر) -->
            <field name="state" position="after">
                <field name="bz_qc_required" invisible="1"/>
                <field name="bz_qc_state" widget="badge"
                       invisible="picking_type_code != 'incoming' or not bz_qc_required"
                       decoration-warning="bz_qc_state == 'pending'"
                       decoration-success="bz_qc_state == 'passed'"
                       decoration-danger="bz_qc_state == 'failed'"/>
                <field name="bz_has_expired_line" invisible="1"/>
                <field name="bz_dispatch_expiry" widget="badge"
                       invisible="picking_type_code != 'outgoing' or not bz_dispatch_expiry"
                       decoration-danger="bz_has_expired_line"
                       decoration-success="not bz_has_expired_line"/>
                <field name="bz_is_dispatch" invisible="1"/>
                <field name="bz_gate_pass_approved" invisible="1"/>
            </field>

            <!-- زر إحصائي لتصاريح البوابة (للشحن الصادر) -->
            <div name="button_box" position="inside">
                <button name="action_bz_open_gate_pass" type="object"
                        class="oe_stat_button" icon="fa-shield"
                        invisible="not bz_is_dispatch">
                    <field name="bz_gate_pass_count" widget="statinfo"
                           string="تصاريح البوابة"/>
                </button>
            </div>

            <!-- شريط تنبيه: بانتظار تصريح البوابة -->
            <xpath expr="//div[@name='button_box']" position="before">
                <widget name="web_ribbon" title="بانتظار تصريح البوابة"
                        bg_color="text-bg-warning"
                        invisible="not bz_is_dispatch or bz_gate_pass_approved or state in ('done', 'cancel')"/>
            </xpath>

            <!-- تبويب فحص الجودة -->
            <notebook position="inside">
                <page name="bz_qc" string="فحص الجودة"
                      invisible="picking_type_code != 'incoming' or not bz_qc_required">
                    <group>
                        <group string="النتيجة">
                            <field name="bz_qc_state"/>
                            <field name="bz_qc_inspector_id"/>
                            <field name="bz_qc_date"/>
                        </group>
                        <group string="ملاحظات">
                            <field name="bz_qc_note" nolabel="1"
                                   placeholder="سبب الرفض أو ملاحظات المفتش..."/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <!-- قائمة الإذون: تلوين حسب نتيجة الجودة -->
    <record id="view_bz_picking_tree" model="ir.ui.view">
        <field name="name">bz.stock.picking.list</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <field name="state" position="before">
                <field name="bz_qc_required" column_invisible="1"/>
                <field name="bz_qc_state" widget="badge" optional="show"
                       invisible="not bz_qc_required"
                       decoration-warning="bz_qc_state == 'pending'"
                       decoration-success="bz_qc_state == 'passed'"
                       decoration-danger="bz_qc_state == 'failed'"/>
                <field name="bz_dispatch_expiry" optional="hide"/>
            </field>
        </field>
    </record>

    <!-- المرحلة 08: حوكمة المرتجعات على إذن المخزون -->
    <record id="view_bz_picking_form_returns" model="ir.ui.view">
        <field name="name">bz.stock.picking.form.returns</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <button name="button_validate" position="before">
                <button name="action_bz_return_approve" type="object"
                        string="اعتماد الإرجاع" class="btn-primary"
                        groups="brandzo_warehouse.group_bz_return_manager"
                        invisible="not bz_is_return or bz_return_state != 'draft' or state in ('done', 'cancel')"/>
                <button name="action_bz_return_reset" type="object"
                        string="سحب اعتماد الإرجاع"
                        groups="brandzo_warehouse.group_bz_return_manager"
                        invisible="not bz_is_return or bz_return_state != 'approved' or state == 'done'"/>
                <button name="action_bz_create_credit_note" type="object"
                        string="إنشاء إشعار دائن" class="btn-secondary"
                        groups="brandzo_warehouse.group_bz_return_manager"
                        invisible="not bz_is_return or bz_credit_note_id"/>
            </button>

            <field name="state" position="after">
                <field name="bz_is_return" invisible="1"/>
                <field name="bz_return_state" widget="badge"
                       invisible="not bz_is_return"
                       decoration-warning="bz_return_state == 'draft'"
                       decoration-success="bz_return_state == 'approved'"/>
            </field>

            <notebook position="inside">
                <page name="bz_return" string="حوكمة الإرجاع"
                      invisible="not bz_is_return">
                    <group>
                        <group>
                            <field name="bz_return_state"/>
                            <field name="bz_return_approver_id"/>
                            <field name="bz_return_approval_date"/>
                        </group>
                        <group>
                            <field name="bz_return_reason"
                                   placeholder="سبب الإرجاع وتصنيف الحالة (سليم/تالف/منتهٍ)..."/>
                            <field name="bz_credit_note_id" readonly="1"
                                   invisible="not bz_credit_note_id"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <!-- إجراء قائمة إذون الإرجاع -->
    <record id="action_bz_returns" model="ir.actions.act_window">
        <field name="name">إذون الإرجاع</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('return_id', '!=', False)]</field>
    </record>
</odoo>
