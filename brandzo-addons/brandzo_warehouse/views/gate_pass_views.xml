<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- نموذج تصريح خروج البوابة -->
    <record id="view_bz_gate_pass_form" model="ir.ui.view">
        <field name="name">bz.gate.pass.form</field>
        <field name="model">bz.gate.pass</field>
        <field name="arch" type="xml">
            <form string="تصريح خروج البوابة">
                <header>
                    <button name="action_approve" type="object"
                            string="اعتماد التصريح" class="btn-primary"
                            invisible="state != 'draft'"
                            groups="brandzo_warehouse.group_bz_gate_officer"/>
                    <button name="action_reset_draft" type="object"
                            string="إعادة لمسودة" invisible="state != 'approved'"
                            groups="brandzo_warehouse.group_bz_gate_officer"/>
                    <button name="action_cancel" type="object" string="إلغاء"
                            invisible="state == 'cancel'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,approved"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="ملغى" bg_color="text-bg-danger"
                            invisible="state != 'cancel'"/>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="الشحنة">
                            <field name="picking_id"/>
                            <field name="partner_id"/>
                            <field name="scheduled_date"/>
                        </group>
                        <group string="المركبة والسائق">
                            <field name="vehicle_plate"/>
                            <field name="driver_name"/>
                            <field name="driver_id_number"/>
                            <field name="transporter"/>
                        </group>
                    </group>
                    <group string="الاعتماد" invisible="state != 'approved'">
                        <field name="approver_id"/>
                        <field name="approval_date"/>
                    </group>
                    <field name="note" placeholder="ملاحظات..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- قائمة تصاريح البوابة -->
    <record id="view_bz_gate_pass_list" model="ir.ui.view">
        <field name="name">bz.gate.pass.list</field>
        <field name="model">bz.gate.pass</field>
        <field name="arch" type="xml">
            <list string="تصاريح البوابة"
                  decoration-success="state == 'approved'"
                  decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="picking_id"/>
                <field name="partner_id"/>
                <field name="vehicle_plate"/>
                <field name="driver_name"/>
                <field name="scheduled_date"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'draft'"
                       decoration-success="state == 'approved'"/>
            </list>
        </field>
    </record>

    <record id="action_bz_gate_pass" model="ir.actions.act_window">
        <field name="name">تصاريح البوابة</field>
        <field name="res_model">bz.gate.pass</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
