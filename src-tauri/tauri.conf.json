{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Brandzo Hub",
  "version": "1.0.0",
  "identifier": "ly.brandzo.hub",
  "build": {
    "frontendDist": "https://albarshi996.github.io/warehouse-system/"
  },
  "app": {
    "windows": [
      {
        "title": "Brandzo Hub — نظام إدارة المستودعات",
        "width": 1280,
        "height": 820,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
