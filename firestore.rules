rules_version = '2';

/*
 * ═══════════════════════════════════════════════════════════════════
 *  قواعد أمان Firestore — Brandzo Hub
 * ═══════════════════════════════════════════════════════════════════
 *  ⚠️ الحالة قبل هذه القواعد: قاعدة البيانات كانت مفتوحة للعالم —
 *     أي شخص يقرأ ويكتب ويحذف دون حساب (مُثبت بالاختبار 2026-07-14).
 *
 *  المبادئ:
 *   1. لا شيء بلا تسجيل دخول.
 *   2. الأدوار لا يعدّلها إلا المدير العام (وإلا رقّى كل موظّف نفسه).
 *   3. سجلّ المسح **غير قابل للتعديل أو الحذف** — التاريخ لا يُزوَّر
 *      (التصحيح يكون بقيد جديد، لا بمحو القديم).
 *
 *  كيف تنشرها:
 *   Firebase Console → Firestore Database → Rules → الصق هذا الملف → Publish
 * ═══════════════════════════════════════════════════════════════════
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // ── دوال مساعدة ──────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasProfile() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // تمهيد المدير العام بالبريد — يطابق التمهيد في authService.js.
    // ضروري لكسر الحلقة المفرغة: بلا مستند دور لا صلاحية، وبلا صلاحية
    // لا يمكن إنشاء مستند الدور. عدّل البريد هنا وهناك معاً عند الحاجة.
    function isBootstrapAdmin() {
      return signedIn() && request.auth.token.email == 'albarshi.96@gmail.com';
    }

    function isAdmin() {
      return isBootstrapAdmin() || (signedIn() && hasProfile() && myRole() == 'admin');
    }

    function isManager() {
      return isBootstrapAdmin() ||
             (signedIn() && hasProfile() && myRole() in ['admin', 'warehouse_manager']);
    }

    // كاتبو جرد المركبات: دور «الحركة» + المديرَان (تعاون المخازن والحركة).
    function isFleetWriter() {
      return isBootstrapAdmin() ||
             (signedIn() && hasProfile() && myRole() in ['admin', 'warehouse_manager', 'fleet']);
    }

    // ── المستخدمون والأدوار ──────────────────────────────────────
    // القراءة لأي مُصادَق (الواجهة تحتاج معرفة دور المستخدم).
    // الكتابة للمدير العام فقط — وإلا استطاع أي مستخدم ترقية نفسه.
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // ── العمليات المخزنية ────────────────────────────────────────
    match /operations/{opId} {
      allow read: if signedIn();
      allow create: if signedIn();
      // الإقفال والملخّص للمديرين فقط؛ ولا حذف للعمليات إطلاقاً.
      allow update: if isManager();
      allow delete: if false;

      // سجلّ المسح: إضافة فقط — لا تعديل ولا حذف (سجلّ تدقيق دائم).
      match /scans/{scanId} {
        allow read: if signedIn();
        allow create: if signedIn()
                      && request.resource.data.byUid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── المستندات (محرّك النماذج — ROADMAP §11) ──────────────────
    //
    // ⚠️ ازدواج مقصود: أدوار الاعتماد أدناه تكرّر ما في مخطّطات
    //    `src/services/documents/schemas/*.js`. القواعد لا تستورد JS، فلا
    //    مفرّ. **عدّلهما معًا** — تمامًا كبريد تمهيد الأدمن أعلاه.
    function approveRoles(docType) {
      return docType == 'GRN' ? ['qc_inspector', 'warehouse_manager'] : [];
    }
    function completeRoles(docType) {
      return docType == 'GRN' ? ['storekeeper', 'warehouse_manager'] : [];
    }

    match /documents/{docId} {
      function isCreator() {
        return signedIn() && resource.data.createdByUid == request.auth.uid;
      }
      // الحقول التي لا يجوز أن تتغيّر بعد الإنشاء — أي منها = تزوير هويّة المستند.
      function immutableKept() {
        return request.resource.data.type == resource.data.type
               && request.resource.data.createdByUid == resource.data.createdByUid
               && request.resource.data.createdAt == resource.data.createdAt;
      }
      // الرقم الرسمي يُكتب مرّة واحدة: من null إلى قيمة، ثم لا يتغيّر أبدًا.
      function numberWriteOnce() {
        return resource.data.number == null
               || request.resource.data.number == resource.data.number;
      }
      function movingTo(states) {
        return request.resource.data.state in states;
      }

      allow read: if signedIn();

      // يولد مسودّةً باسم صاحبه وبلا رقم — لا أحد يُنشئ مستندًا معتمَدًا ابتداءً.
      allow create: if signedIn()
                    && request.resource.data.createdByUid == request.auth.uid
                    && request.resource.data.state == 'draft'
                    && request.resource.data.number == null;

      // ثلاث بوّابات لا رابع لها:
      //  (أ) صاحب المستند يحرّر مسودّته أو يُرسلها.
      //  (ب) صاحب دور الاعتماد يبتّ في المُرسَل: يعتمد أو يرفض.
      //  (ج) صاحب دور الإنهاء يُنهي **المعتمَد** فقط.
      //
      // 🥇 هنا يصير حارس الجودة حقيقيًّا: لا طريق من 'submitted' إلى 'done'.
      //    من أراد إنهاء استلام فعليه المرور باعتماد مفتّش الجودة — ولو زوّر
      //    الواجهة كلّها، فهذه القاعدة على الخادم لا تُتجاوَز.
      allow update: if signedIn() && immutableKept() && numberWriteOnce() && (
                      isAdmin()
                      || (isCreator()
                          && resource.data.state in ['draft', 'rejected']
                          && movingTo(['draft', 'submitted']))
                      || (hasProfile()
                          && resource.data.state == 'submitted'
                          && myRole() in approveRoles(resource.data.type)
                          && movingTo(['approved', 'rejected']))
                      || (hasProfile()
                          && resource.data.state == 'approved'
                          && myRole() in completeRoles(resource.data.type)
                          && movingTo(['done']))
                    );

      // لا حذف لمستند أبدًا. المستند الخاطئ يُرفض ويبقى أثره.
      allow delete: if false;

      // سجلّ التدقيق: إضافة فقط باسم فاعلها — لا تعديل ولا حذف (نمط scans).
      match /audit/{entryId} {
        allow read: if signedIn();
        allow create: if signedIn()
                      && request.resource.data.byUid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── عدّادات الترقيم التسلسلي ──────────────────────────────────
    // العدّاد يزيد **واحدًا فقط في كل مرّة، وإلى الأمام فقط**: لا تصفير ولا
    // قفز. بهذا يستحيل إنتاج رقمين متطابقين أو إعادة استخدام رقم محروق.
    match /counters/{counterId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.seq == 1;
      allow update: if signedIn() && request.resource.data.seq == resource.data.seq + 1;
      allow delete: if false;
    }

    // ── التوظيف (بيانات حسّاسة: أسماء · هواتف · سير · رواتب) ─────
    // قراءةً وكتابةً للمديرَين فقط (قرار المالك 2026-07-16) — حتى القراءة،
    // بخلاف بقية المجموعات، لأن بيانات المرشحين ليست شأن كل مصادق.
    match /candidates/{candidateId} {
      allow read, create, update: if isManager();
      allow delete: if false; // المرشح المرفوض يبقى أثره — لا محو للتاريخ.

      match /files/{fileId} {
        allow read, create, update: if isManager();
        allow delete: if false;
      }
      // سجلّ التدقيق: إضافة فقط باسم فاعلها — نمط scans نفسه.
      match /audit/{entryId} {
        allow read: if isManager();
        allow create: if isManager()
                      && request.resource.data.byUid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── بيانات المخزون ───────────────────────────────────────────
    match /Items_Master/{docId} {
      allow read: if signedIn();
      allow write: if isManager();
    }

    match /warehouses/{docId} {
      allow read: if signedIn();
      allow write: if isManager();
    }

    // ── الأرصدة (كمية لكل صنف×مخزن×تشغيلة) ───────────────────────
    // القراءة لأي مصادَق (الجرد والمستندات تحتاج معرفة الرصيد)؛ الكتابة
    // للمديرَين فقط. لا حذف — الرصيد الصفري يُكتب لا يُمحى (نفاد مخزن حقيقة).
    match /balances/{balId} {
      allow read: if signedIn();
      allow write: if isManager();
      allow delete: if false;
    }

    // سجلّات الوارد والصادر: إضافة فقط — لا محو للتاريخ.
    match /Inbound_Log/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /Outbound_Log/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    // ── جرد المركبات (سجلّ الأسطول الحيّ — إدارة الحركة) ─────────────────
    // القراءة لأي مصادَق (المخازن والموارد البشرية تطالعان السجلّ)، والكتابة
    // لدور «الحركة» والمديرَين. لا حذف لمركبة ولا لفحص ولا لمحضر — نمط
    // `operations` نفسه: التصحيح بقيد جديد لا بمحو التاريخ.
    match /vehicles/{vehicleId} {
      allow read: if signedIn();
      allow create, update: if isFleetWriter();
      allow delete: if false;

      // نماذج الفحص الكاملة (تاريخ المركبة).
      match /inspections/{inspId} {
        allow read: if signedIn();
        allow create, update: if isFleetWriter();
        allow delete: if false;
      }
      // طلبات الصيانة (مفتوحة → منجزة).
      match /maintenance/{reqId} {
        allow read: if signedIn();
        allow create, update: if isFleetWriter();
        allow delete: if false;
      }
      // سجلّ تغيير الزيت.
      match /oil_changes/{entryId} {
        allow read: if signedIn();
        allow create, update: if isFleetWriter();
        allow delete: if false;
      }
      // محاضر الحوادث.
      match /accidents/{caseId} {
        allow read: if signedIn();
        allow create, update: if isFleetWriter();
        allow delete: if false;
      }
    }

    // ── طلبات التوظيف من الإدارات (منفصلة عن `candidates` الحسّاسة) ──────
    // أي إدارة تكتب طلبها فقط (مسمّى وظيفي + بطاقة تعريفية)، وتقرأ طلباتها
    // هي دون سواها — لا تختلط ببيانات مرشحين حقيقيين ولا تراها إدارة أخرى.
    // المدير العام ومدير المستودع يراجعان كل الطلبات. لا حذف — نمط
    // `operations` نفسه: إنشاء حرّ، تحديث للمديرَين، حذف ممنوع دائمًا.
    match /hiring_requests/{reqId} {
      allow read: if isManager()
                  || (signedIn() && resource.data.createdByUid == request.auth.uid);
      allow create: if signedIn()
                    && request.resource.data.createdByUid == request.auth.uid
                    && request.resource.data.status == 'submitted';
      allow update: if isManager();
      allow delete: if false;

      // السيرة الاختيارية: يقرؤها صاحب الطلب أو المدير، ويكتبها صاحب الطلب
      // نفسه (مطابقةً لملكيّة البطاقة الأم). لا حذف — نمط candidates/files.
      match /files/{fileId} {
        allow read: if isManager()
                    || (signedIn()
                        && get(/databases/$(database)/documents/hiring_requests/$(reqId)).data.createdByUid == request.auth.uid);
        allow create, update: if signedIn()
                    && get(/databases/$(database)/documents/hiring_requests/$(reqId)).data.createdByUid == request.auth.uid;
        allow delete: if false;
      }
    }

    // ── الافتراضي: امنع كل ما لم يُذكر صراحةً ────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
